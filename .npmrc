# Hoist every dependency to the workspace-root node_modules (npm-like flat
# layout), the way bun's `bunfig.toml` `linker = "hoisted"` did. The @kolu/*
# surface libraries are hydrated into node_modules/@kolu/<name> as raw .ts
# (scripts/hydrate-kolu-packages.sh) and their transitive imports (@orpc/*,
# zod, solid-js) must resolve by walking up to ONE root node_modules — pnpm's
# default isolated linker would scatter those under .pnpm and leave the
# hydrated sources unable to resolve anything.
node-linker=hoisted
