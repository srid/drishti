{ kind: \"unseen\" } | { kind: \"seen\"; value: V } = {\n   272\t    kind: \"unseen\",\n   273\t  };\n   274\t  return {\n   275\t    noteFrame(next) {\n   276\t      if (lastSeen.kind === \"unseen\") {\n   277\t        lastSeen = { kind: \"seen\", value: next }; // first frame: a value, not a change\n   278\t        return;\n   279\t      }\n   280\t      // Hot-path short-circuit: with no handler registered, the baseline just\n   281\t      // advances to the latest frame in O(1) — a handler added later sees only\n   282\t      // changes FROM that point on, so it never needs the intervening compares.\n   283\t      // This keeps the deep `framesEqual` off every cell/stream/collection frame\n   284\t      // for the overwhelmingly common no-`updated`-handler case.\n   285\t      if (handlers.size === 0) {\n   286\t        lastSeen = { kind: \"seen\", value: next };\n   287\t        return;\n   288\t      }\n   289\t      if (framesEqual(lastSeen.value, next)) return; // equal reconnect snapshot: silent\n   290\t      const prev = lastSeen.value;\n   291\t      lastSeen = { kind: \"seen\", value: next };\n   292\t      // Hand consumers a SNAPSHOT: the store writes these frames through Solid's\n   293\t      // `reconcile`, which adopts a frame and mutates it on the next write — a\n   294\t      // retained `{prev, next}` would silently mutate out from under the\n   295\t      // consumer. Clone only on a firing change with subscribers, so the hot\n   296\t      // no-op path pays nothing. (`framesEqual` above ran on the pre-write\n   297\t      // values, so the baseline compare is unaffected by the mutation.)\n   298\t      const change: CellChange<V> = {\n   299\t        prev: structuredClone(prev),\n   300\t        next: structuredClone(next),\n   301\t      };\n   302\t      // Guard each handler: one consumer's throwing `updated` callback must not\n   303\t      // abort fan-out to the others, and — critically for a SHARED subscription\n   304\t      // behin