{"type":"item.completed","item":{"id":"item_11","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba node_modules/@kolu/surface-map/src/scoped.ts | sed -n '240,410p'; nl -ba node_modules/@kolu/surface-app/src/notify.ts | sed -n '1,260p'; nl -ba node_modules/@kolu/surface/src/reactor.ts | sed -n '180,360p'; nl -ba node_modules/@kolu/surface/src/server.ts | sed -n '1420,1490p'\"","aggregated_output":"   240\t  }\n   241\t\n   242\t  const get = (key: K): T | undefined => index().get(enc(key));\n   243\t\n   244\t  return { active: activeScope, get };\n   245\t}\n   246\t\n   247\t// ── watchByEntry — the eager attention watcher ────────────────────────────\n   248\t\n   249\t/** A point read of a watched entry: its current value and whether the read is\n   250\t *  LIVE (our link to that host is up and it is connected) or STALE (link down —\n   251\t *  the last value is held, so a chip DIMS rather than lies). */\n   252\texport interface WatchedValue<A> {\n   253\t  readonly kind: \"live\" | \"stale\";\n   254\t  readonly value: A;\n   255\t}\n   256\t\n   257\t/** The read-only bound cell a watcher consumes — the structural subset of\n   258\t *  `entry.cells.<name>` it needs: `.use()` yielding the current value and the raw\n   259\t *  `Subscription` (whose `updated` carries the change pairs). A real\n   260\t *  `ReadOnlyBoundCell<A>` (a get-only cell like `urgency`/`alerts`) satisfies it. */\n   261\texport interface WatchableCell<A> {\n   262\t  use(opts?: { onError?: (err: Error) => void }): {\n   263\t    value: Accessor<A | undefined>;\n   264\t    sub: Subscription<A>;\n   265\t  };\n   266\t}\n   267\t\n   268\texport interface WatchByEntry<K, A> {\n   269\t  /** A point read of a key's current watched value + liveness, or `undefined`\n   270\t   *  when the key is not a member OR has no frame yet (a mirror stays silent\n   271\t   *  until the authority speaks — see `@kolu/surface-remote`). Read inside a\n   272\t   *  reactive scope; chips read this. There is deliberately NO `total()`:\n   273\t   *  aggregation is APP policy (kolu sums awaiting terminals across live hosts;\n   274\t   *  drishti counts hosts in trouble — a sum would be noise), so the watcher\n   275\t   *  hands facts and each app folds. */\n   276\t  get(key: K): WatchedValue<A> | undefined;\n   277\t}\n   278\t\n   279\t/**\n   280\t * Watch EVERY member's per-entry cell EAGERLY and fire `onRaise` for newly-raised\n   281\t * ids. The opposite laziness from `scopedByEntry` on the SAME membership kernel:\n   282\t * an attention watcher must be eager because a background host is precisely the\n   283\t * one you need to hear from.\n   284\t *\n   285\t * `cell` selects the per-entry cell (`e => e.cells.urgency`); `items` extracts\n   286\t * STABLE ids from its value (`v => v.awaitingIds`) — stability is the app's one\n   287\t * obligation, and what makes \"same item, not a new one\" decidable. Raise\n   288\t * detection is a pure SET-DIFF over the framework's `updated` `{prev, next}`\n   289\t * pairs: `items(next) ∖ items(prev)` are the newly-raised ids. That one line is\n   290\t * the payoff of the completed Dynamic — no hand-held previous frame, no frame\n   291\t * classification, no per-window memory: the change-iff-fired law upstream is what\n   292\t * makes a plain set-diff trustworthy.\n   293\t *\n   294\t * Runs under the caller's reactive owner (throws otherwise — it holds a keyArray\n   295\t * of per-key roots). Everything a key opens (its cell subscription, its `updated`\n   296\t * registration) tears down when the key leaves membership.\n   297\t */\n   298\texport function watchByEntry<\n   299\t  KS extends z.ZodType,\n   300\t  ES extends SurfaceSpec,\n   301\t  Cause extends string,\n   302\t  A,\n   303\t  // Ids are `PropertyKey` (string / number / symbol), never objects: raise\n   304\t  // detection is a `Set` diff, and object ids — reconstructed fresh from each\n   305\t  // wire frame — would compare by REFERENCE and re-raise every frame. Constrain\n   306\t  // it so an object-id `items` is a compile error, not a silent every-frame\n   307\t  // storm.\n   308\t  I extends PropertyKey,\n   309\t>(\n   310\t  client: SurfaceMapClient<KS, ES, Cause>,\n   311\t  cell: (entry: Entry<ES, Cause>) => WatchableCell<A>,\n   312\t  items: (value: A) => I[],\n   313\t  onRaise: (key: z.infer<KS>, raised: I[], value: A) => void,\n   314\t  opts?: {\n   315\t    /** Called when a watched entry's cell subscription ERRORS. Without this a\n   316\t     *  per-host cell failure would only dim the point read to `stale` (the badge\n   317\t     *  stops counting it) and otherwise VANISH — no log, no user surface. Defaults\n   318\t     *  to a stderr log (like `deriveCell`) so a failure is never invisible; pass a\n   319\t     *  handler to route it to a toast/health surface, or `() => {}` to opt into\n   320\t     *  silent-dim deliberately. This is the app's error CHANNEL — distinct from the\n   321\t     *  live/stale point read, matching the map API's other `use({ onError })` seams\n   322\t     *  rather than fattening `WatchedValue` with an error arm. */\n   323\t    onError?: (key: z.infer<KS>, err: Error) => void;\n   324\t  },\n   325\t): WatchByEntry<z.infer<KS>, A> {\n   326\t  type K = z.infer<KS>;\n   327\t\n   328\t  requireOwner(\"watchByEntry\");\n   329\t\n   330\t  const { enc, memberKeys } = membershipKernel(client);\n   331\t\n   332\t  const onError =\n   333\t    opts?.onError ??\n   334\t    ((key: K, err: Error): void => {\n   335\t      console.error(\n   336\t        `watchByEntry: watched cell subscription errored for key ${String(enc(key))}`,\n   337\t        err,\n   338\t      );\n   339\t    });\n   340\t\n   341\t  // EAGER: the source is the FULL member set, so every host gets a root the moment\n   342\t  // it joins — a background host is subscribed and heard from without ever being\n   343\t  // activated. (scopedByEntry feeds `activated` here instead; the kernel is one.)\n   344\t  const index = keyedRoots<\n   345\t    K,\n   346\t    { value: Accessor<A | undefined>; live: Accessor<boolean> }\n   347\t  >(enc, memberKeys, (key) => {\n   348\t    const entry = client.entry(key);\n   349\t    // Route this entry's subscription error to the app's `onError` channel (default\n   350\t    // logs) so a per-host cell failure is never invisible — the `live` memo below\n   351\t    // dims the point read to `stale`, but the FAILURE itself surfaces here.\n   352\t    const { value, sub } = cell(entry).use({\n   353\t      onError: (err) => onError(key, err),\n   354\t    });\n   355\t    // Raise detection RIDES `updated` (the change-iff-fired law) — a watcher with\n   356\t    // no change channel would silently return values and never raise, defeating\n   357\t    // its one job. Fail fast rather than degrade: a watched cell MUST be minted by\n   358\t    // the surface factories (they always populate `updated`); optional chaining\n   359\t    // here would swallow the contract.\n   360\t    if (!sub.updated) {\n   361\t      throw new Error(\n   362\t        \"watchByEntry: the watched cell's subscription has no `updated` — a watcher \" +\n   363\t          \"needs the change-iff-fired channel to detect raised ids. Select a cell \" +\n   364\t          \"minted by the surface factories (`entry.cells.<name>`), not a hand-assembled one.\",\n   365\t      );\n   366\t    }\n   367\t    // Raise detection: a pure set-diff over the framework's honest change pairs.\n   368\t    // Dedupe `next`'s ids first (`Set` on `PropertyKey`) so a frame that repeats\n   369\t    // an id can't raise it twice.\n   370\t    const off = sub.updated(({ prev, next }) => {\n   371\t      const before = new Set<I>(items(prev));\n   372\t      const raised = [...new Set<I>(items(next))].filter(\n   373\t        (id) => !before.has(id),\n   374\t      );\n   375\t      if (raised.length > 0) onRaise(key, raised, next);\n   376\t    });\n   377\t    onCleanup(off);\n   378\t    // Point reads answer honestly. A value is LIVE only when the host link is up\n   379\t    // (`state().kind === \"connected\"`; foldState downgrades a stale `connected` to\n   380\t    // `warming`) AND this cell's own subscription is neither errored nor ended —\n   381\t    // urgency is not a `liveWhen` gate, so an errored/completed cell would NOT\n   382\t    // downgrade `entry.state()`, and reporting its frozen value as `live` would\n   383\t    // let a consumer count stale urgency. A cell in that state reads STALE (its\n   384\t    // last value dims) rather than lying live.\n   385\t    const live = createMemo(\n   386\t      () =>\n   387\t        entry.state().kind === \"connected\" &&\n   388\t        !sub.error() &&\n   389\t        !(sub.complete?.() ?? false),\n   390\t    );\n   391\t    return { value, live };\n   392\t  });\n   393\t\n   394\t  const get = (key: K): WatchedValue<A> | undefined => {\n   395\t    const world = index().get(enc(key));\n   396\t    if (!world) return undefined;\n   397\t    const v = world.value();\n   398\t    if (v === undefined) return undefined; // no frame yet — the mirror is silent\n   399\t    return { kind: world.live() ? \"live\" : \"stale\", value: v };\n   400\t  };\n   401\t\n   402\t  return { get };\n   403\t}\n     1\t/**\n     2\t * `notify` — OS-notification delivery at the origin's ONE service worker.\n     3\t *\n     4\t * The last hop of cross-host attention: actually showing an OS notification from\n     5\t * a PWA. It is short but MINED, and both landmines are real-world:\n     6\t *\n     7\t *   1. **`getRegistration()`, not `.ready`.** `navigator.serviceWorker.ready`\n     8\t *      resolves only when an active worker EXISTS — in any context where none\n     9\t *      registers (a dev server, a degraded boot) it HANGS FOREVER, silently\n    10\t *      killing the notification path. `getRegistration()` answers honestly,\n    11\t *      including \"there isn't one\", which we handle.\n    12\t *   2. **The service worker shows it, never `new Notification()`.** In an\n    13\t *      installed (standalone) PWA the page-context constructor throws \"Illegal\n    14\t *      constructor\" — notifications MUST go through `registration.showNotification()`.\n    15\t *      Code that works in a browser tab dies precisely when the user commits to\n    16\t *      the app.\n    17\t *\n    18\t * Both are why delivery is a framework piece at all: ONE seam at the origin's one\n    19\t * service worker, instead of N windows each attempting their own delivery. The\n    20\t * `tag` carries the multi-window discipline — two open windows must not both ping\n    21\t * you, and with a tag-keyed `show` they can't (the OS REPLACES the same-tag\n    22\t * notification instead of stacking a duplicate). The click payload comes back to\n    23\t * `onClick` as plain `data` the APP routes; the framework does not know what\n    24\t * clicking attention means — but it does VALIDATE the envelope (`parse`) before\n    25\t * routing, so a `{}` a stale worker or a pre-upgrade notification substitutes is\n    26\t * dropped loudly rather than mis-routed.\n    27\t *\n    28\t * The worker itself (`NOTIFICATION_SW_SOURCE`) handles `notificationclick` two\n    29\t * ways: it focuses an OPEN window and `postMessage`s `{ type: SW_MESSAGE_TYPE,\n    30\t * data }` (the live path `onClick` receives), OR — with NO window open — it opens\n    31\t * one with the payload encoded in a URL param (`NOTIFICATION_DATA_PARAM`), which\n    32\t * `onClick` reads once at startup so the one-action click survives a cold start.\n    33\t */\n    34\t\n    35\timport {\n    36\t  NOTIFICATION_ACK_TYPE,\n    37\t  NOTIFICATION_CLICK_ID_PARAM,\n    38\t  NOTIFICATION_DATA_PARAM,\n    39\t  SW_MESSAGE_TYPE,\n    40\t} from \"./index\";\n    41\t\n    42\t/** A notification to show. `tag` keys the multi-window replace; `data` is the\n    43\t *  opaque routing payload handed back to {@link Notify.onClick}. */\n    44\texport interface NotifyOptions<D> {\n    45\t  /** The dedup/replace key — the OS replaces a same-`tag` notification rather\n    46\t   *  than stacking a duplicate (so two windows never double-ping). Route it per\n    47\t   *  attention item, e.g. `${host}/${itemId}`. */\n    48\t  tag: string;\n    49\t  title: string;\n    50\t  body?: string;\n    51\t  icon?: string;\n    52\t  /** Opaque routing payload — echoed to `onClick` when the notification is\n    53\t   *  clicked (structured-cloneable; the worker `postMessage`s it verbatim, and\n    54\t   *  JSON-encodes it into the cold-start URL param). */\n    55\t  data: D;\n    56\t}\n    57\t\n    58\t/** The origin's notification seam. `D` is the app's own click-routing payload\n    59\t *  shape (kolu: a `{ kind }`-discriminated union). */\n    60\texport interface Notify<D> {\n    61\t  /** Request OS notification permission (idempotent — resolves `true` when\n    62\t   *  already granted, `false` when denied). Delivery is a no-op until granted. */\n    63\t  requestPermission(): Promise<boolean>;\n    64\t  /** Show (or replace, by `tag`) a notification through the service worker.\n    65\t   *  A no-op — never a throw or a hang — where there is no worker, no active\n    66\t   *  worker, or no permission; an operational browser failure is caught and\n    67\t   *  logged, never rejected. So a caller may safely fire-and-forget it. */\n    68\t  show(opts: NotifyOptions<D>): Promise<void>;\n    69\t  /** Subscribe to notification CLICKS. Fires with the clicked notification's\n    70\t   *  VALIDATED `data` (via `parse`; a malformed/stale envelope is dropped with a\n    71\t   *  warning, never routed). Covers both the live postMessage path and the\n    72\t   *  cold-start URL-param handoff. Returns an unsubscribe fn. */\n    73\t  onClick(handler: (data: D) => void): () => void;\n    74\t}\n    75\t\n    76\tconst swAvailable = (): boolean =>\n    77\t  typeof navigator !== \"undefined\" && \"serviceWorker\" in navigator;\n    78\t\n    79\t/** Build a {@link Notify} for a payload shape `D`. `parse` validates an incoming\n    80\t *  click envelope — the framework relays only well-formed payloads, so a stale\n    81\t *  notification carrying a pre-upgrade shape (or a `{}` a degraded worker\n    82\t *  substitutes) is dropped, never mis-routed. Return `undefined` to reject. */\n    83\texport function createNotify<D>(\n    84\t  parse: (data: unknown) => D | undefined,\n    85\t): Notify<D> {\n    86\t  // Route one raw click envelope: validate, then hand the app its typed payload.\n    87\t  const route = (raw: unknown, handler: (data: D) => void): void => {\n    88\t    const parsed = parse(raw);\n    89\t    if (parsed === undefined) {\n    90\t      console.warn(\n    91\t        \"notify.onClick: dropping malformed/stale click payload\",\n    92\t        raw,\n    93\t      );\n    94\t      return;\n    95\t    }\n    96\t    handler(parsed);\n    97\t  };\n    98\t\n    99\t  // Ack the delivering worker to silence its retry loop. Best-effort: mid\n   100\t  // worker-replacement `postMessage` can throw (the delivering worker went\n   101\t  // `redundant`). A throw here must NOT propagate — by the time we ack, the click\n   102\t  // has already been routed AND the id durably claimed, so the worker's fallback\n   103\t  // navigation is deduped at `consumePendingClick`; the click still fires exactly once.\n   104\t  const ackDelivery = (source: ServiceWorker, id: string): void => {\n   105\t    try {\n   106\t      source.postMessage({ type: NOTIFICATION_ACK_TYPE, id });\n   107\t    } catch (err) {\n   108\t      console.warn(\"notify.onClick: ack postMessage failed\", err);\n   109\t    }\n   110\t  };\n   111\t\n   112\t  return {\n   113\t    async requestPermission(): Promise<boolean> {\n   114\t      if (typeof Notification === \"undefined\") return false;\n   115\t      if (Notification.permission === \"granted\") return true;\n   116\t      if (Notification.permission === \"denied\") return false;\n   117\t      try {\n   118\t        return (await Notification.requestPermission()) === \"granted\";\n   119\t      } catch (err) {\n   120\t        // A browser that rejects the prompt (or an insecure context) must not\n   121\t        // turn a fire-and-forget request into an unhandled rejection.\n   122\t        console.warn(\"notify.requestPermission failed\", err);\n   123\t        return false;\n   124\t      }\n   125\t    },\n   126\t\n   127\t    async show(opts): Promise<void> {\n   128\t      if (!swAvailable()) return;\n   129\t      // Permission is the app's to request; attempting a show without it would\n   130\t      // only reject — silent no-op until granted (landmine-free fire-and-forget).\n   131\t      if (\n   132\t        typeof Notification !== \"undefined\" &&\n   133\t        Notification.permission !== \"granted\"\n   134\t      ) {\n   135\t        return;\n   136\t      }\n   137\t      try {\n   138\t        // Landmine 1: getRegistration(), never `.ready`.\n   139\t        const reg = await navigator.serviceWorker.getRegistration();\n   140\t        // A registration can exist WITHOUT an active worker (installing/waiting);\n   141\t        // `showNotification` on it rejects. `reg.active` is the honest gate.\n   142\t        if (!reg?.active) return; // no worker to deliver through — not a hang\n   143\t        // Landmine 2: the worker shows it; `tag` makes the OS replace, never stack.\n   144\t        await reg.showNotification(opts.title, {\n   145\t          tag: opts.tag,\n   146\t          body: opts.body,\n   147\t          icon: opts.icon,\n   148\t          data: opts.data,\n   149\t        });\n   150\t      } catch (err) {\n   151\t        // Delivery is best-effort: a failed OS notification is logged, never\n   152\t        // rejected into an unhandled promise the fire-and-forget caller discards.\n   153\t        console.warn(\"notify.show failed\", err);\n   154\t      }\n   155\t    },\n   156\t\n   157\t    onClick(handler): () => void {\n   158\t      if (!swAvailable()) return () => {};\n   159\t      // The worker retries `postMessage` until we ACK (a message is dropped if this\n   160\t      // page installed its listener AFTER the worker first posted — an open-but-still-\n   161\t      // loading window). Exactly-once live delivery needs BOTH halves: an ackable\n   162\t      // sender to stop the retry loop, AND a durable dedup record to suppress the\n   163\t      // fallback-navigate re-delivery of the same id. If EITHER is missing we do NOT\n   164\t      // route live — we stay silent, let the retry horizon lapse, and let the worker's\n   165\t      // URL fallback navigation be the SINGLE route (deduped there too). This is what\n   166\t      // keeps the one-action guarantee from silently degrading when `event.source` is\n   167\t      // absent or `sessionStorage` is unavailable.\n   168\t      const listener = (event: MessageEvent): void => {\n   169\t        const msg = event.data as\n   170\t          | { type?: string; data?: unknown; id?: unknown }\n   171\t          | undefined;\n   172\t        if (msg?.type !== SW_MESSAGE_TYPE) return;\n   173\t        const id = typeof msg.id === \"string\" ? msg.id : undefined;\n   174\t        if (id !== undefined) {\n   175\t          // The ack must reach the EXACT worker that delivered this message\n   176\t          // (`event.source`), NOT `navigator.serviceWorker.controller`: mid\n   177\t          // worker-replacement the controller can be a DIFFERENT worker than the one\n   178\t          // retrying, so acking the controller would never reach the delivering loop.\n   179\t          const source = event.source as ServiceWorker | null | undefined;\n   180\t          // No ackable sender ⇒ we can't stop the retry loop; defer to the fallback\n   181\t          // navigation as the single route rather than routing live un-acked.\n   182\t          if (!source) return;\n   183\t          if (wasRouted(id)) {\n   184\t            // Already routed (a retry arriving before our earlier ack landed) — ack to\n   185\t            // silence the loop, but never route twice.\n   186\t            ackDelivery(source, id);\n   187\t            return;\n   188\t          }\n   189\t          // Durably CLAIM the id first, and only if the record persisted: a non-durable\n   190\t          // record couldn't survive the fallback navigation, so routing live would risk a\n   191\t          // double-fire — defer to the fallback route instead (stay silent, no ack).\n   192\t          if (!markRouted(id)) return;\n   193\t          // ROUTE before the ack. The ack (`postMessage`) can throw when the delivering\n   194\t          // worker turned redundant mid-replacement; if we acked first and it threw, the\n   195\t          // id would be claimed with the handler never run, and the worker's fallback\n   196\t          // navigation would be suppressed at `consumePendingClick` — ZERO actions. By\n   197\t          // routing first, the click has fired exactly once no matter how the ack goes.\n   198\t          route(msg.data, handler);\n   199\t          ackDelivery(source, id);\n   200\t          return;\n   201\t        }\n   202\t        route(msg.data, handler);\n   203\t      };\n   204\t      navigator.serviceWorker.addEventListener(\"message\", listener);\n   205\t      // Cold-start / fallback handoff: a click that couldn't be delivered live opened\n   206\t      // or navigated a window with the payload + id in the URL params. Consume it ONCE\n   207\t      // here (dedup by id, then strip the params so a reload can't re-route) — the same\n   208\t      // validated `route` path, so a cold click and a live click behave alike.\n   209\t      consumePendingClick(handler, route);\n   210\t      return () =>\n   211\t        navigator.serviceWorker.removeEventListener(\"message\", listener);\n   212\t    },\n   213\t  };\n   214\t}\n   215\t\n   216\t/** A bounded FIFO of recently-routed click ids, kept in `sessionStorage` so it\n   217\t *  survives the worker's durable fallback NAVIGATION (a live route followed by a\n   218\t *  fallback navigate must not fire twice). Capped so it can never grow without\n   219\t *  bound (F27). `sessionStorage` is per-tab and can be unavailable (private mode,\n   220\t *  storage disabled by policy) — but the exactly-once contract does NOT depend on\n   221\t *  silently degrading here: the live-click path only records-and-routes when the\n   222\t *  record is DURABLE (`markRouted` returns `true`), otherwise it stays silent and\n   223\t *  lets the worker's URL fallback perform the single route. A storage failure is\n   224\t *  surfaced (warned), never swallowed into a double-fire. */\n   225\tconst ROUTED_IDS_KEY = \"kolu.surface-app.notify.routedIds\";\n   226\tconst ROUTED_IDS_CAP = 64;\n   227\t\n   228\t/** Read the FIFO. `[]` on a genuinely-empty store; a storage READ failure returns\n   229\t *  `undefined` so callers can tell \"durably empty\" from \"storage broken\". */\n   230\tfunction readRoutedIds(): string[] | undefined {\n   231\t  try {\n   232\t    const raw = sessionStorage.getItem(ROUTED_IDS_KEY);\n   233\t    const parsed: unknown = raw === null ? [] : JSON.parse(raw);\n   234\t    return Array.isArray(parsed)\n   235\t      ? parsed.filter((x): x is string => typeof x === \"string\")\n   236\t      : [];\n   237\t  } catch (err) {\n   238\t    console.warn(\"notify: routed-id store read failed\", err);\n   239\t    return undefined;\n   240\t  }\n   241\t}\n   242\t\n   243\tfunction wasRouted(id: string): boolean {\n   244\t  return readRoutedIds()?.includes(id) ?? false;\n   245\t}\n   246\t\n   247\t/** Durably record `id` as routed. Returns `true` iff the record is now persisted\n   248\t *  (already present counts) — a `false` means storage was unavailable and the\n   249\t *  caller must NOT route live (the fallback navigation will be the single route). */\n   250\tfunction markRouted(id: string): boolean {\n   251\t  const ids = readRoutedIds();\n   252\t  if (ids === undefined) return false; // storage unreadable — not durable\n   253\t  if (ids.includes(id)) return true;\n   254\t  ids.push(id);\n   255\t  while (ids.length > ROUTED_IDS_CAP) ids.shift();\n   256\t  try {\n   257\t    sessionStorage.setItem(ROUTED_IDS_KEY, JSON.stringify(ids));\n   258\t    return true;\n   259\t  } catch (err) {\n   260\t    console.warn(\"notify: routed-id store write failed\", err);\n   180\t        // Install failed: undo the membership so we neither leak the listener nor\n   181\t        // report a subscription the caller can't unsubscribe (we rethrow).\n   182\t        listeners.delete(onEmit);\n   183\t        throw err;\n   184\t      }\n   185\t      return () => {\n   186\t        listeners.delete(onEmit);\n   187\t        if (listeners.size === 0) teardown();\n   188\t      };\n   189\t    },\n   190\t    dispose() {\n   191\t      listeners.clear();\n   192\t      teardown();\n   193\t    },\n   194\t  };\n   195\t}\n   196\t\n   197\t// ── scan — an accumulation over a source ──────────────────────────────────\n   198\t\n   199\t/** The fold step: `(state, frame) => nextState`. Returning the PREV reference\n   200\t *  (`===`) means \"no change\" — the level holds and nothing publishes. */\n   201\texport type ScanStep<S, F> = (state: S, frame: F) => S;\n   202\t\n   203\t/** Accumulate a source's occurrences into a level. Each emission steps the fold\n   204\t *  exactly once; the carried state is the node's value.\n   205\t *\n   206\t *  **Durability** is deliberately absent in phase 0: a scan seeds from its plain\n   207\t *  `initial` and does not survive a restart (drishti's `alerts` wants exactly\n   208\t *  this — a fresh process re-derives its level from fresh samples). The durable\n   209\t *  variant — seeding from a store — is a later phase.\n   210\t *\n   211\t *  **The stop-hold error law.** A step that throws STOPS the derivation: the\n   212\t *  source subscription is disposed, the last state is HELD (never a fabricated\n   213\t *  reset), the throw is logged loudly, and `stopped` latches so the surface's\n   214\t *  liveness can tell a frozen derivation from a legitimately quiet one. It never\n   215\t *  heals — recovery is a restart. (The stateless-compute error policy —\n   216\t *  log-skip-continue — is a later phase's `computed`; a `scan` carries state, so\n   217\t *  continuing past a throw would fold onto a corrupt accumulator.) */\n   218\texport function scan<F, S>(\n   219\t  src: Source<F>,\n   220\t  initial: S,\n   221\t  step: ScanStep<S, F>,\n   222\t): ScanNode<S> {\n   223\t  const state = signal<S>(initial);\n   224\t  const stopped = signal(false);\n   225\t  let unsubscribe: (() => void) | undefined;\n   226\t  // A stop requested DURING `src.subscribe` (a source that emits synchronously on\n   227\t  // install, whose first frame throws) has no `unsubscribe` handle yet — it is\n   228\t  // assigned only after `subscribe` returns. Latch the request here so the\n   229\t  // post-subscribe wiring disposes the handle the instant it exists, instead of\n   230\t  // leaving the stopped scan subscribed (guarded but leaking its source tap).\n   231\t  let stopRequested = false;\n   232\t\n   233\t  const stop = (): void => {\n   234\t    if (unsubscribe) {\n   235\t      unsubscribe();\n   236\t      unsubscribe = undefined;\n   237\t    } else {\n   238\t      stopRequested = true; // handle not yet assigned (sync emit during subscribe)\n   239\t    }\n   240\t  };\n   241\t\n   242\t  const handle = src.subscribe((frame) => {\n   243\t    if (stopped.peek()) return;\n   244\t    let next: S;\n   245\t    try {\n   246\t      next = step(state.peek(), frame);\n   247\t    } catch (err) {\n   248\t      console.error(\n   249\t        \"reactor: scan step threw — stopping derivation, holding last value\",\n   250\t        err,\n   251\t      );\n   252\t      // Latch `stopped` BEFORE tearing down: the stop-hold law's observable fact\n   253\t      // must hold even if `stop()`/cleanup throws — a failed unsubscribe can\n   254\t      // never un-stop or replace the latched state.\n   255\t      stopped.value = true;\n   256\t      stop();\n   257\t      return;\n   258\t    }\n   259\t    // \"step returning the prev reference ⇒ no publish\": a held level writes\n   260\t    // nothing to the signal, so no downstream recompute and no wire frame. The\n   261\t    // member's own `equals` remains the final wire dedup point for values that\n   262\t    // differ by reference but not by content.\n   263\t    if (next !== state.peek()) state.value = next;\n   264\t  });\n   265\t  // If a synchronous install-emit already stopped us, dispose the handle now\n   266\t  // (never retain it); otherwise keep it as the live unsubscribe.\n   267\t  if (stopRequested) handle();\n   268\t  else unsubscribe = handle;\n   269\t\n   270\t  return {\n   271\t    value: state,\n   272\t    stopped,\n   273\t    dispose: () => stop(),\n   274\t  };\n   275\t}\n   276\t\n   277\t// ── derived.cell — publish a graph node as a cell ─────────────────────────\n   278\t\n   279\t/** The deps a `derived.cell(...)` contributes to `implementSurface`'s\n   280\t *  `cells.<key>` slot: an in-memory `store` plus the `connect` hook the runtime\n   281\t *  fires once after wiring. It rides the EXISTING cell connect seam with zero\n   282\t *  runtime surgery — the same `{ store, connect }` shape `deriveCell` already\n   283\t *  uses — plus the derived brand the boot walk reads to enforce wire-read-only. */\n   284\texport interface DerivedCell<T> {\n   285\t  /** READ-ONLY by construction and stateless: `get` reads the node's CURRENT level\n   286\t   *  live (`node.value.peek()`); `set` THROWS (the graph is the one writer). Typed\n   287\t   *  `CellStore<T>` so a derived cell still satisfies `CellImplDeps`, but the dep\n   288\t   *  carries NO writable backing store at all — nothing reflectively reachable\n   289\t   *  (`Object.getOwnPropertySymbols`) can poison the wire snapshot. `implementSurface`\n   290\t   *  builds its OWN private serving store (seeded from this `get`) and drives it\n   291\t   *  exclusively through the `connect` seam. */\n   292\t  readonly store: CellStore<T>;\n   293\t  readonly connect: (cell: { set: (next: T) => void }) => void;\n   294\t  /** Tear down the connect effect and the backing node. */\n   295\t  readonly dispose: () => void;\n   296\t  readonly [DERIVED_CELL_BRAND]: true;\n   297\t}\n   298\t\n   299\t/** The reactor's wire exits. Phase 0 ships `cell`; `collection` is a later\n   300\t *  phase. Namespaced (`derived.cell`) so the read-only-projection intent is\n   301\t *  legible at every declaration site. */\n   302\texport const derived = {\n   303\t  /** Publish a graph node as a cell. The cell is wire-read-only by construction\n   304\t   *  (the boot walk crashes if it declares a write verb) and seeds from the\n   305\t   *  node's current level by an eager pull at wiring — truth, never a fabricated\n   306\t   *  default (a throw at seed time is a boot crash). Every subsequent level\n   307\t   *  change flows through the member's own `equals → onWrite → store.set →\n   308\t   *  bus.publish` gate via the `connect` setter, so the wire dedup point is\n   309\t   *  unchanged and a spec-`equals`-equal recompute never crosses the wire. */\n   310\t  cell<T>(node: GraphNode<T>): DerivedCell<T> {\n   311\t    let disposeEffect: (() => void) | undefined;\n   312\t\n   313\t    return {\n   314\t      // Public store is a READ-ONLY, STATELESS facade: `get` pulls the node's\n   315\t      // current level live (its serving endpoint IS the authority — an eager\n   316\t      // truth, never a fabricated default); `set` throws (fail-fast one-writer\n   317\t      // guard). The dep carries NO writable store — `implementSurface` builds and\n   318\t      // owns its own private serving store (seeded from this `get`) and writes it\n   319\t      // only through the `connect` seam, so nothing a holder can reflect off this\n   320\t      // dep can poison the wire snapshot `cellHandlers.get` serves.\n   321\t      store: {\n   322\t        get: () => node.value.peek(),\n   323\t        set: () => {\n   324\t          throw new Error(\n   325\t            \"derived cell store is graph-owned (one writer) — the graph is its only writer; do not set it directly\",\n   326\t          );\n   327\t        },\n   328\t      },\n   329\t      [DERIVED_CELL_BRAND]: true,\n   330\t      connect: (cell) => {\n   331\t        // The connect seam: an engine effect subscribes the node's level and\n   332\t        // pushes every change through the ctx setter (the member's write gate).\n   333\t        // The first synchronous run pushes the seed, which the member's `equals`\n   334\t        // dedups against the identical store seed — so wiring a derived cell\n   335\t        // publishes nothing until the level genuinely moves.\n   336\t        disposeEffect = effect(() => {\n   337\t          cell.set(node.value.value);\n   338\t        });\n   339\t      },\n   340\t      dispose: () => {\n   341\t        disposeEffect?.();\n   342\t        node.dispose();\n   343\t      },\n   344\t    };\n   345\t  },\n   346\t};\n  1420\t  deps: ImplementSurfaceDeps<S>,\n  1421\t  identity?: BakedIdentity,\n  1422\t): { namespaces: Record<string, Record<string, unknown>>; ctx: SurfaceCtx<S> } {\n  1423\t  const spec = surface.spec;\n  1424\t\n  1425\t  const cellsCtx: Record<string, unknown> = {};\n  1426\t  const collectionsCtx: Record<string, unknown> = {};\n  1427\t  const namespaces: Record<string, Record<string, unknown>> = {};\n  1428\t\n  1429\t  // ── Cells ────────────────────────────────────────────────────────────\n  1430\t  for (const [key, rawSpec] of Object.entries(spec.cells ?? {})) {\n  1431\t    const cellSpec = rawSpec as CellSpec<unknown, unknown>;\n  1432\t    const bus = deps.channel<unknown>(`${key}:changed`);\n  1433\t    // biome-ignore lint/suspicious/noExplicitAny: walk-by-string of the keyed deps\n  1434\t    const cellDeps = (deps.cells as any)?.[key] as\n  1435\t      | {\n  1436\t          store: CellStore<unknown>;\n  1437\t          patch?: (c: unknown, p: unknown) => unknown;\n  1438\t          equals?: (a: unknown, b: unknown) => boolean;\n  1439\t          onMutate?: (p: unknown, c: unknown) => void;\n  1440\t          onWrite?: (next: unknown) => void;\n  1441\t          forward?: CellForward<unknown, unknown>;\n  1442\t          hasSnapshot?: () => boolean;\n  1443\t          connect?: (c: { set: (v: unknown) => void }) => void | Promise<void>;\n  1444\t        }\n  1445\t      | undefined;\n  1446\t    if (!cellDeps) {\n  1447\t      throw new Error(`implementSurface: missing deps for cell \"${key}\"`);\n  1448\t    }\n  1449\t    // Boot narrowing for a reactor `derived.cell(...)`: the graph is the\n  1450\t    // member's ONE writer, so a derived cell is wire-read-only BY CONSTRUCTION.\n  1451\t    // Crash loudly if it declares any write verb (`set`/`patch`/`test__set`) —\n  1452\t    // a second writer is a defect, not a knob, and this makes it a boot crash\n  1453\t    // rather than a silent double-writer. The derived value still reaches the\n  1454\t    // wire through the `connect` seam below; `get` is its only exposed verb.\n  1455\t    if (isDerivedCellDeps(cellDeps)) {\n  1456\t      const writeVerbs = resolveCellVerbs(cellSpec).filter((v) => v !== \"get\");\n  1457\t      if (writeVerbs.length > 0) {\n  1458\t        throw new Error(\n  1459\t          `implementSurface: derived cell \"${key}\" is wire-read-only (its derivation is the one writer) but declares write verb(s) [${writeVerbs.join(\", \")}] — declare verbs: [\"get\"] (test__set included).`,\n  1460\t        );\n  1461\t      }\n  1462\t    }\n  1463\t    // Mirror-never-fabricate, fail-fast: a write-forwarding cell (a re-serve\n  1464\t    // mirror — the ONLY producer of `forward`) MUST carry the `hasSnapshot` gate,\n  1465\t    // or `cellHandlers.get` would fall back to `?? true` and serve the seeded\n  1466\t    // default as if the authority had sent it — the exact fabrication the gate\n  1467\t    // exists to forbid. Crash at boot rather than let the impossible state ship.\n  1468\t    if (cellDeps.forward && !cellDeps.hasSnapshot) {\n  1469\t      throw new Error(\n  1470\t        `implementSurface: forwarding cell \"${key}\" must declare a hasSnapshot gate (mirror-never-fabricate) — a mirror serves no frame until the authority's first fold. See CellHandlerDeps.hasSnapshot.`,\n  1471\t      );\n  1472\t    }\n  1473\t    // Spec-declared `patch` wins; deps may override (rare). Cells with\n  1474\t    // `patchSchema` need one or the other — error loudly if both are\n  1475\t    // missing rather than silently accepting full-replacement semantics.\n  1476\t    const patchFn = cellSpec.patch ?? cellDeps.patch;\n  1477\t    if (cellSpec.patchSchema && !patchFn) {\n  1478\t      throw new Error(\n  1479\t        `implementSurface: cell \"${key}\" has patchSchema but no patch fn (declare on spec or pass via deps)`,\n  1480\t      );\n  1481\t    }\n  1482\t    // Spec-declared `equals` wins; deps may override (rare). Same\n  1483\t    // resolution rule as `patch`.\n  1484\t    const equalsFn = cellSpec.equals ?? cellDeps.equals;\n  1485\t    const onWriteFn = cellDeps.onWrite;\n  1486\t    // A derived cell's PUBLIC `store` is a read-only, stateless facade (its `get`\n  1487\t    // pulls the graph node's current level, its `set` throws — the graph is the one\n  1488\t    // writer). The dep carries NO writable store, so nothing a holder can reflect off\n  1489\t    // it can poison the wire snapshot. `implementSurface` builds and OWNS the private\n  1490\t    // serving store here — seeded from the facade's `get` (the node's current level) —\n","exit_code":0,"status":"completed"}}
