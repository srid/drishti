{"type":"item.completed","item":{"id":"item_14","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba packages/agent/src/main.ts | sed -n '370,480p'; nl -ba packages/common/src/alerts.test.ts; nl -ba packages/common/src/alerts.ts; nl -ba packages/common/src/surface.ts | sed -n '180,280p'; rg -n \\\"Notification|permission|notify\\\" README.md docs packages/app/src --glob '\"'!App.tsx'\"' --glob '\"'!wire.ts'\"'\"","aggregated_output":"   370\t    } catch (err) {\n   371\t      log(`tick error: ${(err as Error).message}`);\n   372\t    }\n   373\t  };\n   374\t  const interval = setInterval(() => {\n   375\t    void tick();\n   376\t  }, POLL_INTERVAL_MS);\n   377\t  // Kick the first enumeration immediately and fire-and-forget, so processes\n   378\t  // and network populate within one scan rather than after a full poll\n   379\t  // interval — but off the serving critical path, so the handshake still\n   380\t  // roundtrips now. (The broken-stdout smoke test writes to fd 1 in `main`,\n   381\t  // before we ever serve.)\n   382\t  void tick();\n   383\t\n   384\t  // `implementSurface` returns a fragment with shape `{ surface: ... }`;\n   385\t  // passing it straight to `serveOverStdio`'s `StandardRPCHandler`\n   386\t  // double-wraps the path (`/surface/surface/...`) and every client\n   387\t  // request 404s. Wrap once via `implement(contract).router(...)` to\n   388\t  // flatten the prefix.\n   389\t  const router = implement(surface.contract).router({ ...fragment.router });\n   390\t\n   391\t  log(\"serving surface over stdio (read=stdin, write=stdout)\");\n   392\t  // Heartbeat while blocked on the first request. A healthy connect\n   393\t  // roundtrips sub-second; if this keeps ticking up to ~30s the parent's\n   394\t  // connect watchdog is about to kill us — and these lines (forwarded to\n   395\t  // the parent's log) show the agent was alive and waiting the whole time,\n   396\t  // pinning the stall on the parent→agent handshake rather than the remote.\n   397\t  const servingSince = Date.now();\n   398\t  const waitingHeartbeat = setInterval(() => {\n   399\t    log(\n   400\t      `waiting for first RPC (${Math.round((Date.now() - servingSince) / 1000)}s)…`,\n   401\t    );\n   402\t  }, 5000);\n   403\t  await serve({\n   404\t    // biome-ignore lint/suspicious/noExplicitAny: implementSurface's Lazy<Router> spread isn't accepted by oRPC's Router<any, T> input type; runtime shape is valid.\n   405\t    router: router as any,\n   406\t    onFirstRequest: () => {\n   407\t      clearInterval(waitingHeartbeat);\n   408\t      log(`first RPC received — link is live (pid=${process.pid})`);\n   409\t    },\n   410\t  });\n   411\t  clearInterval(waitingHeartbeat);\n   412\t  clearInterval(interval);\n   413\t  log(\"stdin closed — agent exiting\");\n   414\t}\n   415\t\n   416\tasync function main(): Promise<void> {\n   417\t  const args = process.argv.slice(2);\n   418\t  if (!args.includes(\"--stdio\")) usage();\n   419\t  const brokenStdoutLog = args.includes(\"--broken-stdout-log\");\n   420\t\n   421\t  const reader = createProcReader();\n   422\t  log(`drishti-agent: os=${reader.os}, pid=${process.pid}`);\n   423\t\n   424\t  // Deliberately broken variant — bypass console.log redirection and write\n   425\t  // directly to fd 1, before any RPC. This is exactly the wire-corrupting bug\n   426\t  // `serveOverStdio` documents: the parent's client peer sees garbage and\n   427\t  // surfaces a frame-parse failure rather than hanging. Smoke-test only.\n   428\t  if (brokenStdoutLog) {\n   429\t    process.stdout.write(\"DEBUG: this line corrupts the protocol channel\\n\");\n   430\t  }\n   431\t\n   432\t  await serveAgent(reader);\n   433\t}\n   434\t\n   435\t// Guard the entrypoint so importing this module (e.g. from main.test.ts to\n   436\t// exercise `serveAgent` directly) doesn't spawn the agent. Mirrors build.ts.\n   437\tif (import.meta.main) {\n   438\t  main().catch((err) => {\n   439\t    log(`fatal: ${(err as Error).message}\\n${(err as Error).stack ?? \"\"}`);\n   440\t    process.exit(1);\n   441\t  });\n   442\t}\n     1\timport { describe, expect, it } from \"bun:test\";\n     2\timport {\n     3\t  type Alerts,\n     4\t  applyHysteresis,\n     5\t  alertsEqual,\n     6\t  type MetricsFrame,\n     7\t  NO_ALERTS,\n     8\t} from \"./alerts\";\n     9\t\n    10\tconst frame = (over: Partial<MetricsFrame>): MetricsFrame => ({\n    11\t  cpu: 0,\n    12\t  mem: 0,\n    13\t  disk: 0,\n    14\t  ...over,\n    15\t});\n    16\t\n    17\tdescribe(\"applyHysteresis\", () => {\n    18\t  it(\"raises a metric at the 80% threshold\", () => {\n    19\t    const next = applyHysteresis(NO_ALERTS, frame({ cpu: 80 }));\n    20\t    expect(next.items).toEqual([\"cpu\"]);\n    21\t  });\n    22\t\n    23\t  it(\"does not raise just below the threshold\", () => {\n    24\t    const next = applyHysteresis(NO_ALERTS, frame({ cpu: 79.9 }));\n    25\t    expect(next.items).toEqual([]);\n    26\t  });\n    27\t\n    28\t  it(\"holds by returning the PREV reference in the 70-80 dead band\", () => {\n    29\t    const raised = applyHysteresis(NO_ALERTS, frame({ cpu: 85 }));\n    30\t    // Falls into the dead band (>=70, <80): an already-raised alert stays\n    31\t    // raised, and — crucially — the SAME reference comes back so `scan`\n    32\t    // publishes nothing.\n    33\t    const held = applyHysteresis(raised, frame({ cpu: 75 }));\n    34\t    expect(held).toBe(raised);\n    35\t  });\n    36\t\n    37\t  it(\"holds (prev reference) when an un-raised metric sits in the dead band\", () => {\n    38\t    const held = applyHysteresis(NO_ALERTS, frame({ cpu: 75 }));\n    39\t    expect(held).toBe(NO_ALERTS);\n    40\t  });\n    41\t\n    42\t  it(\"clears only once the metric falls below 70%\", () => {\n    43\t    const raised = applyHysteresis(NO_ALERTS, frame({ cpu: 90 }));\n    44\t    // 70 is still in the dead band — held.\n    45\t    expect(applyHysteresis(raised, frame({ cpu: 70 }))).toBe(raised);\n    46\t    // Below 70 clears.\n    47\t    const cleared = applyHysteresis(raised, frame({ cpu: 69 }));\n    48\t    expect(cleared.items).toEqual([]);\n    49\t  });\n    50\t\n    51\t  it(\"tracks each metric independently\", () => {\n    52\t    let state: Alerts = NO_ALERTS;\n    53\t    state = applyHysteresis(state, frame({ cpu: 95, mem: 10, disk: 10 }));\n    54\t    expect(state.items).toEqual([\"cpu\"]);\n    55\t\n    56\t    // Raise mem and disk while cpu stays high; ids stay in metric order.\n    57\t    state = applyHysteresis(state, frame({ cpu: 95, mem: 88, disk: 82 }));\n    58\t    expect(state.items).toEqual([\"cpu\", \"mem\", \"disk\"]);\n    59\t\n    60\t    // Drop cpu below the clear edge; mem/disk remain raised.\n    61\t    state = applyHysteresis(state, frame({ cpu: 20, mem: 88, disk: 82 }));\n    62\t    expect(state.items).toEqual([\"mem\", \"disk\"]);\n    63\t  });\n    64\t});\n    65\t\n    66\tdescribe(\"alertsEqual\", () => {\n    67\t  it(\"equal iff the same set of ids is raised\", () => {\n    68\t    const a: Alerts = { items: [\"cpu\"] };\n    69\t    const b: Alerts = { items: [\"cpu\"] };\n    70\t    expect(alertsEqual(a, b)).toBe(true);\n    71\t\n    72\t    const c: Alerts = { items: [\"mem\"] };\n    73\t    expect(alertsEqual(a, c)).toBe(false);\n    74\t    expect(alertsEqual(a, NO_ALERTS)).toBe(false);\n    75\t  });\n    76\t});\n     1\t/**\n     2\t * The `alerts` domain — a pure threshold+hysteresis fold over host metrics.\n     3\t *\n     4\t * This module is AGENT-shared (drishti-common) and stays FRAMEWORK-FREE: it\n     5\t * carries only the wire schema (`AlertsSchema`), the value shapes, and the pure\n     6\t * fold (`applyHysteresis`) + its equality gate (`alertsEqual`). The reactor that\n     7\t * DRIVES this fold (`scan(metrics, NO_ALERTS, applyHysteresis)`) lives ONLY in\n     8\t * the agent's `main.ts` — importing `@kolu/surface/reactor` here would fold a\n     9\t * backend-only signals engine into the agent-shared graph, which the agent-boots\n    10\t * CI check forbids. So the graph is the agent's; the fold is everyone's.\n    11\t *\n    12\t * **Hysteresis, not a bare threshold.** A single cutoff at 80% would flap an\n    13\t * alert on and off every poll for a metric hovering at the line. Instead a metric\n    14\t * RAISES at `pct >= RAISE_PCT` (80) and only CLEARS once it falls below\n    15\t * `CLEAR_PCT` (70) — the dead band between the two is the \"hold\" region where an\n    16\t * already-raised alert stays raised and an un-raised one stays quiet. This is the\n    17\t * same Schmitt-trigger shape a thermostat uses.\n    18\t *\n    19\t * **The prev-reference hold is load-bearing.** When nothing crosses a threshold,\n    20\t * `applyHysteresis` returns the PREV `state` reference unchanged. The reactor's\n    21\t * `scan` reads that `===` as \"no change\" and publishes nothing — so a quiet tick\n    22\t * costs zero wire traffic. Returning a fresh-but-equal object would defeat that\n    23\t * gate; the cell's `equals` (`alertsEqual`) is the second line of defence for\n    24\t * values that differ by reference but not by content.\n    25\t */\n    26\t\n    27\timport { z } from \"zod\";\n    28\timport type { MetricKey } from \"./metrics\";\n    29\t\n    30\t/** A host's raw metric percentages for one poll tick (0-100). The fold's input\n    31\t *  frame — one number per metric, keyed by the shared `MetricKey`, decoupled\n    32\t *  from the wider `system` cell so the alert graph steps on exactly the numbers\n    33\t *  it thresholds, nothing more. */\n    34\texport type MetricsFrame = Record<MetricKey, number>;\n    35\t\n    36\t/** The metrics an alert can fire for — the SAME vocabulary the history chart\n    37\t *  keys on (`MetricKey`, single-sourced in `drishti-common/metrics`). Stable\n    38\t *  ids: `watchByEntry`'s set-diff decides \"same alert, not a new one\" on these,\n    39\t *  so they must not churn. */\n    40\texport type AlertId = MetricKey;\n    41\t\n    42\t/** The set of currently-raised alerts for one host — just the raised ids. The\n    43\t *  concept IS a set of metric ids, so the shape says so; the human word is a\n    44\t *  client-owned presentation lookup (`LABELS` in the app), never a wire fact. */\n    45\texport interface Alerts {\n    46\t  items: AlertId[];\n    47\t}\n    48\t\n    49\texport const AlertsSchema = z.object({\n    50\t  items: z.array(z.enum([\"cpu\", \"mem\", \"disk\"])),\n    51\t});\n    52\t\n    53\t/** The empty alert set — the fold's seed and the cell's gate-closed default. A\n    54\t *  fresh process re-derives its alerts from fresh samples (the fold carries no\n    55\t *  durable state), so booting with \"nothing raised\" is the honest start. */\n    56\texport const NO_ALERTS: Alerts = { items: [] };\n    57\t\n    58\t/** Raise once a metric reaches this percentage (0-100). */\n    59\tconst RAISE_PCT = 80;\n    60\t/** Clear only once a metric falls below this — the lower edge of the dead band\n    61\t *  that stops a hovering metric from flapping. */\n    62\tconst CLEAR_PCT = 70;\n    63\t\n    64\t/** The metrics folded, in a fixed order, so `applyHysteresis` iterates one list\n    65\t *  rather than three hand-copied blocks. */\n    66\tconst METRIC_IDS: readonly AlertId[] = [\"cpu\", \"mem\", \"disk\"];\n    67\t\n    68\t/**\n    69\t * Threshold+hysteresis fold: step the raised-alert set forward by one metric\n    70\t * frame.\n    71\t *\n    72\t * Per metric: RAISE (add the id) when it crosses up to `RAISE_PCT` while not\n    73\t * already raised; CLEAR (remove it) when it falls below `CLEAR_PCT` while raised;\n    74\t * otherwise HOLD. When NOTHING crosses — the common case — the PREV `state`\n    75\t * reference is returned unchanged, which the reactor's `scan` reads as \"no\n    76\t * publish\" (see the module docstring). A raise/clear returns a fresh `Alerts`.\n    77\t */\n    78\texport function applyHysteresis(state: Alerts, frame: MetricsFrame): Alerts {\n    79\t  const raised = new Set(state.items);\n    80\t  let changed = false;\n    81\t\n    82\t  for (const id of METRIC_IDS) {\n    83\t    const pct = frame[id];\n    84\t    const isRaised = raised.has(id);\n    85\t    if (!isRaised && pct >= RAISE_PCT) {\n    86\t      raised.add(id);\n    87\t      changed = true;\n    88\t    } else if (isRaised && pct < CLEAR_PCT) {\n    89\t      raised.delete(id);\n    90\t      changed = true;\n    91\t    }\n    92\t  }\n    93\t\n    94\t  // No threshold crossed — return the PREV reference so `scan` publishes\n    95\t  // nothing. This is REQUIRED, not an optimization: a fresh object here would\n    96\t  // step the graph every quiet tick.\n    97\t  if (!changed) return state;\n    98\t\n    99\t  // Rebuild in the fixed metric order so the id list is deterministic\n   100\t  // regardless of raise sequence.\n   101\t  return { items: METRIC_IDS.filter((id) => raised.has(id)) };\n   102\t}\n   103\t\n   104\t/** Equal iff the SAME set of alert ids is raised — the cell's `equals` gate.\n   105\t *  Only a raise or a clear (a change to the id set) crosses the wire. */\n   106\texport function alertsEqual(a: Alerts, b: Alerts): boolean {\n   107\t  if (a.items.length !== b.items.length) return false;\n   108\t  const ids = new Set(a.items);\n   109\t  return b.items.every((id) => ids.has(id));\n   110\t}\n   180\t    kind: z.literal(\"snapshot\"),\n   181\t    entries: z.array(z.tuple([PidSchema, ProcessSchema])),\n   182\t  }),\n   183\t  z.object({\n   184\t    kind: z.literal(\"delta\"),\n   185\t    upserts: z.array(z.tuple([PidSchema, ProcessSchema])),\n   186\t    removes: z.array(PidSchema),\n   187\t  }),\n   188\t]);\n   189\t\n   190\t/** One point in a host's metric history — CPU% and memory% at a wall-clock\n   191\t *  instant. Captured by the **parent** on each agent poll tick (the parent\n   192\t *  is the only tier that observes every tick regardless of which browser\n   193\t *  tabs are open) and retained in an in-memory ring for the life of the\n   194\t *  parent process. */\n   195\tconst MetricSampleSchema = z.object({\n   196\t  /** Wall-clock capture time, epoch ms. */\n   197\t  t: z.number(),\n   198\t  /** Mean busy-percentage across all cores at capture (0-100). */\n   199\t  cpu: z.number(),\n   200\t  /** Memory used as a percentage of total at capture (0-100). */\n   201\t  mem: z.number(),\n   202\t  /** Root-filesystem used as a percentage of total at capture (0-100). */\n   203\t  disk: z.number(),\n   204\t});\n   205\t\n   206\t/** Snapshot-then-delta `Stream<>` for the per-host metric-history ring —\n   207\t *  the same bulk-friendly shape as `processesSnapshot`. A new subscriber\n   208\t *  (a freshly-loaded browser, or a tab just switched to this host) gets the\n   209\t *  parent's entire ring in one `snapshot` frame, then one `delta` per poll\n   210\t *  tick. This is why history survives reloads and tab switches: the state\n   211\t *  lives in the parent, and every subscriber is re-seeded from it. */\n   212\tconst MetricHistoryMessage = z.discriminatedUnion(\"kind\", [\n   213\t  z.object({\n   214\t    kind: z.literal(\"snapshot\"),\n   215\t    samples: z.array(MetricSampleSchema),\n   216\t  }),\n   217\t  z.object({\n   218\t    kind: z.literal(\"delta\"),\n   219\t    sample: MetricSampleSchema,\n   220\t  }),\n   221\t]);\n   222\t\n   223\texport const surface = defineSurface({\n   224\t  cells: {\n   225\t    system: {\n   226\t      schema: SystemSchema,\n   227\t      default: DEFAULT_SYSTEM,\n   228\t    },\n   229\t    // Per-host raised-alert set — a threshold+hysteresis fold over the host's\n   230\t    // metrics (see `./alerts.ts`). Wire-READ-ONLY (`verbs: [\"get\"]`): the agent\n   231\t    // is the sole writer via `@kolu/surface/reactor`'s `derived.cell(scan(...))`,\n   232\t    // so the boot walk MUST see get-only here or it crashes on a write verb.\n   233\t    // `equals: alertsEqual` is the final wire dedup — a metric drifting within\n   234\t    // an already-raised level publishes nothing (same id set). This stays\n   235\t    // reactor-FREE: only schema/default/verbs/equals, no graph import (the\n   236\t    // reactor lives in the AGENT's main.ts, never in this agent-shared module).\n   237\t    alerts: {\n   238\t      schema: AlertsSchema,\n   239\t      default: NO_ALERTS,\n   240\t      verbs: [\"get\"],\n   241\t      equals: alertsEqual,\n   242\t    },\n   243\t    // NOTE: no `connection` cell here. Link health is composed ONLY at the\n   244\t    // nix-host re-serve seam via `mirroredSurface(surface)` (`browserSurface`\n   245\t    // below) — the agent serves this connection-free base; the parent mirrors\n   246\t    // it and adds the cell, writing it off `session.onState` (kolu #1568).\n   247\t  },\n   248\t  collections: {\n   249\t    processes: {\n   250\t      keySchema: PidSchema,\n   251\t      schema: ProcessSchema,\n   252\t    },\n   253\t    /** Per-core CPU usage — small-N (typical 4-32) `Collection<K,T>`.\n   254\t     *  The host drill-in renders one bar per core, so per-key reactive identity\n   255\t     *  is the right shape. But every core ticks every poll, so the host view\n   256\t     *  reads the WHOLE collection — hence the opt-in `deltas` verb: the parent\n   257\t     *  re-serves all N cores in one coalesced frame per tick instead of one\n   258\t     *  per-key frame each (the per-key `get` path stays for \"watch one core\").\n   259\t     *  The fleet card reads the `system.cpuPct` aggregate and never subscribes\n   260\t     *  here at all. */\n   261\t    cpuCores: {\n   262\t      keySchema: z.number().int().nonnegative(),\n   263\t      schema: CpuCoreSchema,\n   264\t      verbs: [\"keys\", \"get\", \"upsert\", \"delete\", \"deltas\"],\n   265\t    },\n   266\t    /** Per-NIC network I/O — keyed by interface name, the same `Collection<K,T>`\n   267\t     *  shape as `cpuCores`. The host view reads the whole set (dozens of NICs,\n   268\t     *  most idle), so it opts into batched `deltas` too — dozens of per-key\n   269\t     *  frames per tick collapse to one. */\n   270\t    networkInterfaces: {\n   271\t      keySchema: z.string(),\n   272\t      schema: NetInterfaceSchema,\n   273\t      verbs: [\"keys\", \"get\", \"upsert\", \"delete\", \"deltas\"],\n   274\t    },\n   275\t  },\n   276\t  streams: {\n   277\t    processesSnapshot: {\n   278\t      inputSchema: z.object({}),\n   279\t      outputSchema: ProcessesSnapshotMessage,\n   280\t    },\n","exit_code":1,"status":"failed"}}
