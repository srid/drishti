341\t  source: (signal: AbortSignal) => Promise<AsyncIterable<T>>,\n   342\t  options: Omit<SubscriptionOptions<T>, \"reduce\" | \"initial\">,\n   343\t): Subscription<T>;\n   344\texport function createSubscription<T, R>(\n   345\t  source: (signal: AbortSignal) => Promise<AsyncIterable<T>>,\n   346\t  options: SubscriptionOptions<T, R> & { initial: R },\n   347\t): Subscription<R>;\n   348\texport function createSubscription<T, R = T>(\n   349\t  source: (signal: AbortSignal) => Promise<AsyncIterable<T>>,\n   350\t  options?: SubscriptionOptions<T, R>,\n   351\t): Subscription<T | R> {\n   352\t  const reduce = options?.reduce as\n   353\t    | ((acc: T | R, item: T) => T | R)\n   354\t    | undefined;\n   355\t  const initial = options?.initial;\n   356\t\n   357\t  if (reduce && initial === undefined) {\n   358\t    throw new Error(\n   359\t      \"createSubscription: 'initial' is required when using 'reduce'\",\n   360\t    );\n   361\t  }\n   362\t\n   363\t  // Internal state as a store for fine-grained reactivity on object values.\n   364\t  // The store wraps the value in { v: T } so reconcile works on any T shape.\n   365\t  const [store, setStore] = createStore<{ v: T | R | undefined }>({\n   366\t    v: initial,\n   367\t  });\n   368\t  const [error, setError] = createSignal<Error | undefined>();\n   369\t  const [pending, setPending] = createSignal(true);\n   370\t  const [complete, setComplete] = createSignal(false);\n   371\t\n   372\t  function updateValue(next: T | R): void {\n   373\t    writeWrappedValue(setStore, next as T | R | undefined);\n   374\t  }\n   375\t\n   376\t  // The change-iff-fired half of the Dynamic — the ONE law shared with\n   377\t  // `createReactiveSubscription` via `createUpdatedTracker`.\n   378\t  const tracker = createUpdatedTracker<T | R>();\n   379\t\n   380\t  function toError(err: unknown): Error {\n   381\t    return err instanceof Error ? err : new Error(String(err));\n   382\t  }\n   383\t\n   384\t  // Single cleanup path: external signal OR internal AbortController + onCleanup.\n   385\t  // Never both — avoids dual lifecycle braiding.\n   386\t  const abortSignal =\n   387\t    options?.signal ??\n   388\t    (() => {\n   389\t      const controller = new AbortController();\n   390\t      onCleanup(() => controller.abort());\n   391\t      return controller.signal;\n   392\t    })();\n   393\t\n   394\t  // Consume the stream\n   395\t  void (async () => {\n   396\t    try {\n   397\t      const iterable = await source(abortSignal);\n   398\t      for await (const item of iterable) {\n   399\t        if (abortSignal.aborted) break;\n   400\t        const next = reduce ? reduce(store.v as T | R, item) : (item as T | R);\n   401\t        tracker.noteFrame(next); // fire `updated` on a genuine change, before the write\n   402\t        updateValue(next);\n   403\t        if (pending()) setPending(false);\n   404\t        if (error()) setError(undefined);\n   405\t      }\n   406\t      // Normal completion — the iterable ended because the server/map sent a TYPED\n   407\t      // end (not an abort: an aborted loop takes the `break` above and its\n   408\t      // `abortSignal.aborted` is already true here). Clear any lingering `pending`\n   409\t      // and signal the typed end so the dedup cache can evict this slot. An aborted\n   410\t      // (disposed) subscription reports nothing.\n   411\t      if (!abortSignal.aborted) {\n   412\t        if (pending()) setPending(false);\n   413\t        setComplete(true);\n   414\t        options?.onComplete?.();\n   415\t      }\n   416\t    } catch (err) {\n   417\t      if (!abortSignal.aborted) {\n   418\t        setError(toError(err));\n   419\t        if (pending()) setPending(false);\n   420\t      }\n   421\t    }\n   422\t  })();\n   423\t\n   424\t  const sub = Object.assign(() => store.v as (T | R) | undefined, {\n   425\t    error,\n   426\t    pending,\n   427\t    complete,\n   428\t    updated: tracker.updated,\n   429\t  }) as Subscription<T | R>;\n   430\t\n   431\t  if (options?.onError) {\n   432\t    wireSubscriptionError(sub, options.onError);\n   433\t  }\n   434\t\n   435\t  return sub;\n   436\t}\n   437\t\n   438\t/** Wire a per-consumer error handler onto a subscription's self-clearing `error()`\n   439\t *  signal, via an EDGE effect — fires once per rising error transition and clears\n   440\t *  with the signal (never the inline-in-catch double-fire, and never latching a\n   130\texport interface UseCellLocalResult<T, P>\n   131\t  extends Omit<UseCellResult<T, P>, \"value\"> {\n   132\t  value: Accessor<T>;\n   133\t}\n   134\t\n   135\texport function useCell<Name extends string, T extends object, P = T>(\n   136\t  cell: Cell<Name, T>,\n   137\t  options: UseCellLocalOptions<T, P>,\n   138\t): UseCellLocalResult<T, P>;\n   139\texport function useCell<Name extends string, T, P = T>(\n   140\t  cell: Cell<Name, T>,\n   141\t  options: UseCellServerOptions<T, P>,\n   142\t): UseCellResult<T, P>;\n   143\texport function useCell<Name extends string, T, P = T>(\n   144\t  cell: Cell<Name, T>,\n   145\t  options: UseCellOptions<T, P>,\n   146\t): UseCellResult<T, P> | UseCellLocalResult<T, P> {\n   147\t  if (options.authority === \"local\") {\n   148\t    return useCellLocal(\n   149\t      cell as Cell<Name, T & object>,\n   150\t      options as unknown as UseCellLocalOptions<T & object, P>,\n   151\t    ) as unknown as UseCellLocalResult<T, P>;\n   152\t  }\n   153\t  return useCellServer(cell, options as UseCellServerOptions<T, P>);\n   154\t}\n   155\t\n   156\tfunction toError(err: unknown): Error {\n   157\t  return err instanceof Error ? err : new Error(String(err));\n   158\t}\n   159\t\n   160\t/** Wrap a streaming procedure ref into the thunk shape `createSubscription`\n   161\t *  expects, threading `STREAM_RETRY` context so transport drops re-subscribe\n   162\t *  transparently, AND the subscription's own abort signal — so disposing the\n   163\t *  cell (the last consumer of a shared dedup slot leaving) cancels the wire\n   164\t *  stream instead of leaving it open with nothing left to read it. */\n   165\tfunction streamingThunk<T>(\n   166\t  source: StreamingProcedure<undefined, T>,\n   167\t): (signal: AbortSignal) => Promise<AsyncIterable<T>> {\n   168\t  return (signal) => source(undefined, { signal, context: STREAM_RETRY });\n   169\t}\n   170\t\n   171\tfunction useCellServer<Name extends string, T, P>(\n   172\t  _cell: Cell<Name, T>,\n   173\t  options: UseCellServerOptions<T, P>,\n   174\t): UseCellResult<T, P> {\n   175\t  // No wrapping `createRoot`: the subscription runs under the CALLER's owner — the\n   176\t  // keyed-cache slot when the surface client shares it, else the consumer's own\n   177\t  // owner — so it aborts when that owner disposes instead of leaking app-lifetime.\n   178\t  const sub = createSubscription(streamingThunk(options.source), {\n   179\t    onError: options.onError,\n   180\t    onComplete: options.onComplete,\n   181\t  });\n   182\t\n   183\t  async function callMutate(p: P): Promise<void> {\n   184\t    if (!options.mutate) {\n   185\t      throw new Error(\"useCell: no mutate handler provided\");\n   186\t    }\n   187\t    await options.mutate(p);\n   188\t  }\n   189\t\n   190\t  return {\n   191\t    value: () => sub(),\n   192\t    pending: sub.pending,\n   193\t    error: sub.error,\n   194\t    set: (next) => callMutate(next as unknown as P),\n   195\t    // Server authority has no local store to coalesce against — every write is\n   196\t    // a round-trip; the `opts` arg is accepted for signature parity and ignored.\n   197\t    patch: (p) => callMutate(p),\n   198\t    sub,\n   199\t  };\n   200\t}\n   201\t\n   202\tfunction useCellLocal<Name extends string, T extends object, P>(\n   203\t  _cell: Cell<Name, T>,\n   204\t  options: UseCellLocalOptions<T, P>,\n   205\t): UseCellLocalResult<T, P> {\n   206\t  const [store, setStore] = createStore<T>(options.initial);\n   207\t  // Mutable guard: once any server value arrives, seed the local store\n   208\t  // from it and never overwrite again. Server echoes after init must not\n   209\t  // stomp local mutations whose RPC hasn't round-tripped — the local\n   210\t  // store is authoritative thereafter. A reactive signal would fire\n   211\t  // unnecessary effects for a one-time transition.\n   212\t  let initialized = false;\n   213\t\n   214\t  // No wrapping `createRoot`: the subscription + its seed effect run under the\n   215\t  // CALLER's owner (the keyed-cache slot when shared, else the consumer's own owner),\n   216\t  // so they dispose with that owner instead of leaking app-lifetime.\n   217\t  const sub = createSubscription(streamingThunk(options.source), {\n   218\t    onError: options.onError,\n   219\t    onComplete: options.onComplete,\n   220\t  });\n   221\t  createEffect(\n   222\t    on(\n   223\t      () => sub(),\n   224\t      (server) => {\n   225\t        if (server !== undefined && !initialized) {\n   226\t          initialized = true;\n   227\t          setStore(reconcile(server as T));\n   228\t        }\n   229\t      },\n   230\t    ),\n   231\t  );\n   232\t\n   233\t  function applyLocal(p: P): void {\n   234\t    if (options.mergeIntoStore) {\n   235\t      options.mergeIntoStore(setStore, p);\n   236\t      return;\n   237\t    }\n   238\t    if (options.applyPatch) {\n   239\t      const next = options.applyPatch(store as T, p);\n   240\t      setStore(reconcile(next));\n   241\t      return;\n   242\t    }\n   243\t    // No patch helpers — treat P as T (full replacement).\n   244\t    setStore(reconcile(p as unknown as T));\n   245\t  }\n   246\t\n   247\t  // Coalesced server flush (opt-in via `coalesceMs`). `applyLocal` has already\n   248\t  // run by the time we enqueue, so the store is current; we defer only the\n   249\t  // server round-trip. Patches merge through `applyPatch` so a flush carries\n   250\t  // every key touched in the window, not just the last write.\n     1\t/**\n     2\t * `watchByEntry` — the eager per-member attention watcher, pinned end-to-end\n     3\t * over the in-process map harness. Proves: EAGER subscription (a background\n     4\t * member is watched without ever being activated), raise detection as a pure\n     5\t * SET-DIFF over `updated` `{prev, next}` pairs (a first frame never raises; a new\n     6\t * id raises once; a held id never re-raises; a cleared-then-re-raised id raises\n     7\t * again), and point reads that mark `live`/`stale` on link liveness.\n     8\t */\n     9\t\n    10\timport { createRoot } from \"solid-js\";\n    11\timport { describe, expect, it } from \"vitest\";\n    12\timport { watchByEntry } from \"./client\";\n    13\timport {\n    14\t  A,\n    15\t  B,\n    16\t  connected,\n    17\t  type HostKey,\n    18\t  makeEntry,\n    19\t  settle,\n    20\t  setup,\n    21\t} from \"./mapHarness.testlib\";\n    22\t\n    23\tinterface Raise {\n    24\t  host: HostKey;\n    25\t  ids: string[];\n    26\t}\n    27\t\n    28\tdescribe(\"watchByEntry — eager attention over entries membership\", () => {\n    29\t  it(\"watches a background member EAGERLY (never activated) and raises new ids\", async () => {\n    30\t    await createRoot(async (dispose) => {\n    31\t      const { client, addSession } = setup();\n    32\t      const raises: Raise[] = [];\n    33\t      const att = watchByEntry(\n    34\t        client,\n    35\t        (e) => e.cells.urgency,\n    36\t        (v) => [...v.awaitingIds],\n    37\t        (host, raised) => raises.push({ host, ids: [...raised] }),\n    38\t      );\n    39\t\n    40\t      const entry = makeEntry({ awaiting: 0, awaitingIds: [] });\n    41\t      addSession(A, entry.link, connected(0));\n    42\t      await settle();\n    43\t\n    44\t      // EAGER: the member is watched with NO activation. A first frame is a\n    45\t      // value, not a change — no raise. The point read reflects it, live.\n    46\t      expect(raises).toEqual([]);\n    47\t      expect(att.get(A)).toEqual({\n    48\t        kind: \"live\",\n    49\t        value: { awaiting: 0, awaitingIds: [] },\n    50\t      });\n    51\t\n    52\t      // A terminal starts awaiting → exactly one raise for the new id.\n    53\t      entry.setUrgency({ awaiting: 1, awaitingIds: [\"t1\"] });\n    54\t      await settle();\n    55\t      expect(raises).toEqual([{ host: A, ids: [\"t1\"] }]);\n    56\t\n    57\t      // A second id joins → the set-diff raises ONLY the new one (t1 is held).\n    58\t      entry.setUrgency({ awaiting: 2, awaitingIds: [\"t1\", \"t2\"] });\n    59\t      await settle();\n    60\t      expect(raises).toEqual([\n    61\t        { host: A, ids: [\"t1\"] },\n    62\t        { host: A, ids: [\"t2\"] },\n    63\t      ]);\n    64\t\n    65\t      dispose();\n    66\t    });\n    67\t  });\n    68\t\n    69\t  it(\"a held id never re-raises; a cleared-then-re-raised id raises again\", async () => {\n    70\t    await createRoot(async (dispose) => {\n    71\t      const { client, addSession } = setup();\n    72\t      const raises: Raise[] = [];\n    73\t      // The watcher runs via its per-key effects — no need to bind the handle.\n    74\t      watchByEntry(\n    75\t        client,\n    76\t        (e) => e.cells.urgency,\n    77\t        (v) => [...v.awaitingIds],\n    78\t        (host, raised) => raises.push({ host, ids: [...raised] }),\n    79\t      );\n    80\t      const entry = makeEntry({ awaiting: 0, awaitingIds: [] });\n    81\t      addSession(A, entry.link, connected(0));\n    82\t      await settle();\n    83\t\n    84\t      entry.setUrgency({ awaiting: 1, awaitingIds: [\"t1\"] });\n    85\t      await settle();\n    86\t      // A no-op re-publish of the SAME ids — no change, no raise (change-iff-fired).\n    87\t      entry.setUrgency({ awaiting: 1, awaitingIds: [\"t1\"] });\n    88\t      await settle();\n    89\t      // Cleared, then the same id raises again — it is genuinely new relative to\n    90\t      // the empty set, so it raises (not suppressed by a stale per-window memory).\n    91\t      entry.setUrgency({ awaiting: 0, awaitingIds: [] });\n    92\t      await settle();\n    93\t      entry.setUrgency({ awaiting: 1, awaitingIds: [\"t1\"] });\n    94\t      await settle();\n    95\t\n    96\t      expect(raises).toEqual([\n    97\t        { host: A, ids: [\"t1\"] },\n    98\t        { host: A, ids: [\"t1\"] },\n    99\t      ]);\n   100\t      dispose();\n   101\t    });\n   102\t  });\n   103\t\n   104\t  it(\"get() marks a member with a down link STALE, keeping its last value\", async () => {\n   105\t    await createRoot(async (dispose) => {\n   106\t      const { client, addSession, setState } = setup();\n   107\t      const att = watchByEntry(\n   108\t        client,\n   109\t        (e) => e.cells.urgency,\n   110\t        (v) => [...v.awaitingIds],\n   111\t        () => {},\n   112\t      );\n   113\t      const entry = makeEntry({ awaiting: 1, awaitingIds: [\"t1\"] });\n   114\t      addSession(A, entry.link, connected(0));\n   115\t      await settle();\n   116\t      expect(att.get(A)?.kind).toBe(\"live\");\n   117\t\n   118\t      // The host's link goes down → its chip must DIM, not lie: stale, last value held.\n   119\t      setState(A, { kind: \"failed\", reason: \"link died\" });\n   120\t      await settle();\n   121\t      const stale = att.get(A);\n   122\t      expect(stale?.kind).toBe(\"stale\");\n   123\t      expect(stale?.value).toEqual({ awaiting: 1, awaitingIds: [\"t1\"] });\n   124\t\n   125\t      dispose();\n   126\t    });\n   127\t  });\n   128\t\n   129\t  it(\"a non-member key reads undefined (no total(), no owner created)\", async () => {\n   130\t    await createRoot(async (dispose) => {\n   131\t      const { client, addSession } = setup();\n   132\t      const att = watchByEntry(\n   133\t        client,\n   134\t        (e) => e.cells.urgency,\n   135\t        (v) => [...v.awaitingIds],\n   136\t        () => {},\n   137\t      );\n   138\t      addSession(\n   139\t        A,\n   140\t        makeEntry({ awaiting: 0, awaitingIds: [] }).link,\n   141\t        connected(0),\n   142\t      );\n   143\t      await settle();\n   144\t      expect(att.get(B)).toBeUndefined(); // B never joined\n   145\t      dispose();\n   146\t    });\n   147\t  });\n   148\t});\n","exit_code":0,"status":"completed"}}
