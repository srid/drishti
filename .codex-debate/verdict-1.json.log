ws from: `App.tsx`'s `watchByEntry` over `hostMap` fires `notify.show`\n./packages/app/src/client/wire.ts:105:export const notify = createNotify<{ host: string; id: string }>((data) => {\n.lens-debate/comment.md\n.lens-debate/hickey-1.msg\n.lens-debate/hickey-3.msg\n.lens-debate/lowy-1.msg\n.lens-debate/lowy-2.msg\n.lens-debate/lowy-3.msg\npackages/common/src/alerts.test.ts:5:  alertsEqual,\npackages/common/src/alerts.test.ts:8:} from \"./alerts\";\npackages/common/src/alerts.test.ts:66:describe(\"alertsEqual\", () => {\npackages/common/src/alerts.test.ts:70:    expect(alertsEqual(a, b)).toBe(true);\npackages/common/src/alerts.test.ts:73:    expect(alertsEqual(a, c)).toBe(false);\npackages/common/src/alerts.test.ts:74:    expect(alertsEqual(a, NO_ALERTS)).toBe(false);\n","exit_code":0,"status":"completed"}}
