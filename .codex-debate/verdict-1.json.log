ires (never a\n  * raw link), so a silently half-open connection can no longer paint a\n  * green host-map dot either.\n  */\n \n import type { ContractRouterClient } from \"@orpc/contract\";\n import { createProcessIdEcho } from \"@kolu/surface-app/connect\";\n+import { createNotify } from \"@kolu/surface-app/notify\";\n import { connectSurfaces } from \"@kolu/surface-app/solid\";\n import { connectSurfaceMap } from \"@kolu/surface-map/client\";\n import { adminContract, adminSurfaces } from \"../common/admin-surface\";\n import { ADMIN_HOST_SENTINEL } from \"../common/host\";\n import { hostSurfaceMap } from \"../common/hostMap\";\n import type { browserSurface } from \"drishti-common/browser\";\n \n // ONE `pid` echo for the ONE socket. The parent mints a fresh `processId`\n // per boot; the echo threads the last-known one back as the `pid` query\n // param on every (re)connect so the parent recognizes a stale tab after a\n // restart and rejects it at the handshake. `App.tsx` feeds this via the\n // provider's `onProcessId` callback (the turnkey `{ ws, probe }` source\n // publishes each observed id); it's null until the first probe, so the\n // first connect omits the param.\n const echo = createProcessIdEcho();\n export const rememberServerProcessId = echo.remember;\n \n // The ONE WS URL — WITHOUT the `pid` (the echo appends it). `host=` is kept\n // as the routing sentinel `main.ts`'s upgrade handler still checks, though\n // there is now exactly one thing it can route to.\n function wsBase(): string {\n   const proto = location.protocol === \"https:\" ? \"wss:\" : \"ws:\";\n   return `${proto}//${location.host}/rpc/ws?host=${encodeURIComponent(ADMIN_HOST_SENTINEL)}`;\n }\n \n // Cold start can take 30+ seconds while the parent provisions the FIRST\n // host's agent via `nix copy`, so the connect deadline is bumped well past\n // partysocket's 4s default — without this, the socket flaps repeatedly\n // during the first connect.\n const BASE_SOCKET_OPTIONS = {\n   connectionTimeout: 60_000,\n   minReconnectionDelay: 2_000,\n   maxReconnectionDelay: 15_000,\n } as const;\n \n // The admin transport multiplexes TWO sibling surfaces (kolu#1197/#1201):\n // drishti's own `admin` surface (host-lifecycle procedures) and\n // surface-app's complete surface (`buildInfo` + the `identity.info` probe).\n // `connectSurfaces` splits the one link into a per-key client bundle and\n // folds them into ONE `health()` fact (`live` AND-reduced across siblings\n // off the one socket). It ALWAYS wires the half-open watchdog (it mints the\n // watchdog-backed `LiveSignal` every client — and now the host map too —\n // requires). The `<SurfaceAppProvider>` lifecycle over the SAME socket\n // (`App.tsx`) opts ITS own watchdog out (`heartbeat={false}`) so the socket\n // isn't double-watched; the lifecycle still retires the socket on a\n // stale-restart, so this opts out of self-retire (`retireOnStaleClose:\n // false`).\n const conn = connectSurfaces({\n   surfaces: adminSurfaces,\n   url: wsBase,\n   echo,\n   socketOptions: BASE_SOCKET_OPTIONS,\n   retireOnStaleClose: false,\n });\n \n export const ws = conn.ws;\n \n // ── The host MAP — a keyed map of remote surfaces: ONE entry surface\n //    (`browserSurface`) served N times, keyed by host. `host` is no longer a\n //    dedicated socket — every host's `system`/`cpuCores`/`processesSnapshot`/\n //    `connection` rides `hostMap.entry(host)` (a pure point lens) or\n //    `hostMap.useEntry(activeHost)` (a reactive lens that re-keys on\n //    switch). The map is dialled over the `hosts` SIBLING of `conn`'s\n //    BRANDED transport handle: `connectSurfaceMap` slices `hosts` from it\n //    and recovers the parent `connectSurfaces` watchdog `live` by\n //    construction (the handle is unforgeable), so every chip floors on the\n //    real socket — there is no raw `{ live }` seam to pass a\n //    green-over-dead accessor through.\n export const hostMap = connectSurfaceMap(hostSurfaceMap, conn.transport, \"hosts\");\n \n+// The origin's ONE notification seam (kolu W5, `@kolu/surface-app/notify`) —\n+// the last hop of cross-host attention. App-scoped alongside the host map it\n+// draws from: `App.tsx`'s `watchByEntry` over `hostMap` fires `notify.show`\n+// per newly-raised alert, and `notify.onClick` routes a click's `{ host, id }`\n+// back to drill into that host. The payload shape `D` is drishti's own routing\n+// key — the framework carries it opaquely and hands it back verbatim.\n+export const notify = createNotify<{ host: string; id: string }>((data) => {\n+  // Validate the click envelope the framework relays (a live postMessage or a\n+  // cold-start URL param) before routing — a stale/pre-upgrade notification, or a\n+  // `{}` a degraded worker substitutes, is dropped rather than routed to\n+  // `expandHost(undefined)`. Both fields are plain strings here (a host key and a\n+  // metric-series id), so a shape check is the whole validation.\n+  if (typeof data !== \"object\" || data === null) return undefined;\n+  const d = data as Record<string, unknown>;\n+  if (typeof d.host !== \"string\" || typeof d.id !== \"string\") return undefined;\n+  return { host: d.host, id: d.id };\n+});\n+\n /** The ONE membership-error handler for `hostMap.entries` — shared by every\n  *  whole-collection consumer (`App.tsx`'s reconcile effect, `TabStrip`'s\n  *  strip) so a membership-stream failure toasts once, not per-consumer. */\n export const onHostMembershipError = (err: Error): void => {\n   console.error(\"host membership subscription failed\", err);\n };\n \n // `connectSurfaceMap` types `entry(key).rpc` as `unknown` at the generic map\n // boundary (it sidesteps a TS2590 \"union too complex\" expansion under a\n // generic `ES`) — recover the CONCRETE contract here, the framework's\n // blessed \"cast `.rpc` to your concrete contract once at the wire boundary\".\n export type HostRpc = ContractRouterClient<typeof browserSurface.contract>;\n \n /** The per-host PROCEDURE client — `hostRpc(host).surface.process.kill(...)`\n  *  resolves at the map's key-folded wire path. Replaces the old\n  *  `surfaceForHost(host).rpc`. */\n export function hostRpc(host: string): HostRpc {\n   return hostMap.entry(host).rpc as HostRpc;\n }\n \n // The admin scoped client's `.rpc` is the slice `{ surface: link.surface.admin }`,\n // typed `any` by `connectSurfaces`; recover the admin router type so the\n // imperative host-lifecycle procedures stay typed.\n type AdminScopedRpc = {\n   surface: ContractRouterClient<typeof adminContract>[\"surface\"][\"admin\"];\n };\n \n /** Get the admin surface client — drishti's OWN `admin` surface, used for\n  *  its host-lifecycle procedures. */\n export function adminClient() {\n   return conn.clients.admin;\n }\n \n /** The admin surface's PROCEDURE namespace. `adminRpc().hosts.add(...)` /\n  *  `.remove(...)` / `.reconnect(...)` / `.recheck(...)` resolve at\n  *  `/surface/admin/hosts/<verb>`. */\n export function adminRpc() {\n   return (conn.clients.admin.rpc as AdminScopedRpc).surface;\n }\n \ndiff --git a/packages/app/src/common/history.ts b/packages/app/src/common/history.ts\nindex 7d12fc5..f83919d 100644\n--- a/packages/app/src/common/history.ts\n+++ b/packages/app/src/common/history.ts\n@@ -1,126 +1,120 @@\n /**\n  * The pure, framework-free metric-history domain — shared by the **parent**\n  * (which owns the in-memory ring and samples it on every poll tick) and the\n  * **browser** (which renders the ring it's streamed). Keeping the ring\n  * maths (eviction, windowing, SVG projection — the part that's wrong on\n  * screen, or wrong in memory, if an index or a scale slips) in one\n  * framework-free module lets it be unit-tested in isolation and reused on\n  * both sides of the wire.\n  *\n  * The history is **server-side and in-memory**: it lives in the parent for\n  * the life of the process, accruing for every connected host whether or not\n  * a browser tab is open on it. A browser gets the whole ring on connect\n  * (snapshot) then per-tick deltas — so reloads and tab switches both replay\n  * the full history instantly. It is never persisted to disk (preserving the\n  * zero-config posture); restarting the parent starts fresh.\n  */\n \n import type { MetricSample, SystemInfo } from \"drishti-common\";\n-import { diskPct, memPct } from \"./metrics\";\n+import { type MetricKey, metricPercents } from \"drishti-common/metrics\";\n \n-/** The series the chart draws. */\n-export type MetricKey = \"cpu\" | \"mem\" | \"disk\";\n+/** The series the chart draws — the shared metric vocabulary, re-exported so the\n+ *  client keeps importing it from this history module. */\n+export type { MetricKey };\n \n /** Selectable chart windows, mirroring the time-range chips popular\n  *  monitors (Netdata, btop, Datadog) put above their graphs. Ascending by\n  *  span; the widest doubles as the ring's retention bound. */\n export const HISTORY_WINDOWS = [\n   { key: \"1m\", ms: 60_000 },\n   { key: \"5m\", ms: 5 * 60_000 },\n   { key: \"15m\", ms: 15 * 60_000 },\n   { key: \"30m\", ms: 30 * 60_000 },\n ] as const;\n \n export type HistoryWindowKey = (typeof HISTORY_WINDOWS)[number][\"key\"];\n \n /** The widest selectable window — the one the fleet card sparkline pins to,\n  *  so the card always shows the same span as the retention bound. Derived\n  *  from the last entry (the array is ascending by span) so adding a wider\n  *  window automatically widens the sparkline too. */\n // Non-null assertion: HISTORY_WINDOWS is a non-empty const tuple, so .at(-1)\n // always resolves. TypeScript can't prove this from the index type alone.\n export const WIDEST_HISTORY_WINDOW: HistoryWindowKey =\n   HISTORY_WINDOWS.at(-1)!.key;\n \n /** Default window on first open — the widest span, so the chart shows the\n  *  fullest trend the ring retains the moment a host opens. */\n export const DEFAULT_HISTORY_WINDOW: HistoryWindowKey = \"30m\";\n \n /** Retention bound for the ring: the widest selectable window. Samples\n  *  older than this are evicted on push, so a host left open for hours\n  *  still holds at most the widest window's worth of points. Derived from\n  *  the window set so it can't drift below a selectable window — adding a\n  *  wider window automatically widens retention to match. */\n export const HISTORY_RETENTION_MS = Math.max(\n   ...HISTORY_WINDOWS.map((w) => w.ms),\n );\n \n /** Resolve a window key to its span in ms, falling back to the narrowest\n  *  window if the key is somehow unknown (never NaN). */\n export function windowMsFor(key: HistoryWindowKey): number {\n   return HISTORY_WINDOWS.find((w) => w.key === key)?.ms ?? HISTORY_WINDOWS[0].ms;\n }\n \n /** Whether a raw string is a selectable window key — the guard for\n  *  restoring a persisted choice, so a key dropped from a future build\n  *  falls back to the default instead of selecting nothing. */\n export function isHistoryWindowKey(raw: string): boolean {\n   return HISTORY_WINDOWS.some((w) => w.key === raw);\n }\n \n /** Assemble a `MetricSample` from a live system snapshot — the single home for\n- *  \"what a captured sample is.\" Every series reads off the `system` cell: `cpu`\n- *  is the agent-computed `system.cpuPct` (the ONE host-CPU mean, no longer\n- *  re-averaged from the parent's `coreCache` — which could lag the system tick\n- *  by a frame under concurrent pumping), `mem`/`disk` reuse the canonical\n- *  `metrics.ts` shares. Adding a series touches the data layer it comes from\n- *  (the `MetricKey` union, the `MetricSample` schema, and this assembler); the\n- *  *render* side is single-sourced separately in the client's `SERIES` table.\n- *  Pure: `t` is passed in. */\n+ *  \"what a captured sample is.\" The per-metric percentages come from the ONE\n+ *  shared system→% projection (`metricPercents` in `drishti-common/metrics`, the\n+ *  same projection the agent's alert fold consumes), stamped with the capture\n+ *  time. Adding a series touches that projection and the `MetricSample` schema;\n+ *  the *render* side is single-sourced separately in the client's `SERIES`\n+ *  table. Pure: `t` is passed in. */\n export function captureSample(t: number, system: SystemInfo): MetricSample {\n-  return {\n-    t,\n-    cpu: system.cpuPct,\n-    mem: memPct(system),\n-    disk: diskPct(system),\n-  };\n+  return { t, ...metricPercents(system) };\n }\n \n /** Append a sample and evict any older than `retentionMs` behind the\n  *  newest. Returns a new array (the caller holds it in a signal or a\n  *  closure cell); the input is never mutated. The cutoff is measured from\n  *  the newest timestamp across the whole ring — not blindly from the\n  *  incoming sample — so a backwards clock blip can't wipe the buffer. */\n export function pushSample(\n   buffer: readonly MetricSample[],\n   sample: MetricSample,\n   retentionMs: number,\n ): MetricSample[] {\n   const next = [...buffer, sample];\n   const newest = next.reduce((max, s) => (s.t > max ? s.t : max), sample.t);\n   const cutoff = newest - retentionMs;\n   return next.filter((s) => s.t >= cutoff);\n }\n \n /** The slice within `windowMs` of `now` — what the chart draws for the\n  *  selected duration. `now` is passed in (not read from the clock) so the\n  *  projection stays pure and testable. */\n export function windowSlice(\n   buffer: readonly MetricSample[],\n   windowMs: number,\n   now: number,\n ): readonly MetricSample[] {\n   const cutoff = now - windowMs;\n   // The buffer is time-ascending, so if its OLDEST sample is already within the\n   // window every sample is — return it as-is. The fleet card pins the widest\n   // window (= the ring's retention bound), so it hits this every tick and skips\n   // an O(ring) filter allocation, handing the buffer straight to `downsample`.\n   if (buffer.length === 0 || buffer[0]!.t >= cutoff) return buffer;\n   return buffer.filter((s) => s.t >= cutoff);\n }\n \n /** Max points a glance sparkline / drill-in chart is drawn from. A trace\n  *  renders into at most a few hundred horizontal pixels, so beyond ~one point\n  *  per pixel the extra samples are invisible — yet each still costs a\n  *  coordinate pair, two `toFixed` calls, and ~12 bytes of `points` string PER\n  *  series PER tick. The 30m ring holds 900 samples at the 2s cadence; without a\ndiff --git a/packages/app/src/server/router.ts b/packages/app/src/server/router.ts\nindex 97d9fe7..4a70b76 100644\n--- a/packages/app/src/server/router.ts\n+++ b/packages/app/src/server/router.ts\n@@ -28,152 +28,160 @@\n  *\n  * The router this file builds is now the ENTRY surface `@kolu/surface-map`\n  * serves N times — `admin-router.ts`'s `serveHostMap` calls `buildRouter`\n  * once per pool member and hands `directLink(router)` to the map as that\n  * host's `linkFor`, replacing the `RPCHandler`-per-`?host=`-socket dispatch\n  * this file used to feed directly.\n  */\n \n import { implement } from \"@orpc/server\";\n import {\n   type CellStore,\n   type Channel,\n   implementSurface,\n   inMemoryChannel,\n   inMemoryChannelByName,\n   inMemoryStore,\n } from \"@kolu/surface/server\";\n import { type ProcedureForwarders } from \"@kolu/surface/mirror\";\n import {\n   type AgentClient,\n   pumpRemoteSurface,\n   seedConnectionCell,\n   type Session,\n   type SshProv,\n } from \"@kolu/surface-remote\";\n import { browserSurface, type ConnectionInfo } from \"drishti-common/browser\";\n import {\n   type CoreId,\n   type CpuCore,\n   DEFAULT_SYSTEM,\n   type IfaceName,\n   type MetricHistoryMsg,\n   type MetricSample,\n   type NetInterface,\n   type Pid,\n   type Process,\n   type ProcessesSnapshotMsg,\n   type SystemInfo,\n   surface,\n } from \"drishti-common\";\n+import { type Alerts, NO_ALERTS } from \"drishti-common/alerts\";\n import {\n   captureSample,\n   HISTORY_RETENTION_MS,\n   pushSample,\n } from \"../common/history\";\n import { type Logger, makeLogger } from \"./log\";\n \n export interface BuildRouterOptions {\n   /** The host this router bridges — used only to tag the bridge's log\n    *  lines (`bridge:${host}`). The `Session` keeps its `host` private,\n    *  so the registry (which has it) passes it in explicitly. */\n   host: string;\n   session: Session<AgentClient<typeof surface.contract>, SshProv>;\n }\n \n /** Build the parent's oRPC router. The session's connection state\n  *  drives the `system.state` field exposed to the browser; agent data\n  *  flows through once the link is live. */\n export function buildRouter(opts: BuildRouterOptions) {\n   const session = opts.session;\n   // Per-host bridge logger. One `buildRouter` runs per host, so a tag\n   // built from `host` here gives every bridge line a host discriminator —\n   // without it, the N concurrent per-host bridge loops all wrote a flat\n   // `[bridge]` and interleaved into one unattributable stream.\n   const log = makeLogger(`bridge:${opts.host}`);\n   const systemStore: CellStore<SystemInfo> = inMemoryStore({\n     ...DEFAULT_SYSTEM,\n   });\n+  // The parent MIRRORS the agent's `alerts` cell (the agent is the sole\n+  // producer — it folds the threshold+hysteresis derivation via the reactor).\n+  // A plain local store the pump sink writes each agent `alerts` frame into,\n+  // re-served to the browser exactly like `system`. Seeds gate-closed\n+  // (`NO_ALERTS`) until the first agent frame lands.\n+  const alertsStore: CellStore<Alerts> = inMemoryStore({ ...NO_ALERTS });\n   // The seeded, gate-closed connection cell — the shared `seedConnectionCell()`,\n   // not a hand-rolled store. Written by `pumpRemoteSurface` off `session.onState`\n   // (the `connection` option below), which owns the subscription + teardown.\n   const connection = seedConnectionCell();\n   const processCache = new Map<Pid, Process>();\n   const coreCache = new Map<CoreId, CpuCore>();\n   const netCache = new Map<IfaceName, NetInterface>();\n   // Local snapshot bus — every msg the parent receives from the\n   // agent's snapshot stream is also re-published here so the parent's\n   // own `processesSnapshot` source (consumed by the browser) can\n   // forward the same data without re-subscribing to the agent.\n   const browserSnapshotBus: Channel<ProcessesSnapshotMsg> =\n     inMemoryChannel<ProcessesSnapshotMsg>();\n   // Parent-owned metric-history ring. Sampled once per agent poll tick (see\n   // `recordSample`), bounded to the widest selectable window, and held for\n   // the life of this session — independent of any browser. A new browser\n   // subscriber is re-seeded from `historyRing` (full snapshot) then fed\n   // per-tick deltas via `historyBus`, so reloads and tab switches replay the\n   // whole history. Reassigned (not mutated) by `pushSample`; the stream\n   // source reads the current binding on subscribe.\n   let historyRing: MetricSample[] = [];\n   const historyBus: Channel<MetricHistoryMsg> =\n     inMemoryChannel<MetricHistoryMsg>();\n \n   // R7 (kolu #1505): the browser's `process.kill` is forwarded to the agent\n   // through the MIRROR's procedure stub — the first forwarded procedure on a\n   // mirrored surface. The mirror is re-issued per spawn (stdio doesn't recover\n   // mid-stream), so the live stub set lives in this holder: the pump sets it\n   // on each connect and clears it when the link dies. A kill with no live agent\n   // reports `{ ok: false }` rather than silently no-op'ing.\n   const liveProcedures: {\n     current: ProcedureForwarders<typeof surface.spec> | null;\n   } = { current: null };\n \n   // Implements the MIRRORED surface (base + the get-only `connection` cell). The\n   // base primitives are forwarded/folded from the agent; `connection` is the\n   // seeded local store the session pump writes — the agent's surface stays\n   // connection-free.\n   const fragment = implementSurface(browserSurface, {\n     // Name-keyed in-memory channel factory — publish/subscribe sites\n     // land on the same `Channel<T>` instance per name.\n     channel: inMemoryChannelByName(),\n     cells: {\n       system: { store: systemStore },\n+      alerts: { store: alertsStore },\n       connection,\n     },\n     collections: {\n       processes: {\n         readAll: () => processCache,\n         // The framework's wrapped upsert/remove call these deps first\n         // and only then publish through the keyed channels. If we throw\n         // here (to \"guard against browser writes\"), the framework's own\n         // bridging path — `ctx.collections.processes.upsert(...)` from\n         // `reconcileProcesses` — also throws and the publish never fires.\n         // Browser-vs-server isn't a write-vs-read distinction inside the\n         // process; it's a wire-protocol distinction (the browser-facing\n         // contract simply doesn't expose `upsert` / `remove`). So these\n         // deps stay as the single in-process write seam.\n         upsert: (key, value) => {\n           processCache.set(key, value);\n         },\n         remove: (key) => {\n           processCache.delete(key);\n         },\n       },\n       cpuCores: {\n         readAll: () => coreCache,\n         upsert: (key, value) => {\n           coreCache.set(key, value);\n         },\n         remove: (key) => {\n           coreCache.delete(key);\n         },\n       },\n       networkInterfaces: {\n         readAll: () => netCache,\n         upsert: (key, value) => {\n           netCache.set(key, value);\n         },\n         remove: (key) => {\n           netCache.delete(key);\n         },\n       },\n     },\n@@ -251,157 +259,165 @@ export function buildRouter(opts: BuildRouterOptions) {\n   // process is respawned (after a transport drop), the pump fetches the new\n   // client and re-issues ONE `mirrorRemoteSurface` against the sink built\n   // below. The framework's `ClientRetryPlugin` is NOT load-bearing here:\n   // stdio links don't recover mid-stream (the underlying streams die with\n   // the process), so the only reliable recovery is to re-mirror on the\n   // *new* client. The pump's outer loop is what implements \"reconnect →\n   // state reconciles, no ghosts\"; drishti supplies only the per-spawn sink.\n   void pumpRemoteSurface({\n     source: surface,\n     session,\n     // Build the mirror sink for ONE freshly-spawned client. Called once per\n     // (re)spawn, so the per-client state below resets naturally each\n     // reconnect: the agent leads every (re)connect with a fresh `system`\n     // snapshot, so the first-frame handshake marker and the frame counter\n     // re-arm with the client. `seq` labels successive spawns (`#1`, `#2`, …)\n     // so the otherwise-identical per-reconnect log lines trace to a specific\n     // spawn — if the mirror against `#2` never yields a `system` frame while\n     // the agent logged `serving surface over stdio`, the handoff (not the\n     // remote) is where a stuck reconnect lives.\n     makeSink: ({ seq }) => {\n       let firstSystemFrame = true;\n       let frames = 0;\n       const issuedAt = Date.now();\n       return {\n         cells: {\n           // The agent's `system` cell → the parent's. The first yield is also\n           // the connection handshake: it flips the session to `connected`\n           // (idempotent thereafter). Every tick is the parent's authoritative\n           // metric-history sampling point (it sees every tick, browser or not).\n           system: (remoteSystem) => {\n             if (firstSystemFrame) {\n               firstSystemFrame = false;\n               log(\n                 `system: first snapshot → marking connected (client #${seq}, ${Date.now() - issuedAt}ms to first RPC)`,\n               );\n             }\n             session.markConnected();\n             fragment.ctx.cells.system.set(remoteSystem);\n             recordSample(remoteSystem);\n           },\n+          // The agent's `alerts` cell → the parent's. Wire-read-only downstream;\n+          // the parent only ever mirrors the agent's derived value inward. The\n+          // agent's own `equals` (`alertsEqual`) already gated the frame, so a\n+          // frame arriving here is a genuine raise/clear worth re-publishing.\n+          alerts: (remoteAlerts) => {\n+            fragment.ctx.cells.alerts.set(remoteAlerts);\n+          },\n         },\n         collections: {\n           // Small-N per-key collections — the path the private collection\n           // engine drives (keys stream + per-key value streams). `coreCache` /\n           // `netCache` outlive the per-spawn sink (they're minted once above),\n           // so a core/iface that vanished while the ssh link was down would\n           // survive as a ghost row across the reconnect. `initialKeys` hands the\n           // fresh mirror this spawn's carry-over keys; its first `keys` frame\n           // prunes any the snapshot omits — no stale row, no empty flash\n           // (kolu #1661; mirrors surface-remote's reServeSurface).\n           cpuCores: {\n             upsert: (key, value) =>\n               fragment.ctx.collections.cpuCores.upsert(key, value),\n             remove: (key) => fragment.ctx.collections.cpuCores.remove(key),\n             initialKeys: () => new Set(coreCache.keys()),\n           },\n           networkInterfaces: {\n             upsert: (key, value) =>\n               fragment.ctx.collections.networkInterfaces.upsert(key, value),\n             remove: (key) =>\n               fragment.ctx.collections.networkInterfaces.remove(key),\n             initialKeys: () => new Set(netCache.keys()),\n           },\n         },\n         streams: {\n           // Bulk discriminated-union stream — ONE long-lived stream regardless\n           // of process count (vs. keys-stream + N per-key subscribes, a drip\n           // over a high-latency ssh link). Each frame is a full keyed-snapshot\n           // (first, or on reconnect) or a per-tick delta; `applySnapshotMessage`\n           // applies both, and the parent re-publishes the frame verbatim to its\n           // browser bus.\n           processesSnapshot: {\n             input: {},\n             onFrame: (msg) => {\n               frames += 1;\n               applySnapshotMessage(log, msg, processCache, fragment, frames);\n               browserSnapshotBus.publish(msg);\n             },\n           },\n         },\n       };\n     },\n     // Publish each spawn's forwarding stubs for the parent's `kill` handler;\n     // the pump clears them the instant the link dies, so a kill in the gap\n     // fails honestly rather than calling into a dead client.\n     liveProcedures,\n     // The session's link health (copying / connecting / failed) onto the\n     // browser-facing `connection` cell — the pump OWNS this subscription for the\n     // session's lifetime and tears it down on exit (kolu #1568), so it can't be\n     // forgotten or leak. The cell tracks the SESSION's state, never a mirror frame.\n     connection: { set: (info) => fragment.ctx.cells.connection.set(info) },\n     log,\n   });\n \n   // `implementSurface` returns a router *fragment* — `{ surface: ... }`\n   // wrapping the per-key namespaces. Passing it directly to RPCHandler\n   // produces a `surface/surface/...` double-prefix in the matcher tree\n   // (no procedure matches what the client sends). Wrap once via\n   // `implement(contract).router({...fragment})` to flatten the prefix.\n   const router = implement(browserSurface.contract).router({\n     ...fragment.router,\n   });\n   return { router, session };\n }\n \n /** The write-side methods the pump sink is allowed to touch — a\n  *  deliberate least-privilege narrowing of `implementSurface(...).ctx`,\n  *  not the full ctx. The sink only ever mirrors remote data inward, so it\n  *  gets `set` / `upsert` / `remove`; `readAll` and the underlying stores\n  *  stay out of reach. This is a boundary, not a maintenance chore: the\n  *  `_pumpCtx` guard above assigns the real fragment to this type, so a\n  *  collection renamed or retyped on the surface becomes a compile error\n  *  here rather than silent drift. */\n type FragmentCtx = {\n   ctx: {\n     cells: {\n       system: { set: (v: SystemInfo) => void };\n+      alerts: { set: (v: Alerts) => void };\n       connection: { set: (v: ConnectionInfo) => void };\n     };\n     collections: {\n       processes: {\n         upsert: (k: Pid, v: Process) => void;\n         remove: (k: Pid) => void;\n       };\n       cpuCores: {\n         upsert: (k: CoreId, v: CpuCore) => void;\n         remove: (k: CoreId) => void;\n       };\n       networkInterfaces: {\n         upsert: (k: IfaceName, v: NetInterface) => void;\n         remove: (k: IfaceName) => void;\n       };\n     };\n   };\n };\n \n /** Apply one `processesSnapshot` frame to the parent's local\n  *  collection — full reset on `snapshot`, incremental delta on\n  *  `delta`. Reads `processCache` directly for the live-PID set; the\n  *  framework's `upsert`/`remove` keep the cache and the per-key\n  *  channels in lockstep, so there's no separate shadow set to\n  *  maintain here. */\n function applySnapshotMessage(\n   log: Logger,\n   msg: ProcessesSnapshotMsg,\n   processCache: Map<Pid, Process>,\n   fragment: FragmentCtx,\n   frameNumber: number,\n ): void {\n   if (msg.kind === \"snapshot\") {\n     const next = new Set(msg.entries.map(([pid]) => pid));\n     for (const pid of [...processCache.keys()]) {\n       if (!next.has(pid)) fragment.ctx.collections.processes.remove(pid);\n     }\n     for (const [pid, value] of msg.entries) {\n       fragment.ctx.collections.processes.upsert(pid, value);\n     }\ndiff --git a/packages/common/package.json b/packages/common/package.json\nindex 7482194..6062d1e 100644\n--- a/packages/common/package.json\n+++ b/packages/common/package.json\n@@ -1,21 +1,22 @@\n {\n   \"name\": \"drishti-common\",\n   \"version\": \"0.1.0\",\n   \"private\": true,\n   \"type\": \"module\",\n   \"//\": \"Deps are what the wire contract needs at runtime: surface.ts uses zod and @kolu/surface/define (which pulls @orpc/contract). @kolu/surface is hydrated from the Nix store, not bun.lock, so its support deps must be declared by consumers \\u2014 here for the contract, and in drishti-agent for the server/peer-server it serves.\",\n   \"main\": \"./src/surface.ts\",\n   \"types\": \"./src/surface.ts\",\n   \"exports\": {\n     \".\": \"./src/surface.ts\",\n+    \"./alerts\": \"./src/alerts.ts\",\n     \"./browser\": \"./src/browser.ts\",\n     \"./metrics\": \"./src/metrics.ts\"\n   },\n   \"scripts\": {\n     \"typecheck\": \"tsc --noEmit\"\n   },\n   \"dependencies\": {\n     \"@orpc/contract\": \"^1.13.13\",\n     \"zod\": \"^4.3.6\"\n   }\n }\ndiff --git a/packages/common/src/alerts.test.ts b/packages/common/src/alerts.test.ts\nnew file mode 100644\nindex 0000000..400dc38\n--- /dev/null\n+++ b/packages/common/src/alerts.test.ts\n@@ -0,0 +1,76 @@\n+import { describe, expect, it } from \"bun:test\";\n+import {\n+  type Alerts,\n+  applyHysteresis,\n+  alertsEqual,\n+  type MetricsFrame,\n+  NO_ALERTS,\n+} from \"./alerts\";\n+\n+const frame = (over: Partial<MetricsFrame>): MetricsFrame => ({\n+  cpu: 0,\n+  mem: 0,\n+  disk: 0,\n+  ...over,\n+});\n+\n+describe(\"applyHysteresis\", () => {\n+  it(\"raises a metric at the 80% threshold\", () => {\n+    const next = applyHysteresis(NO_ALERTS, frame({ cpu: 80 }));\n+    expect(next.items).toEqual([\"cpu\"]);\n+  });\n+\n+  it(\"does not raise just below the threshold\", () => {\n+    const next = applyHysteresis(NO_ALERTS, frame({ cpu: 79.9 }));\n+    expect(next.items).toEqual([]);\n+  });\n+\n+  it(\"holds by returning the PREV reference in the 70-80 dead band\", () => {\n+    const raised = applyHysteresis(NO_ALERTS, frame({ cpu: 85 }));\n+    // Falls into the dead band (>=70, <80): an already-raised alert stays\n+    // raised, and — crucially — the SAME reference comes back so `scan`\n+    // publishes nothing.\n+    const held = applyHysteresis(raised, frame({ cpu: 75 }));\n+    expect(held).toBe(raised);\n+  });\n+\n+  it(\"holds (prev reference) when an un-raised metric sits in the dead band\", () => {\n+    const held = applyHysteresis(NO_ALERTS, frame({ cpu: 75 }));\n+    expect(held).toBe(NO_ALERTS);\n+  });\n+\n+  it(\"clears only once the metric falls below 70%\", () => {\n+    const raised = applyHysteresis(NO_ALERTS, frame({ cpu: 90 }));\n+    // 70 is still in the dead band — held.\n+    expect(applyHysteresis(raised, frame({ cpu: 70 }))).toBe(raised);\n+    // Below 70 clears.\n+    const cleared = applyHysteresis(raised, frame({ cpu: 69 }));\n+    expect(cleared.items).toEqual([]);\n+  });\n+\n+  it(\"tracks each metric independently\", () => {\n+    let state: Alerts = NO_ALERTS;\n+    state = applyHysteresis(state, frame({ cpu: 95, mem: 10, disk: 10 }));\n+    expect(state.items).toEqual([\"cpu\"]);\n+\n+    // Raise mem and disk while cpu stays high; ids stay in metric order.\n+    state = applyHysteresis(state, frame({ cpu: 95, mem: 88, disk: 82 }));\n+    expect(state.items).toEqual([\"cpu\", \"mem\", \"disk\"]);\n+\n+    // Drop cpu below the clear edge; mem/disk remain raised.\n+    state = applyHysteresis(state, frame({ cpu: 20, mem: 88, disk: 82 }));\n+    expect(state.items).toEqual([\"mem\", \"disk\"]);\n+  });\n+});\n+\n+describe(\"alertsEqual\", () => {\n+  it(\"equal iff the same set of ids is raised\", () => {\n+    const a: Alerts = { items: [\"cpu\"] };\n+    const b: Alerts = { items: [\"cpu\"] };\n+    expect(alertsEqual(a, b)).toBe(true);\n+\n+    const c: Alerts = { items: [\"mem\"] };\n+    expect(alertsEqual(a, c)).toBe(false);\n+    expect(alertsEqual(a, NO_ALERTS)).toBe(false);\n+  });\n+});\ndiff --git a/packages/common/src/alerts.ts b/packages/common/src/alerts.ts\nnew file mode 100644\nindex 0000000..5c28673\n--- /dev/null\n+++ b/packages/common/src/alerts.ts\n@@ -0,0 +1,110 @@\n+/**\n+ * The `alerts` domain — a pure threshold+hysteresis fold over host metrics.\n+ *\n+ * This module is AGENT-shared (drishti-common) and stays FRAMEWORK-FREE: it\n+ * carries only the wire schema (`AlertsSchema`), the value shapes, and the pure\n+ * fold (`applyHysteresis`) + its equality gate (`alertsEqual`). The reactor that\n+ * DRIVES this fold (`scan(metrics, NO_ALERTS, applyHysteresis)`) lives ONLY in\n+ * the agent's `main.ts` — importing `@kolu/surface/reactor` here would fold a\n+ * backend-only signals engine into the agent-shared graph, which the agent-boots\n+ * CI check forbids. So the graph is the agent's; the fold is everyone's.\n+ *\n+ * **Hysteresis, not a bare threshold.** A single cutoff at 80% would flap an\n+ * alert on and off every poll for a metric hovering at the line. Instead a metric\n+ * RAISES at `pct >= RAISE_PCT` (80) and only CLEARS once it falls below\n+ * `CLEAR_PCT` (70) — the dead band between the two is the \"hold\" region where an\n+ * already-raised alert stays raised and an un-raised one stays quiet. This is the\n+ * same Schmitt-trigger shape a thermostat uses.\n+ *\n+ * **The prev-reference hold is load-bearing.** When nothing crosses a threshold,\n+ * `applyHysteresis` returns the PREV `state` reference unchanged. The reactor's\n+ * `scan` reads that `===` as \"no change\" and publishes nothing — so a quiet tick\n+ * costs zero wire traffic. Returning a fresh-but-equal object would defeat that\n+ * gate; the cell's `equals` (`alertsEqual`) is the second line of defence for\n+ * values that differ by reference but not by content.\n+ */\n+\n+import { z } from \"zod\";\n+import type { MetricKey } from \"./metrics\";\n+\n+/** A host's raw metric percentages for one poll tick (0-100). The fold's input\n+ *  frame — one number per metric, keyed by the shared `MetricKey`, decoupled\n+ *  from the wider `system` cell so the alert graph steps on exactly the numbers\n+ *  it thresholds, nothing more. */\n+export type MetricsFrame = Record<MetricKey, number>;\n+\n+/** The metrics an alert can fire for — the SAME vocabulary the history chart\n+ *  keys on (`MetricKey`, single-sourced in `drishti-common/metrics`). Stable\n+ *  ids: `watchByEntry`'s set-diff decides \"same alert, not a new one\" on these,\n+ *  so they must not churn. */\n+export type AlertId = MetricKey;\n+\n+/** The set of currently-raised alerts for one host — just the raised ids. The\n+ *  concept IS a set of metric ids, so the shape says so; the human word is a\n+ *  client-owned presentation lookup (`LABELS` in the app), never a wire fact. */\n+export interface Alerts {\n+  items: AlertId[];\n+}\n+\n+export const AlertsSchema = z.object({\n+  items: z.array(z.enum([\"cpu\", \"mem\", \"disk\"])),\n+});\n+\n+/** The empty alert set — the fold's seed and the cell's gate-closed default. A\n+ *  fresh process re-derives its alerts from fresh samples (the fold carries no\n+ *  durable state), so booting with \"nothing raised\" is the honest start. */\n+export const NO_ALERTS: Alerts = { items: [] };\n+\n+/** Raise once a metric reaches this percentage (0-100). */\n+const RAISE_PCT = 80;\n+/** Clear only once a metric falls below this — the lower edge of the dead band\n+ *  that stops a hovering metric from flapping. */\n+const CLEAR_PCT = 70;\n+\n+/** The metrics folded, in a fixed order, so `applyHysteresis` iterates one list\n+ *  rather than three hand-copied blocks. */\n+const METRIC_IDS: readonly AlertId[] = [\"cpu\", \"mem\", \"disk\"];\n+\n+/**\n+ * Threshold+hysteresis fold: step the raised-alert set forward by one metric\n+ * frame.\n+ *\n+ * Per metric: RAISE (add the id) when it crosses up to `RAISE_PCT` while not\n+ * already raised; CLEAR (remove it) when it falls below `CLEAR_PCT` while raised;\n+ * otherwise HOLD. When NOTHING crosses — the common case — the PREV `state`\n+ * reference is returned unchanged, which the reactor's `scan` reads as \"no\n+ * publish\" (see the module docstring). A raise/clear returns a fresh `Alerts`.\n+ */\n+export function applyHysteresis(state: Alerts, frame: MetricsFrame): Alerts {\n+  const raised = new Set(state.items);\n+  let changed = false;\n+\n+  for (const id of METRIC_IDS) {\n+    const pct = frame[id];\n+    const isRaised = raised.has(id);\n+    if (!isRaised && pct >= RAISE_PCT) {\n+      raised.add(id);\n+      changed = true;\n+    } else if (isRaised && pct < CLEAR_PCT) {\n+      raised.delete(id);\n+      changed = true;\n+    }\n+  }\n+\n+  // No threshold crossed — return the PREV reference so `scan` publishes\n+  // nothing. This is REQUIRED, not an optimization: a fresh object here would\n+  // step the graph every quiet tick.\n+  if (!changed) return state;\n+\n+  // Rebuild in the fixed metric order so the id list is deterministic\n+  // regardless of raise sequence.\n+  return { items: METRIC_IDS.filter((id) => raised.has(id)) };\n+}\n+\n+/** Equal iff the SAME set of alert ids is raised — the cell's `equals` gate.\n+ *  Only a raise or a clear (a change to the id set) crosses the wire. */\n+export function alertsEqual(a: Alerts, b: Alerts): boolean {\n+  if (a.items.length !== b.items.length) return false;\n+  const ids = new Set(a.items);\n+  return b.items.every((id) => ids.has(id));\n+}\ndiff --git a/packages/common/src/metrics.test.ts b/packages/common/src/metrics.test.ts\nindex 9d0cc5e..df2a9c3 100644\n--- a/packages/common/src/metrics.test.ts\n+++ b/packages/common/src/metrics.test.ts\n@@ -1,12 +1,31 @@\n import { describe, expect, it } from \"bun:test\";\n-import { averageCoreUsage } from \"./metrics\";\n+import { averageCoreUsage, metricPercents } from \"./metrics\";\n+import { DEFAULT_SYSTEM, type SystemInfo } from \"./surface\";\n \n describe(\"averageCoreUsage\", () => {\n   it(\"averages the per-core usages\", () => {\n     expect(averageCoreUsage([10, 20, 30, 40])).toBe(25);\n   });\n \n   it(\"returns 0 for no cores (never NaN)\", () => {\n     expect(averageCoreUsage([])).toBe(0);\n   });\n });\n+\n+describe(\"metricPercents\", () => {\n+  it(\"reads cpuPct directly and derives mem/disk as guarded shares\", () => {\n+    const system: SystemInfo = {\n+      ...DEFAULT_SYSTEM,\n+      cpuPct: 42,\n+      memUsed: 8,\n+      memTotal: 16,\n+      diskUsed: 30,\n+      diskTotal: 120,\n+    };\n+    expect(metricPercents(system)).toEqual({ cpu: 42, mem: 50, disk: 25 });\n+  });\n+\n+  it(\"guards against a zero total (never NaN)\", () => {\n+    expect(metricPercents(DEFAULT_SYSTEM)).toEqual({ cpu: 0, mem: 0, disk: 0 });\n+  });\n+});\ndiff --git a/packages/common/src/metrics.ts b/packages/common/src/metrics.ts\nindex 56ece9a..e40d0dd 100644\n--- a/packages/common/src/metrics.ts\n+++ b/packages/common/src/metrics.ts\n@@ -1,20 +1,62 @@\n /**\n  * Pure metric math shared across tiers — framework-free, no runtime deps.\n  *\n- * `averageCoreUsage` lives HERE (not in the app) because the **agent** is the\n- * SOLE producer of the host-CPU aggregate: it reads per-core usage each tick and\n- * folds the mean into the `system` cell's `cpuPct` (see `agent/src/main.ts`).\n- * Every downstream tier — the parent re-serve and the browser — reads that one\n- * pre-computed `system.cpuPct` scalar and does NOT re-derive the mean (the old\n- * shape, where the fleet card averaged the `cpuCores` collection client-side, was\n- * the O(hosts×cores) fan-out this collapsed). The formula sits in the one package\n- * the agent can import; its only non-test consumer is the agent.\n+ * This is the ONE agent-shared home for host-metric derivations. `averageCoreUsage`\n+ * lives HERE (not in the app) because the **agent** is the SOLE producer of the\n+ * host-CPU aggregate: it reads per-core usage each tick and folds the mean into the\n+ * `system` cell's `cpuPct` (see `agent/src/main.ts`). The `pctOf` / `memPct` /\n+ * `diskPct` share-of-total helpers live here too, so the agent's `alerts` fold\n+ * (`./alerts`) derives mem%/disk% from the SAME formula the app-tier UI does — the\n+ * app module (`app/src/common/metrics.ts`) re-exports them so its consumers keep\n+ * resolving against one module, and no tier re-derives the math.\n  */\n \n+import type { SystemInfo } from \"./surface\";\n+\n /** Mean busy-percentage across the supplied per-core usages — the single\n  *  \"host CPU%\" number. Zero for a host with no reported cores (e.g. not yet\n  *  connected), never NaN. */\n export function averageCoreUsage(usages: readonly number[]): number {\n   if (usages.length === 0) return 0;\n   return usages.reduce((s, u) => s + u, 0) / usages.length;\n }\n+\n+/** `part` as a percentage of `whole`, guarded: 0 when `whole` is 0 (or negative)\n+ *  so callers never divide by zero — a freshly-connected host whose first `system`\n+ *  tick hasn't landed yet reports a 0 total. The single \"share of a total\" formula,\n+ *  used for host memory (`memPct`), root-fs (`diskPct`), and a process's share of\n+ *  host RAM in the detail panel. */\n+export function pctOf(part: number, whole: number): number {\n+  return whole > 0 ? (100 * part) / whole : 0;\n+}\n+\n+/** Memory used as a percentage of total. */\n+export function memPct(system: SystemInfo): number {\n+  return pctOf(system.memUsed, system.memTotal);\n+}\n+\n+/** Root-filesystem used as a percentage of total — the disk twin of `memPct`,\n+ *  reusing the same guarded `pctOf`. 0 when the host reports no disk total (agent\n+ *  couldn't `statfs`), never NaN. */\n+export function diskPct(system: SystemInfo): number {\n+  return pctOf(system.diskUsed, system.diskTotal);\n+}\n+\n+/** The metric-series names — the single vocabulary of \"which host metrics\n+ *  exist.\" The alert fold (`AlertId`) and the history chart (`MetricKey` in\n+ *  `common/history.ts`) both key on these, so adding a metric touches this union\n+ *  and the projection below, not a parallel copy per tier. */\n+export type MetricKey = \"cpu\" | \"mem\" | \"disk\";\n+\n+/** Project a live `system` snapshot to its per-metric percentages (0-100) — the\n+ *  ONE system→% projection, consumed by BOTH the parent's history sampler\n+ *  (`captureSample`) and the agent's alert fold. `cpu` is the agent's\n+ *  pre-computed `cpuPct`; `mem`/`disk` are the guarded shares above, so no tier\n+ *  re-derives the formula. */\n+export function metricPercents(system: SystemInfo): Record<MetricKey, number> {\n+  return {\n+    cpu: system.cpuPct,\n+    mem: memPct(system),\n+    disk: diskPct(system),\n+  };\n+}\ndiff --git a/packages/common/src/surface.ts b/packages/common/src/surface.ts\nindex da558de..ab2efb5 100644\n--- a/packages/common/src/surface.ts\n+++ b/packages/common/src/surface.ts\n@@ -1,61 +1,62 @@\n /**\n  * drishti surface — the shape served by the agent over stdio and\n  * re-served by the parent over WebSocket.\n  *\n  * Two primitives carry the entire feature:\n  *\n  *   - `system`     — singleton cell with load averages, memory, uptime.\n  *   - `processes`  — keyed collection (PID → per-process snapshot).\n  *\n  * One imperative escape hatch: the `process.kill` **procedure** — the\n  * first *forwarded procedure* on a mirrored surface (kolu #1505, R7). It\n  * runs on the agent (the host that owns the pids) and the parent forwards\n  * the browser's call to it through `mirrorRemoteSurface`'s total-dual\n  * procedure stub; everything else is read-only cells/collections/streams.\n  *\n  * Plus a `connection` cell so the parent can stream \"copying agent to\n  * remote…\" lifecycle to the browser while `nix copy` is in flight.\n  */\n \n import { defineSurface, type SurfaceTypes } from \"@kolu/surface/define\";\n import { z } from \"zod\";\n+import { alertsEqual, AlertsSchema, NO_ALERTS } from \"./alerts\";\n \n // IMPORTANT: this module is AGENT-shared (drishti-common's `.` export — the\n // agent serves the base surface from it). It must NOT import\n // `@kolu/surface-remote`: the agent's scoped build hydrates only `@kolu/surface`,\n // so a runtime import of the parent-only provisioning lib crashes the agent at\n // load. The connection-cell types, `DEFAULT_CONNECTION`, and the `browserSurface`\n // mirror-seam composition therefore live in the APP-only `drishti-common/browser`\n // subpath (./browser.ts), imported only by the parent re-serve + the client.\n \n const PidSchema = z.number().int().nonnegative();\n const ProcessSchema = z.object({\n   user: z.string(),\n   cpuPct: z.number(),\n   /** Resident set size in bytes — the absolute physical memory the\n    *  process occupies. The headline memory number the UI shows; a ratio\n    *  view can derive `rssBytes / system.memTotal` at the call site. */\n   rssBytes: z.number(),\n   command: z.string(),\n   /** Current working directory. From `/proc/<pid>/cwd` on linux and a single\n    *  batched `lsof -d cwd` on darwin. Empty string when unknown — kernel\n    *  threads have no cwd, and other-user pids without root can't be resolved\n    *  (EACCES on `/proc/<pid>/cwd` on linux; no `lsof` cwd line on darwin). */\n   cwd: z.string(),\n   /** Parent process id — `/proc/<pid>/stat` field 4 on linux, `ps -o\n    *  ppid=` on darwin. 0 for pid 1 / the rare orphan whose parent has\n    *  already reaped. */\n   ppid: PidSchema,\n   /** Single-char kernel state code: `R` running, `S` sleeping, `D`\n    *  uninterruptible, `Z` zombie, `T` stopped, `I` idle, … `/proc/<pid>/stat`\n    *  field 3 on linux; the first char of `ps -o state=` on darwin (its\n    *  trailing flags like `+`/`s` are dropped). Empty when unknown. */\n   state: z.string(),\n   /** Nice value (scheduling priority, -20..19). `/proc/<pid>/stat` field 19\n    *  on linux, `ps -o nice=` on darwin. */\n   nice: z.number().int(),\n   /** Thread count (`/proc/<pid>/stat` field 20), or null when the platform\n    *  can't cheaply source it — darwin's `ps` has no per-process thread count.\n    *  Null (not 0) so \"unavailable\" is distinct from a real count at the type\n    *  level; a live linux process always has >= 1. */\n   threads: z.number().int().positive().nullable(),\n@@ -188,80 +189,94 @@ export const ProcessesSnapshotMessage = z.discriminatedUnion(\"kind\", [\n \n /** One point in a host's metric history — CPU% and memory% at a wall-clock\n  *  instant. Captured by the **parent** on each agent poll tick (the parent\n  *  is the only tier that observes every tick regardless of which browser\n  *  tabs are open) and retained in an in-memory ring for the life of the\n  *  parent process. */\n const MetricSampleSchema = z.object({\n   /** Wall-clock capture time, epoch ms. */\n   t: z.number(),\n   /** Mean busy-percentage across all cores at capture (0-100). */\n   cpu: z.number(),\n   /** Memory used as a percentage of total at capture (0-100). */\n   mem: z.number(),\n   /** Root-filesystem used as a percentage of total at capture (0-100). */\n   disk: z.number(),\n });\n \n /** Snapshot-then-delta `Stream<>` for the per-host metric-history ring —\n  *  the same bulk-friendly shape as `processesSnapshot`. A new subscriber\n  *  (a freshly-loaded browser, or a tab just switched to this host) gets the\n  *  parent's entire ring in one `snapshot` frame, then one `delta` per poll\n  *  tick. This is why history survives reloads and tab switches: the state\n  *  lives in the parent, and every subscriber is re-seeded from it. */\n const MetricHistoryMessage = z.discriminatedUnion(\"kind\", [\n   z.object({\n     kind: z.literal(\"snapshot\"),\n     samples: z.array(MetricSampleSchema),\n   }),\n   z.object({\n     kind: z.literal(\"delta\"),\n     sample: MetricSampleSchema,\n   }),\n ]);\n \n export const surface = defineSurface({\n   cells: {\n     system: {\n       schema: SystemSchema,\n       default: DEFAULT_SYSTEM,\n     },\n+    // Per-host raised-alert set — a threshold+hysteresis fold over the host's\n+    // metrics (see `./alerts.ts`). Wire-READ-ONLY (`verbs: [\"get\"]`): the agent\n+    // is the sole writer via `@kolu/surface/reactor`'s `derived.cell(scan(...))`,\n+    // so the boot walk MUST see get-only here or it crashes on a write verb.\n+    // `equals: alertsEqual` is the final wire dedup — a metric drifting within\n+    // an already-raised level publishes nothing (same id set). This stays\n+    // reactor-FREE: only schema/default/verbs/equals, no graph import (the\n+    // reactor lives in the AGENT's main.ts, never in this agent-shared module).\n+    alerts: {\n+      schema: AlertsSchema,\n+      default: NO_ALERTS,\n+      verbs: [\"get\"],\n+      equals: alertsEqual,\n+    },\n     // NOTE: no `connection` cell here. Link health is composed ONLY at the\n     // nix-host re-serve seam via `mirroredSurface(surface)` (`browserSurface`\n     // below) — the agent serves this connection-free base; the parent mirrors\n     // it and adds the cell, writing it off `session.onState` (kolu #1568).\n   },\n   collections: {\n     processes: {\n       keySchema: PidSchema,\n       schema: ProcessSchema,\n     },\n     /** Per-core CPU usage — small-N (typical 4-32) `Collection<K,T>`.\n      *  The host drill-in renders one bar per core, so per-key reactive identity\n      *  is the right shape. But every core ticks every poll, so the host view\n      *  reads the WHOLE collection — hence the opt-in `deltas` verb: the parent\n      *  re-serves all N cores in one coalesced frame per tick instead of one\n      *  per-key frame each (the per-key `get` path stays for \"watch one core\").\n      *  The fleet card reads the `system.cpuPct` aggregate and never subscribes\n      *  here at all. */\n     cpuCores: {\n       keySchema: z.number().int().nonnegative(),\n       schema: CpuCoreSchema,\n       verbs: [\"keys\", \"get\", \"upsert\", \"delete\", \"deltas\"],\n     },\n     /** Per-NIC network I/O — keyed by interface name, the same `Collection<K,T>`\n      *  shape as `cpuCores`. The host view reads the whole set (dozens of NICs,\n      *  most idle), so it opts into batched `deltas` too — dozens of per-key\n      *  frames per tick collapse to one. */\n     networkInterfaces: {\n       keySchema: z.string(),\n       schema: NetInterfaceSchema,\n       verbs: [\"keys\", \"get\", \"upsert\", \"delete\", \"deltas\"],\n     },\n   },\n   streams: {\n     processesSnapshot: {\n       inputSchema: z.object({}),\n       outputSchema: ProcessesSnapshotMessage,\n     },\n     /** Per-host CPU%/memory% history. Parent-owned, in-memory, bounded —\n      *  see `MetricHistoryMessage`. The agent serves an inert empty stub\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_4","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba packages/agent/src/main.ts | sed -n '1,380p'; nl -ba packages/app/src/client/wire.ts | sed -n '1,280p'; nl -ba packages/app/src/common/history.ts | sed -n '1,260p'; nl -ba packages/app/src/server/router.ts | sed -n '1,320p'\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_4","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba packages/agent/src/main.ts | sed -n '1,380p'; nl -ba packages/app/src/client/wire.ts | sed -n '1,280p'; nl -ba packages/app/src/common/history.ts | sed -n '1,260p'; nl -ba packages/app/src/server/router.ts | sed -n '1,320p'\"","aggregated_output":"     1\t/**\n     2\t * drishti-agent entrypoint.\n     3\t *\n     4\t * Modes:\n     5\t *   --stdio                   serve the surface over stdin/stdout (the\n     6\t *                             headline path; what `ssh $host $agent\n     7\t *                             --stdio` invokes).\n     8\t *   --broken-stdout-log       deliberately log a stray line to stdout\n     9\t *                             before any RPC. The parent's client peer\n    10\t *                             sees garbage and surfaces a frame-parse\n    11\t *                             failure rather than hanging. Smoke-test\n    12\t *                             only; not for production.\n    13\t *   (no args)                 print usage to stderr and exit 1.\n    14\t *\n    15\t * The agent polls `proc` and `system` every `POLL_INTERVAL_MS` and\n    16\t * pushes deltas through the surface's typed `ctx` — the framework\n    17\t * mutates the snapshot AND publishes per-key updates in one call. New\n    18\t * subscribers see a full snapshot as their first yield\n    19\t * (snapshot-then-delta invariant) and per-PID upserts/removes\n    20\t * thereafter.\n    21\t *\n    22\t * **Stdout is the protocol channel.** All logging goes to fd 2\n    23\t * (`process.stderr.write`). `serveOverStdio` defensively redirects\n    24\t * `console.log` to stderr too, but this module avoids `console.log`\n    25\t * entirely for clarity.\n    26\t */\n    27\t\n    28\timport { implement } from \"@orpc/server\";\n    29\timport {\n    30\t  implementSurface,\n    31\t  inMemoryChannel,\n    32\t  inMemoryChannelByName,\n    33\t  inMemoryStore,\n    34\t} from \"@kolu/surface/server\";\n    35\timport { serveOverStdio } from \"@kolu/surface/peer-server\";\n    36\t// The reactive bridge (kolu W5, phase 0). This import is CORRECT here and only\n    37\t// here: the agent is the surface's serving endpoint, so folding host metrics\n    38\t// into the `alerts` cell through a backend signal graph belongs in the agent's\n    39\t// main.ts. It must NOT reach the agent-SHARED graph (`drishti-common`) — the\n    40\t// agent-boots CI check guards exactly that — so the pure fold lives in\n    41\t// `drishti-common/alerts` (reactor-free) and the graph that DRIVES it lives\n    42\t// here.\n    43\timport { derived, scan, source } from \"@kolu/surface/reactor\";\n    44\timport {\n    45\t  type CoreId,\n    46\t  type CpuCore,\n    47\t  type IfaceName,\n    48\t  type MetricHistoryMsg,\n    49\t  type NetInterface,\n    50\t  type Pid,\n    51\t  type Process,\n    52\t  type ProcessesSnapshotMsg,\n    53\t  surface,\n    54\t} from \"drishti-common\";\n    55\timport {\n    56\t  applyHysteresis,\n    57\t  type MetricsFrame,\n    58\t  NO_ALERTS,\n    59\t} from \"drishti-common/alerts\";\n    60\timport { averageCoreUsage, metricPercents } from \"drishti-common/metrics\";\n    61\timport { createProcReader, type ProcReader } from \"./proc\";\n    62\t\n    63\tconst POLL_INTERVAL_MS = 2000;\n    64\t\n    65\t// The host-CPU aggregate, folded into the `system` cell so a glance card reads\n    66\t// one scalar instead of subscribing to every per-core cell (which opens N\n    67\t// per-core value streams per host — the fleet's O(hosts×cores) CPU sink). The\n    68\t// agent is the natural producer: it already reads per-core usage each tick.\n    69\tconst cpuAggregate = (\n    70\t  cores: ReadonlyMap<CoreId, CpuCore>,\n    71\t): { cpuPct: number; coreCount: number } => ({\n    72\t  cpuPct: averageCoreUsage(Array.from(cores.values(), (c) => c.usagePct)),\n    73\t  coreCount: cores.size,\n    74\t});\n    75\t\n    76\tfunction log(...args: unknown[]): void {\n    77\t  process.stderr.write(`${args.map((a) => String(a)).join(\" \")}\\n`);\n    78\t}\n    79\t\n    80\tfunction usage(): never {\n    81\t  process.stderr.write(\n    82\t    [\n    83\t      \"drishti-agent — exposes /proc or sysctl as a typed @kolu/surface over stdio.\",\n    84\t      \"\",\n    85\t      \"Usage:\",\n    86\t      \"  drishti-agent --stdio                # serve over stdin/stdout (normal mode)\",\n    87\t      \"  drishti-agent --stdio --broken-stdout-log\",\n    88\t      \"                                        # stdout corruption smoke test\",\n    89\t      \"\",\n    90\t    ].join(\"\\n\"),\n    91\t  );\n    92\t  process.exit(1);\n    93\t}\n    94\t\n    95\t// The mutable per-tick fields of `Process` — the ones whose change must\n    96\t// re-publish a row. All of these can shift over a process's life; `startedAtMs`\n    97\t// cannot (a process can't change when it started — immutable per pid), so it is\n    98\t// deliberately absent, which also keeps it out of the publish gate regardless\n    99\t// of how the agent derives it. Listing membership explicitly (rather than a\n   100\t// hand-maintained OR-chain, which had already silently dropped `user`) keeps it\n   101\t// exhaustively reviewable, and `satisfies` ties each entry to a real schema\n   102\t// field so a typo or renamed field fails to compile.\n   103\tconst MUTABLE_PROCESS_FIELDS = [\n   104\t  \"user\",\n   105\t  \"cpuPct\",\n   106\t  \"rssBytes\",\n   107\t  \"command\",\n   108\t  \"cwd\",\n   109\t  \"ppid\",\n   110\t  \"state\",\n   111\t  \"nice\",\n   112\t  \"threads\",\n   113\t] as const satisfies readonly (keyof Process)[];\n   114\t\n   115\t// Whether a process's wire-visible state changed since the last poll — the\n   116\t// gate for re-publishing a row.\n   117\tfunction processChanged(a: Process, b: Process): boolean {\n   118\t  return MUTABLE_PROCESS_FIELDS.some((f) => a[f] !== b[f]);\n   119\t}\n   120\t\n   121\t/** The serve operation `serveAgent` calls — narrowed to the one shape it\n   122\t *  uses, so a test can inject a fake (the default is the real stdio\n   123\t *  transport, which is assignable to this). Module-private and named for the\n   124\t *  *role*, not the `serveOverStdio` implementation: nothing outside this file\n   125\t *  consumes it, and the test passes an inline, contextually-typed fake.\n   126\t *  Resolves to `unknown` because the agent only awaits serving's *end*, not\n   127\t *  its value: the real `serveOverStdio` settles with a `ServeOverStdioEnd`\n   128\t *  (`{ reason: \"end\" | \"error\" }` — it never rejects on a peer transport\n   129\t *  death), while a test fake may simply resolve void. */\n   130\ttype Serve = (opts: {\n   131\t  // biome-ignore lint/suspicious/noExplicitAny: the kolu handler's router type; the real serveOverStdio is invoked with the same `as any` cast at the call site below.\n   132\t  router: any;\n   133\t  onFirstRequest: () => void;\n   134\t}) => Promise<unknown>;\n   135\t\n   136\t/**\n   137\t * Build the surface fragment + poll loop for `reader`, then serve it.\n   138\t *\n   139\t * **Serve before you enumerate.** The connect handshake — the parent's first\n   140\t * `system.get` — needs only the cheap `system` snapshot, so that is the one\n   141\t * read we seed before serving. The expensive process scan (darwin: `ps` +\n   142\t * `lsof -nP -d cwd` over the *whole* table) and network read (`netstat`) are\n   143\t * NOT on the handshake's critical path: they start empty and the poll loop\n   144\t * fills them. `await`-ing them before `serve` is what let a busy,\n   145\t * high-process-count host (a loaded macOS box as `localhost`, say) blow the\n   146\t * parent's 30s connect watchdog — \"transport up, no first RPC\" — while the\n   147\t * link itself was fine. See docs/plans/talk-localhost-handshake-timeout.html.\n   148\t *\n   149\t * `serve` is injectable for tests; it defaults to the real stdio transport.\n   150\t */\n   151\texport async function serveAgent(\n   152\t  reader: ProcReader,\n   153\t  serve: Serve = serveOverStdio,\n   154\t): Promise<void> {\n   155\t  // Per-core CPU usage is a *rate* against the previous tick; the reader\n   156\t  // captured its baseline at construction, so this synchronous seed (just\n   157\t  // os.cpus(), no fork) costs nothing and lets a subscriber see cores at once.\n   158\t  // Seeded before `system` so its cpuPct/coreCount aggregate is live too.\n   159\t  const cpuCoreSnapshot = new Map<CoreId, CpuCore>();\n   160\t  for (const [core, value] of reader.readCpuCores())\n   161\t    cpuCoreSnapshot.set(core, value);\n   162\t  // Seed the `system` cell synchronously — the cheap read (vm_stat + statfs\n   163\t  // on darwin, a couple of /proc reads on linux) the handshake actually\n   164\t  // needs, so the cell is live the instant we serve.\n   165\t  const systemStore = inMemoryStore({\n   166\t    ...(await reader.readSystem()),\n   167\t    ...cpuAggregate(cpuCoreSnapshot),\n   168\t    pollIntervalMs: POLL_INTERVAL_MS,\n   169\t  });\n   170\t  // Processes and network start EMPTY and are filled by the poll loop's first\n   171\t  // tick (kicked immediately below), NOT awaited here. On darwin\n   172\t  // `readProcesses` forks `ps` + `lsof` over every pid and `readNetwork`\n   173\t  // forks `netstat`; awaiting them before serving would gate the first RPC\n   174\t  // behind a full process scan — the bug this reorder fixes.\n   175\t  const processSnapshot = new Map<Pid, Process>();\n   176\t  const netSnapshot = new Map<IfaceName, NetInterface>();\n   177\t\n   178\t  // Build the surface implementation. The `processes` collection's\n   179\t  // `readAll` yields the current snapshot; `upsert`/`remove` are the\n   180\t  // single in-process write seam — the poll loop calls\n   181\t  // `fragment.ctx.collections.processes.upsert/remove`, which mutates\n   182\t  // the snapshot AND publishes through the framework's keyed channels.\n   183\t  // `processesSnapshot` stream subscribers read the current map on\n   184\t  // first subscribe, then forward every delta the poll loop publishes.\n   185\t  const snapshotDeltaBus = inMemoryChannel<ProcessesSnapshotMsg>();\n   186\t\n   187\t  // The metrics SOURCE feeding the `alerts` reactor graph. The poll `tick`\n   188\t  // pushes one `MetricsFrame` per tick through `emitMetrics`; `scan` folds each\n   189\t  // occurrence into the raised-alert set via the pure `applyHysteresis`, and\n   190\t  // `derived.cell` publishes that level as the wire-read-only `alerts` cell (its\n   191\t  // own `equals` gate, `alertsEqual`, is the wire dedup). No store: `alerts`\n   192\t  // must NOT survive a restart — a fresh process re-derives its level from fresh\n   193\t  // samples. `emitMetrics` is null until the source's first subscriber installs\n   194\t  // the tap (the `derived.cell`'s connect effect), so the poll's `?.` guard is a\n   195\t  // real pre-connect no-op, not defensive noise.\n   196\t  let emitMetrics: ((f: MetricsFrame) => void) | null = null;\n   197\t  const metrics = source<MetricsFrame>((emit) => {\n   198\t    emitMetrics = emit;\n   199\t    return () => {\n   200\t      emitMetrics = null;\n   201\t    };\n   202\t  });\n   203\t\n   204\t  const fragment = implementSurface(surface, {\n   205\t    channel: inMemoryChannelByName(),\n   206\t    cells: {\n   207\t      // The agent serves the connection-FREE base surface. Link health is the\n   208\t      // PARENT's observation of the parent↔agent link (the agent can't see its\n   209\t      // own SSH transport from the inside), so it's composed only at the parent's\n   210\t      // re-serve via `mirroredSurface`, never here.\n   211\t      system: { store: systemStore },\n   212\t      // The reactor's wire exit: `alerts` is a DERIVED cell — the graph is its\n   213\t      // only writer. `scan(metrics, NO_ALERTS, applyHysteresis)` folds the\n   214\t      // metrics source into the raised-alert set; `derived.cell` plugs into the\n   215\t      // existing cell connect seam ({ store, connect }) and is branded so the\n   216\t      // boot walk enforces the contract's get-only verbs.\n   217\t      alerts: derived.cell(scan(metrics, NO_ALERTS, applyHysteresis)),\n   218\t    },\n   219\t    collections: {\n   220\t      processes: {\n   221\t        readAll: () => processSnapshot,\n   222\t        upsert: (key, value) => {\n   223\t          processSnapshot.set(key, value);\n   224\t        },\n   225\t        remove: (key) => {\n   226\t          processSnapshot.delete(key);\n   227\t        },\n   228\t      },\n   229\t      cpuCores: {\n   230\t        readAll: () => cpuCoreSnapshot,\n   231\t        upsert: (key, value) => {\n   232\t          cpuCoreSnapshot.set(key, value);\n   233\t        },\n   234\t        remove: (key) => {\n   235\t          cpuCoreSnapshot.delete(key);\n   236\t        },\n   237\t      },\n   238\t      networkInterfaces: {\n   239\t        readAll: () => netSnapshot,\n   240\t        upsert: (key, value) => {\n   241\t          netSnapshot.set(key, value);\n   242\t        },\n   243\t        remove: (key) => {\n   244\t          netSnapshot.delete(key);\n   245\t        },\n   246\t      },\n   247\t    },\n   248\t    streams: {\n   249\t      processesSnapshot: {\n   250\t        source: async function* (_input, signal) {\n   251\t          yield {\n   252\t            kind: \"snapshot\",\n   253\t            entries: [...processSnapshot.entries()],\n   254\t          } satisfies ProcessesSnapshotMsg;\n   255\t          for await (const delta of snapshotDeltaBus.subscribe(signal)) {\n   256\t            yield delta;\n   257\t          }\n   258\t        },\n   259\t      },\n   260\t      // ⚠ **INERT STUB — the agent keeps no history.** Declared on the\n   261\t      // shared surface so the browser can subscribe; the parent is the\n   262\t      // authoritative source (see router.ts). A direct-to-agent client sees\n   263\t      // an empty, never-updating history — by design, like `connection`.\n   264\t      // After the empty snapshot it parks until the subscriber leaves —\n   265\t      // never an active transport, so there's no channel to allocate.\n   266\t      metricHistory: {\n   267\t        source: async function* (_input, signal) {\n   268\t          yield { kind: \"snapshot\", samples: [] } satisfies MetricHistoryMsg;\n   269\t          await new Promise<void>((resolve) => {\n   270\t            if (!signal || signal.aborted) resolve();\n   271\t            else\n   272\t              signal.addEventListener(\"abort\", () => resolve(), { once: true });\n   273\t          });\n   274\t        },\n   275\t      },\n   276\t    },\n   277\t    // The one PROCEDURE on this surface — `kill` runs HERE, on the host that owns\n   278\t    // the pids (the parent has none; it forwards through the mirror's stub, kolu\n   279\t    // #1505 R7). `process.kill` raising (ESRCH gone, EPERM not permitted) is a\n   280\t    // normal, reportable outcome, not a crash — caught and returned as\n   281\t    // `{ ok: false, error }` so the browser can surface it.\n   282\t    procedures: {\n   283\t      process: {\n   284\t        kill: ({ input }) => {\n   285\t          try {\n   286\t            process.kill(input.pid, `SIG${input.signal}`);\n   287\t            return { ok: true };\n   288\t          } catch (err) {\n   289\t            return { ok: false, error: (err as Error).message };\n   290\t          }\n   291\t        },\n   292\t      },\n   293\t    },\n   294\t  });\n   295\t\n   296\t  // Poll loop: refresh system + processes, diff against current\n   297\t  // `processSnapshot`, push deltas through the framework's ctx (which\n   298\t  // mutates the snapshot AND publishes to subscribers in one step).\n   299\t  const tick = async (): Promise<void> => {\n   300\t    try {\n   301\t      const [nextSystem, nextProcesses, nextNet] = await Promise.all([\n   302\t        reader.readSystem(),\n   303\t        reader.readProcesses(),\n   304\t        reader.readNetwork(),\n   305\t      ]);\n   306\t      // Read per-core usage up front so the host-CPU aggregate (cpuPct /\n   307\t      // coreCount) rides this tick's `system` cell — the fleet card reads that\n   308\t      // one scalar instead of subscribing to all N per-core cells to average\n   309\t      // them (the O(hosts×cores) fan-out the fleet used to pay).\n   310\t      const nextCores = reader.readCpuCores();\n   311\t      const sys = {\n   312\t        ...nextSystem,\n   313\t        ...cpuAggregate(nextCores),\n   314\t        pollIntervalMs: POLL_INTERVAL_MS,\n   315\t      };\n   316\t      fragment.ctx.cells.system.set(sys);\n   317\t      // Feed the alert reactor the frame just composed. `emitMetrics` is null\n   318\t      // until a subscriber installs the source tap (the `derived.cell` connect\n   319\t      // effect), so a tick before wiring is a no-op — the fold re-derives from\n   320\t      // subsequent frames.\n   321\t      emitMetrics?.(metricPercents(sys));\n   322\t      const upserts: Array<[Pid, Process]> = [];\n   323\t      const removes: Pid[] = [];\n   324\t      for (const [pid, value] of nextProcesses) {\n   325\t        const prev = processSnapshot.get(pid);\n   326\t        if (prev === undefined || processChanged(prev, value)) {\n   327\t          fragment.ctx.collections.processes.upsert(pid, value);\n   328\t          upserts.push([pid, value]);\n   329\t        }\n   330\t      }\n   331\t      for (const pid of processSnapshot.keys()) {\n   332\t        if (!nextProcesses.has(pid)) {\n   333\t          fragment.ctx.collections.processes.remove(pid);\n   334\t          removes.push(pid);\n   335\t        }\n   336\t      }\n   337\t      if (upserts.length > 0 || removes.length > 0) {\n   338\t        snapshotDeltaBus.publish({ kind: \"delta\", upserts, removes });\n   339\t      }\n   340\t\n   341\t      // Per-core CPU usage — published through the framework's\n   342\t      // Collection<K,T>. Small-N (4-32 cores) so per-key fan-out is the right\n   343\t      // shape for the host drill-in, where each core gets its own reactive bar;\n   344\t      // the fleet glance card reads the `system.cpuPct` aggregate above instead\n   345\t      // of subscribing here. `nextCores` was read above for that aggregate.\n   346\t      // Evict cores that disappeared (hot-unplug / VM CPU resize) so stale bars\n   347\t      // don't linger in the browser strip.\n   348\t      for (const [core, value] of nextCores) {\n   349\t        fragment.ctx.collections.cpuCores.upsert(core, value);\n   350\t      }\n   351\t      for (const core of cpuCoreSnapshot.keys()) {\n   352\t        if (!nextCores.has(core))\n   353\t          fragment.ctx.collections.cpuCores.remove(core);\n   354\t      }\n   355\t\n   356\t      // Per-NIC network I/O — same Collection<K,T> publish shape as\n   357\t      // cpuCores. Throughput shifts almost every tick, so unconditional\n   358\t      // upserts are simplest; evict interfaces that vanished (NIC down /\n   359\t      // hot-unplug) so stale rows don't linger in the browser. `nextNet`\n   360\t      // is read in the tick-top Promise.all — an independent forked probe\n   361\t      // (darwin `netstat`), so it rides alongside system/processes rather\n   362\t      // than adding a serial leg to every tick's latency.\n   363\t      for (const [iface, value] of nextNet) {\n   364\t        fragment.ctx.collections.networkInterfaces.upsert(iface, value);\n   365\t      }\n   366\t      for (const iface of netSnapshot.keys()) {\n   367\t        if (!nextNet.has(iface))\n   368\t          fragment.ctx.collections.networkInterfaces.remove(iface);\n   369\t      }\n   370\t    } catch (err) {\n   371\t      log(`tick error: ${(err as Error).message}`);\n   372\t    }\n   373\t  };\n   374\t  const interval = setInterval(() => {\n   375\t    void tick();\n   376\t  }, POLL_INTERVAL_MS);\n   377\t  // Kick the first enumeration immediately and fire-and-forget, so processes\n   378\t  // and network populate within one scan rather than after a full poll\n   379\t  // interval — but off the serving critical path, so the handshake still\n   380\t  // roundtrips now. (The broken-stdout smoke test writes to fd 1 in `main`,\n     1\t/**\n     2\t * Client-side surface bundle — ONE WebSocket for the whole app.\n     3\t *\n     4\t * Every configured host used to get its own `PartySocket` via\n     5\t * `connectSurface`; that's DELETED (`@kolu/surface-map` adoption). Now the\n     6\t * admin socket — drishti's control plane (host set + the surface-app\n     7\t * sibling) — is the ONLY connection. Every host's own data (`system` /\n     8\t * `cpuCores` / `processesSnapshot` / `connection` / …) rides the SAME\n     9\t * transport, key-folded through the `hosts` host MAP\n    10\t * (`../common/hostMap.ts`): `connectSurfaceMap(hostSurfaceMap,\n    11\t * conn.transport, \"hosts\")` slices the map's link off the admin socket's\n    12\t * BRANDED handle, so every host chip's dot floors on the SAME real\n    13\t * transport liveness the control plane already watches — there is no\n    14\t * second socket, no second half-open watchdog, and no per-host\n    15\t * `disposeHostSurface` left to call on removal (a departed host's live\n    16\t * subs end typed, over this one socket, the instant the server's `entries`\n    17\t * drops the key).\n    18\t *\n    19\t * `connectSurfaces` wires the half-open liveness heartbeat — probing the\n    20\t * framework-reserved `system.live` round-trip — BY CONSTRUCTION, and its\n    21\t * BRANDED transport handle is what `connectSurfaceMap` requires (never a\n    22\t * raw link), so a silently half-open connection can no longer paint a\n    23\t * green host-map dot either.\n    24\t */\n    25\t\n    26\timport type { ContractRouterClient } from \"@orpc/contract\";\n    27\timport { createProcessIdEcho } from \"@kolu/surface-app/connect\";\n    28\timport { createNotify } from \"@kolu/surface-app/notify\";\n    29\timport { connectSurfaces } from \"@kolu/surface-app/solid\";\n    30\timport { connectSurfaceMap } from \"@kolu/surface-map/client\";\n    31\timport { adminContract, adminSurfaces } from \"../common/admin-surface\";\n    32\timport { ADMIN_HOST_SENTINEL } from \"../common/host\";\n    33\timport { hostSurfaceMap } from \"../common/hostMap\";\n    34\timport type { browserSurface } from \"drishti-common/browser\";\n    35\t\n    36\t// ONE `pid` echo for the ONE socket. The parent mints a fresh `processId`\n    37\t// per boot; the echo threads the last-known one back as the `pid` query\n    38\t// param on every (re)connect so the parent recognizes a stale tab after a\n    39\t// restart and rejects it at the handshake. `App.tsx` feeds this via the\n    40\t// provider's `onProcessId` callback (the turnkey `{ ws, probe }` source\n    41\t// publishes each observed id); it's null until the first probe, so the\n    42\t// first connect omits the param.\n    43\tconst echo = createProcessIdEcho();\n    44\texport const rememberServerProcessId = echo.remember;\n    45\t\n    46\t// The ONE WS URL — WITHOUT the `pid` (the echo appends it). `host=` is kept\n    47\t// as the routing sentinel `main.ts`'s upgrade handler still checks, though\n    48\t// there is now exactly one thing it can route to.\n    49\tfunction wsBase(): string {\n    50\t  const proto = location.protocol === \"https:\" ? \"wss:\" : \"ws:\";\n    51\t  return `${proto}//${location.host}/rpc/ws?host=${encodeURIComponent(ADMIN_HOST_SENTINEL)}`;\n    52\t}\n    53\t\n    54\t// Cold start can take 30+ seconds while the parent provisions the FIRST\n    55\t// host's agent via `nix copy`, so the connect deadline is bumped well past\n    56\t// partysocket's 4s default — without this, the socket flaps repeatedly\n    57\t// during the first connect.\n    58\tconst BASE_SOCKET_OPTIONS = {\n    59\t  connectionTimeout: 60_000,\n    60\t  minReconnectionDelay: 2_000,\n    61\t  maxReconnectionDelay: 15_000,\n    62\t} as const;\n    63\t\n    64\t// The admin transport multiplexes TWO sibling surfaces (kolu#1197/#1201):\n    65\t// drishti's own `admin` surface (host-lifecycle procedures) and\n    66\t// surface-app's complete surface (`buildInfo` + the `identity.info` probe).\n    67\t// `connectSurfaces` splits the one link into a per-key client bundle and\n    68\t// folds them into ONE `health()` fact (`live` AND-reduced across siblings\n    69\t// off the one socket). It ALWAYS wires the half-open watchdog (it mints the\n    70\t// watchdog-backed `LiveSignal` every client — and now the host map too —\n    71\t// requires). The `<SurfaceAppProvider>` lifecycle over the SAME socket\n    72\t// (`App.tsx`) opts ITS own watchdog out (`heartbeat={false}`) so the socket\n    73\t// isn't double-watched; the lifecycle still retires the socket on a\n    74\t// stale-restart, so this opts out of self-retire (`retireOnStaleClose:\n    75\t// false`).\n    76\tconst conn = connectSurfaces({\n    77\t  surfaces: adminSurfaces,\n    78\t  url: wsBase,\n    79\t  echo,\n    80\t  socketOptions: BASE_SOCKET_OPTIONS,\n    81\t  retireOnStaleClose: false,\n    82\t});\n    83\t\n    84\texport const ws = conn.ws;\n    85\t\n    86\t// ── The host MAP — a keyed map of remote surfaces: ONE entry surface\n    87\t//    (`browserSurface`) served N times, keyed by host. `host` is no longer a\n    88\t//    dedicated socket — every host's `system`/`cpuCores`/`processesSnapshot`/\n    89\t//    `connection` rides `hostMap.entry(host)` (a pure point lens) or\n    90\t//    `hostMap.useEntry(activeHost)` (a reactive lens that re-keys on\n    91\t//    switch). The map is dialled over the `hosts` SIBLING of `conn`'s\n    92\t//    BRANDED transport handle: `connectSurfaceMap` slices `hosts` from it\n    93\t//    and recovers the parent `connectSurfaces` watchdog `live` by\n    94\t//    construction (the handle is unforgeable), so every chip floors on the\n    95\t//    real socket — there is no raw `{ live }` seam to pass a\n    96\t//    green-over-dead accessor through.\n    97\texport const hostMap = connectSurfaceMap(hostSurfaceMap, conn.transport, \"hosts\");\n    98\t\n    99\t// The origin's ONE notification seam (kolu W5, `@kolu/surface-app/notify`) —\n   100\t// the last hop of cross-host attention. App-scoped alongside the host map it\n   101\t// draws from: `App.tsx`'s `watchByEntry` over `hostMap` fires `notify.show`\n   102\t// per newly-raised alert, and `notify.onClick` routes a click's `{ host, id }`\n   103\t// back to drill into that host. The payload shape `D` is drishti's own routing\n   104\t// key — the framework carries it opaquely and hands it back verbatim.\n   105\texport const notify = createNotify<{ host: string; id: string }>((data) => {\n   106\t  // Validate the click envelope the framework relays (a live postMessage or a\n   107\t  // cold-start URL param) before routing — a stale/pre-upgrade notification, or a\n   108\t  // `{}` a degraded worker substitutes, is dropped rather than routed to\n   109\t  // `expandHost(undefined)`. Both fields are plain strings here (a host key and a\n   110\t  // metric-series id), so a shape check is the whole validation.\n   111\t  if (typeof data !== \"object\" || data === null) return undefined;\n   112\t  const d = data as Record<string, unknown>;\n   113\t  if (typeof d.host !== \"string\" || typeof d.id !== \"string\") return undefined;\n   114\t  return { host: d.host, id: d.id };\n   115\t});\n   116\t\n   117\t/** The ONE membership-error handler for `hostMap.entries` — shared by every\n   118\t *  whole-collection consumer (`App.tsx`'s reconcile effect, `TabStrip`'s\n   119\t *  strip) so a membership-stream failure toasts once, not per-consumer. */\n   120\texport const onHostMembershipError = (err: Error): void => {\n   121\t  console.error(\"host membership subscription failed\", err);\n   122\t};\n   123\t\n   124\t// `connectSurfaceMap` types `entry(key).rpc` as `unknown` at the generic map\n   125\t// boundary (it sidesteps a TS2590 \"union too complex\" expansion under a\n   126\t// generic `ES`) — recover the CONCRETE contract here, the framework's\n   127\t// blessed \"cast `.rpc` to your concrete contract once at the wire boundary\".\n   128\texport type HostRpc = ContractRouterClient<typeof browserSurface.contract>;\n   129\t\n   130\t/** The per-host PROCEDURE client — `hostRpc(host).surface.process.kill(...)`\n   131\t *  resolves at the map's key-folded wire path. Replaces the old\n   132\t *  `surfaceForHost(host).rpc`. */\n   133\texport function hostRpc(host: string): HostRpc {\n   134\t  return hostMap.entry(host).rpc as HostRpc;\n   135\t}\n   136\t\n   137\t// The admin scoped client's `.rpc` is the slice `{ surface: link.surface.admin }`,\n   138\t// typed `any` by `connectSurfaces`; recover the admin router type so the\n   139\t// imperative host-lifecycle procedures stay typed.\n   140\ttype AdminScopedRpc = {\n   141\t  surface: ContractRouterClient<typeof adminContract>[\"surface\"][\"admin\"];\n   142\t};\n   143\t\n   144\t/** Get the admin surface client — drishti's OWN `admin` surface, used for\n   145\t *  its host-lifecycle procedures. */\n   146\texport function adminClient() {\n   147\t  return conn.clients.admin;\n   148\t}\n   149\t\n   150\t/** The admin surface's PROCEDURE namespace. `adminRpc().hosts.add(...)` /\n   151\t *  `.remove(...)` / `.reconnect(...)` / `.recheck(...)` resolve at\n   152\t *  `/surface/admin/hosts/<verb>`. */\n   153\texport function adminRpc() {\n   154\t  return (conn.clients.admin.rpc as AdminScopedRpc).surface;\n   155\t}\n   156\t\n   157\t/** The surface-app client over the admin transport — the global\n   158\t *  build-identity `buildInfo` cell + the `identity.info` restart probe.\n   159\t *  Handed to `<SurfaceAppProvider controlPlane=...>` and\n   160\t *  `surfaceAppProbe(...)`. The `surfaceApp` key is consumed by the scope,\n   161\t *  so the probe's wire path is `/surface/surfaceApp/identity/info` (the key\n   162\t *  does NOT reappear). */\n   163\texport function surfaceAppClient() {\n   164\t  return conn.clients.surfaceApp;\n   165\t}\n   166\t\n   167\t/** The ONE transport. drishti's control plane — surface-app's\n   168\t *  `<SurfaceAppProvider>` observes ITS open/close to derive the connection\n   169\t *  lifecycle (paired with the `surfaceApp.info` probe to tell a transient\n   170\t *  drop from a parent restart). Every host chip's dot ultimately floors on\n   171\t *  this same socket via `hostMap`'s branded transport slice. */\n   172\texport function adminSocket() {\n   173\t  return conn.ws;\n   174\t}\n     1\t/**\n     2\t * The pure, framework-free metric-history domain — shared by the **parent**\n     3\t * (which owns the in-memory ring and samples it on every poll tick) and the\n     4\t * **browser** (which renders the ring it's streamed). Keeping the ring\n     5\t * maths (eviction, windowing, SVG projection — the part that's wrong on\n     6\t * screen, or wrong in memory, if an index or a scale slips) in one\n     7\t * framework-free module lets it be unit-tested in isolation and reused on\n     8\t * both sides of the wire.\n     9\t *\n    10\t * The history is **server-side and in-memory**: it lives in the parent for\n    11\t * the life of the process, accruing for every connected host whether or not\n    12\t * a browser tab is open on it. A browser gets the whole ring on connect\n    13\t * (snapshot) then per-tick deltas — so reloads and tab switches both replay\n    14\t * the full history instantly. It is never persisted to disk (preserving the\n    15\t * zero-config posture); restarting the parent starts fresh.\n    16\t */\n    17\t\n    18\timport type { MetricSample, SystemInfo } from \"drishti-common\";\n    19\timport { type MetricKey, metricPercents } from \"drishti-common/metrics\";\n    20\t\n    21\t/** The series the chart draws — the shared metric vocabulary, re-exported so the\n    22\t *  client keeps importing it from this history module. */\n    23\texport type { MetricKey };\n    24\t\n    25\t/** Selectable chart windows, mirroring the time-range chips popular\n    26\t *  monitors (Netdata, btop, Datadog) put above their graphs. Ascending by\n    27\t *  span; the widest doubles as the ring's retention bound. */\n    28\texport const HISTORY_WINDOWS = [\n    29\t  { key: \"1m\", ms: 60_000 },\n    30\t  { key: \"5m\", ms: 5 * 60_000 },\n    31\t  { key: \"15m\", ms: 15 * 60_000 },\n    32\t  { key: \"30m\", ms: 30 * 60_000 },\n    33\t] as const;\n    34\t\n    35\texport type HistoryWindowKey = (typeof HISTORY_WINDOWS)[number][\"key\"];\n    36\t\n    37\t/** The widest selectable window — the one the fleet card sparkline pins to,\n    38\t *  so the card always shows the same span as the retention bound. Derived\n    39\t *  from the last entry (the array is ascending by span) so adding a wider\n    40\t *  window automatically widens the sparkline too. */\n    41\t// Non-null assertion: HISTORY_WINDOWS is a non-empty const tuple, so .at(-1)\n    42\t// always resolves. TypeScript can't prove this from the index type alone.\n    43\texport const WIDEST_HISTORY_WINDOW: HistoryWindowKey =\n    44\t  HISTORY_WINDOWS.at(-1)!.key;\n    45\t\n    46\t/** Default window on first open — the widest span, so the chart shows the\n    47\t *  fullest trend the ring retains the moment a host opens. */\n    48\texport const DEFAULT_HISTORY_WINDOW: HistoryWindowKey = \"30m\";\n    49\t\n    50\t/** Retention bound for the ring: the widest selectable window. Samples\n    51\t *  older than this are evicted on push, so a host left open for hours\n    52\t *  still holds at most the widest window's worth of points. Derived from\n    53\t *  the window set so it can't drift below a selectable window — adding a\n    54\t *  wider window automatically widens retention to match. */\n    55\texport const HISTORY_RETENTION_MS = Math.max(\n    56\t  ...HISTORY_WINDOWS.map((w) => w.ms),\n    57\t);\n    58\t\n    59\t/** Resolve a window key to its span in ms, falling back to the narrowest\n    60\t *  window if the key is somehow unknown (never NaN). */\n    61\texport function windowMsFor(key: HistoryWindowKey): number {\n    62\t  return HISTORY_WINDOWS.find((w) => w.key === key)?.ms ?? HISTORY_WINDOWS[0].ms;\n    63\t}\n    64\t\n    65\t/** Whether a raw string is a selectable window key — the guard for\n    66\t *  restoring a persisted choice, so a key dropped from a future build\n    67\t *  falls back to the default instead of selecting nothing. */\n    68\texport function isHistoryWindowKey(raw: string): boolean {\n    69\t  return HISTORY_WINDOWS.some((w) => w.key === raw);\n    70\t}\n    71\t\n    72\t/** Assemble a `MetricSample` from a live system snapshot — the single home for\n    73\t *  \"what a captured sample is.\" The per-metric percentages come from the ONE\n    74\t *  shared system→% projection (`metricPercents` in `drishti-common/metrics`, the\n    75\t *  same projection the agent's alert fold consumes), stamped with the capture\n    76\t *  time. Adding a series touches that projection and the `MetricSample` schema;\n    77\t *  the *render* side is single-sourced separately in the client's `SERIES`\n    78\t *  table. Pure: `t` is passed in. */\n    79\texport function captureSample(t: number, system: SystemInfo): MetricSample {\n    80\t  return { t, ...metricPercents(system) };\n    81\t}\n    82\t\n    83\t/** Append a sample and evict any older than `retentionMs` behind the\n    84\t *  newest. Returns a new array (the caller holds it in a signal or a\n    85\t *  closure cell); the input is never mutated. The cutoff is measured from\n    86\t *  the newest timestamp across the whole ring — not blindly from the\n    87\t *  incoming sample — so a backwards clock blip can't wipe the buffer. */\n    88\texport function pushSample(\n    89\t  buffer: readonly MetricSample[],\n    90\t  sample: MetricSample,\n    91\t  retentionMs: number,\n    92\t): MetricSample[] {\n    93\t  const next = [...buffer, sample];\n    94\t  const newest = next.reduce((max, s) => (s.t > max ? s.t : max), sample.t);\n    95\t  const cutoff = newest - retentionMs;\n    96\t  return next.filter((s) => s.t >= cutoff);\n    97\t}\n    98\t\n    99\t/** The slice within `windowMs` of `now` — what the chart draws for the\n   100\t *  selected duration. `now` is passed in (not read from the clock) so the\n   101\t *  projection stays pure and testable. */\n   102\texport function windowSlice(\n   103\t  buffer: readonly MetricSample[],\n   104\t  windowMs: number,\n   105\t  now: number,\n   106\t): readonly MetricSample[] {\n   107\t  const cutoff = now - windowMs;\n   108\t  // The buffer is time-ascending, so if its OLDEST sample is already within the\n   109\t  // window every sample is — return it as-is. The fleet card pins the widest\n   110\t  // window (= the ring's retention bound), so it hits this every tick and skips\n   111\t  // an O(ring) filter allocation, handing the buffer straight to `downsample`.\n   112\t  if (buffer.length === 0 || buffer[0]!.t >= cutoff) return buffer;\n   113\t  return buffer.filter((s) => s.t >= cutoff);\n   114\t}\n   115\t\n   116\t/** Max points a glance sparkline / drill-in chart is drawn from. A trace\n   117\t *  renders into at most a few hundred horizontal pixels, so beyond ~one point\n   118\t *  per pixel the extra samples are invisible — yet each still costs a\n   119\t *  coordinate pair, two `toFixed` calls, and ~12 bytes of `points` string PER\n   120\t *  series PER tick. The 30m ring holds 900 samples at the 2s cadence; without a\n   121\t *  cap the fleet redraws 27 polylines × 900 points (~24k points, ~270 KB of\n   122\t *  strings) every tick into 40px boxes. Capping turns that into a fixed,\n   123\t *  pixel-sized draw. The fleet sparkline is ~40px tall; the host chart wider. */\n   124\texport const SPARKLINE_MAX_POINTS = 120;\n   125\texport const CHART_MAX_POINTS = 240;\n   126\t\n   127\t/** Reduce a series to at most `maxPoints` evenly-spaced samples, always keeping\n   128\t *  the first and last (so the trace still spans the full window and its right\n   129\t *  edge stays \"latest\"). A no-op when already within budget. Pure; the input is\n   130\t *  never mutated. Index-strided (not time-bucketed averaged) because a monitor\n   131\t *  trace wants the real peaks/troughs preserved, not smoothed away. */\n   132\texport function downsample<T>(\n   133\t  items: readonly T[],\n   134\t  maxPoints: number,\n   135\t): readonly T[] {\n   136\t  const n = items.length;\n   137\t  if (maxPoints <= 0 || n <= maxPoints) return items;\n   138\t  if (maxPoints === 1) return [items[n - 1]!];\n   139\t  const out: T[] = [];\n   140\t  for (let i = 0; i < maxPoints; i++) {\n   141\t    out.push(items[Math.round((i * (n - 1)) / (maxPoints - 1))]!);\n   142\t  }\n   143\t  return out;\n   144\t}\n   145\t\n   146\tfunction clamp(n: number, lo: number, hi: number): number {\n   147\t  return n < lo ? lo : n > hi ? hi : n;\n   148\t}\n   149\t\n   150\t/** Project samples to an SVG polyline `points` string in a 0-100 × 0-100\n   151\t *  viewBox. X maps time across the window (left edge = `now - windowMs`,\n   152\t *  right edge = `now`) so the trace fills in from the right as data\n   153\t *  accrues, exactly like the time-range graphs in btop/Netdata. Y inverts\n   154\t *  the 0-100 metric (SVG's origin is top-left, so 100% sits at y=0). Both\n   155\t *  axes are clamped to the band. Empty input yields \"\". */\n   156\texport function polylinePoints(\n   157\t  samples: readonly MetricSample[],\n   158\t  key: MetricKey,\n   159\t  now: number,\n   160\t  windowMs: number,\n   161\t): string {\n   162\t  const start = now - windowMs;\n   163\t  return samples\n   164\t    .map((s) => {\n   165\t      const x = clamp(((s.t - start) / windowMs) * 100, 0, 100);\n   166\t      const y = 100 - clamp(s[key], 0, 100);\n   167\t      return `${x.toFixed(2)},${y.toFixed(2)}`;\n   168\t    })\n   169\t    .join(\" \");\n   170\t}\n     1\t/**\n     2\t * Parent-side router — bridges browser ↔ remote agent.\n     3\t *\n     4\t * The browser subscribes to the same `surface` as the agent serves. The\n     5\t * parent doesn't re-define a different surface; it implements the agent\n     6\t * surface locally by *forwarding* every read to the remote stdio client.\n     7\t * On a fresh subscriber, the parent:\n     8\t *\n     9\t *   1. Synchronously yields the parent's connection-state-aware\n    10\t *      `system` snapshot (state = \"copying\" / \"connecting\" / etc.).\n    11\t *   2. Once the agent's link is up, mirrors the agent's `system` and\n    12\t *      `processes` updates into the parent's local store/collection.\n    13\t *   3. Per-key process upserts/removes from the agent flow through to\n    14\t *      the framework's channels and on to the browser.\n    15\t *\n    16\t * The surface is strictly read-only — it carries no procedures, so the\n    17\t * parent only ever mirrors agent data inward; it never forwards a\n    18\t * mutation back to the host.\n    19\t *\n    20\t * R7 keystone (kolu #1505): the reconnect-mirror loop that used to live\n    21\t * here as `bridgeAgentToParent` is now `@kolu/surface-remote`'s\n    22\t * `pumpRemoteSurface` — lifted verbatim-in-shape from this file so\n    23\t * pulam-web's terminal-awareness server can share it. drishti keeps only\n    24\t * the surface-specific knowledge the pump deliberately doesn't hold: the\n    25\t * per-spawn sink (`makeSink`) that folds the agent's `system` / `cpuCores`\n    26\t * / `networkInterfaces` / `processesSnapshot` frames into the parent's\n    27\t * local surface, and the `liveProcedures` holder the `kill` forward reads.\n    28\t *\n    29\t * The router this file builds is now the ENTRY surface `@kolu/surface-map`\n    30\t * serves N times — `admin-router.ts`'s `serveHostMap` calls `buildRouter`\n    31\t * once per pool member and hands `directLink(router)` to the map as that\n    32\t * host's `linkFor`, replacing the `RPCHandler`-per-`?host=`-socket dispatch\n    33\t * this file used to feed directly.\n    34\t */\n    35\t\n    36\timport { implement } from \"@orpc/server\";\n    37\timport {\n    38\t  type CellStore,\n    39\t  type Channel,\n    40\t  implementSurface,\n    41\t  inMemoryChannel,\n    42\t  inMemoryChannelByName,\n    43\t  inMemoryStore,\n    44\t} from \"@kolu/surface/server\";\n    45\timport { type ProcedureForwarders } from \"@kolu/surface/mirror\";\n    46\timport {\n    47\t  type AgentClient,\n    48\t  pumpRemoteSurface,\n    49\t  seedConnectionCell,\n    50\t  type Session,\n    51\t  type SshProv,\n    52\t} from \"@kolu/surface-remote\";\n    53\timport { browserSurface, type ConnectionInfo } from \"drishti-common/browser\";\n    54\timport {\n    55\t  type CoreId,\n    56\t  type CpuCore,\n    57\t  DEFAULT_SYSTEM,\n    58\t  type IfaceName,\n    59\t  type MetricHistoryMsg,\n    60\t  type MetricSample,\n    61\t  type NetInterface,\n    62\t  type Pid,\n    63\t  type Process,\n    64\t  type ProcessesSnapshotMsg,\n    65\t  type SystemInfo,\n    66\t  surface,\n    67\t} from \"drishti-common\";\n    68\timport { type Alerts, NO_ALERTS } from \"drishti-common/alerts\";\n    69\timport {\n    70\t  captureSample,\n    71\t  HISTORY_RETENTION_MS,\n    72\t  pushSample,\n    73\t} from \"../common/history\";\n    74\timport { type Logger, makeLogger } from \"./log\";\n    75\t\n    76\texport interface BuildRouterOptions {\n    77\t  /** The host this router bridges — used only to tag the bridge's log\n    78\t   *  lines (`bridge:${host}`). The `Session` keeps its `host` private,\n    79\t   *  so the registry (which has it) passes it in explicitly. */\n    80\t  host: string;\n    81\t  session: Session<AgentClient<typeof surface.contract>, SshProv>;\n    82\t}\n    83\t\n    84\t/** Build the parent's oRPC router. The session's connection state\n    85\t *  drives the `system.state` field exposed to the browser; agent data\n    86\t *  flows through once the link is live. */\n    87\texport function buildRouter(opts: BuildRouterOptions) {\n    88\t  const session = opts.session;\n    89\t  // Per-host bridge logger. One `buildRouter` runs per host, so a tag\n    90\t  // built from `host` here gives every bridge line a host discriminator —\n    91\t  // without it, the N concurrent per-host bridge loops all wrote a flat\n    92\t  // `[bridge]` and interleaved into one unattributable stream.\n    93\t  const log = makeLogger(`bridge:${opts.host}`);\n    94\t  const systemStore: CellStore<SystemInfo> = inMemoryStore({\n    95\t    ...DEFAULT_SYSTEM,\n    96\t  });\n    97\t  // The parent MIRRORS the agent's `alerts` cell (the agent is the sole\n    98\t  // producer — it folds the threshold+hysteresis derivation via the reactor).\n    99\t  // A plain local store the pump sink writes each agent `alerts` frame into,\n   100\t  // re-served to the browser exactly like `system`. Seeds gate-closed\n   101\t  // (`NO_ALERTS`) until the first agent frame lands.\n   102\t  const alertsStore: CellStore<Alerts> = inMemoryStore({ ...NO_ALERTS });\n   103\t  // The seeded, gate-closed connection cell — the shared `seedConnectionCell()`,\n   104\t  // not a hand-rolled store. Written by `pumpRemoteSurface` off `session.onState`\n   105\t  // (the `connection` option below), which owns the subscription + teardown.\n   106\t  const connection = seedConnectionCell();\n   107\t  const processCache = new Map<Pid, Process>();\n   108\t  const coreCache = new Map<CoreId, CpuCore>();\n   109\t  const netCache = new Map<IfaceName, NetInterface>();\n   110\t  // Local snapshot bus — every msg the parent receives from the\n   111\t  // agent's snapshot stream is also re-published here so the parent's\n   112\t  // own `processesSnapshot` source (consumed by the browser) can\n   113\t  // forward the same data without re-subscribing to the agent.\n   114\t  const browserSnapshotBus: Channel<ProcessesSnapshotMsg> =\n   115\t    inMemoryChannel<ProcessesSnapshotMsg>();\n   116\t  // Parent-owned metric-history ring. Sampled once per agent poll tick (see\n   117\t  // `recordSample`), bounded to the widest selectable window, and held for\n   118\t  // the life of this session — independent of any browser. A new browser\n   119\t  // subscriber is re-seeded from `historyRing` (full snapshot) then fed\n   120\t  // per-tick deltas via `historyBus`, so reloads and tab switches replay the\n   121\t  // whole history. Reassigned (not mutated) by `pushSample`; the stream\n   122\t  // source reads the current binding on subscribe.\n   123\t  let historyRing: MetricSample[] = [];\n   124\t  const historyBus: Channel<MetricHistoryMsg> =\n   125\t    inMemoryChannel<MetricHistoryMsg>();\n   126\t\n   127\t  // R7 (kolu #1505): the browser's `process.kill` is forwarded to the agent\n   128\t  // through the MIRROR's procedure stub — the first forwarded procedure on a\n   129\t  // mirrored surface. The mirror is re-issued per spawn (stdio doesn't recover\n   130\t  // mid-stream), so the live stub set lives in this holder: the pump sets it\n   131\t  // on each connect and clears it when the link dies. A kill with no live agent\n   132\t  // reports `{ ok: false }` rather than silently no-op'ing.\n   133\t  const liveProcedures: {\n   134\t    current: ProcedureForwarders<typeof surface.spec> | null;\n   135\t  } = { current: null };\n   136\t\n   137\t  // Implements the MIRRORED surface (base + the get-only `connection` cell). The\n   138\t  // base primitives are forwarded/folded from the agent; `connection` is the\n   139\t  // seeded local store the session pump writes — the agent's surface stays\n   140\t  // connection-free.\n   141\t  const fragment = implementSurface(browserSurface, {\n   142\t    // Name-keyed in-memory channel factory — publish/subscribe sites\n   143\t    // land on the same `Channel<T>` instance per name.\n   144\t    channel: inMemoryChannelByName(),\n   145\t    cells: {\n   146\t      system: { store: systemStore },\n   147\t      alerts: { store: alertsStore },\n   148\t      connection,\n   149\t    },\n   150\t    collections: {\n   151\t      processes: {\n   152\t        readAll: () => processCache,\n   153\t        // The framework's wrapped upsert/remove call these deps first\n   154\t        // and only then publish through the keyed channels. If we throw\n   155\t        // here (to \"guard against browser writes\"), the framework's own\n   156\t        // bridging path — `ctx.collections.processes.upsert(...)` from\n   157\t        // `reconcileProcesses` — also throws and the publish never fires.\n   158\t        // Browser-vs-server isn't a write-vs-read distinction inside the\n   159\t        // process; it's a wire-protocol distinction (the browser-facing\n   160\t        // contract simply doesn't expose `upsert` / `remove`). So these\n   161\t        // deps stay as the single in-process write seam.\n   162\t        upsert: (key, value) => {\n   163\t          processCache.set(key, value);\n   164\t        },\n   165\t        remove: (key) => {\n   166\t          processCache.delete(key);\n   167\t        },\n   168\t      },\n   169\t      cpuCores: {\n   170\t        readAll: () => coreCache,\n   171\t        upsert: (key, value) => {\n   172\t          coreCache.set(key, value);\n   173\t        },\n   174\t        remove: (key) => {\n   175\t          coreCache.delete(key);\n   176\t        },\n   177\t      },\n   178\t      networkInterfaces: {\n   179\t        readAll: () => netCache,\n   180\t        upsert: (key, value) => {\n   181\t          netCache.set(key, value);\n   182\t        },\n   183\t        remove: (key) => {\n   184\t          netCache.delete(key);\n   185\t        },\n   186\t      },\n   187\t    },\n   188\t    streams: {\n   189\t      // Browser-facing snapshot stream — yields the parent's current\n   190\t      // process cache on subscribe (synchronous snapshot from local\n   191\t      // state, no agent round-trip needed) then forwards every delta\n   192\t      // / snapshot the agent publishes via the parent's local bus.\n   193\t      processesSnapshot: {\n   194\t        source: async function* (_input, signal) {\n   195\t          yield {\n   196\t            kind: \"snapshot\",\n   197\t            entries: [...processCache.entries()],\n   198\t          } satisfies ProcessesSnapshotMsg;\n   199\t          for await (const msg of browserSnapshotBus.subscribe(signal)) {\n   200\t            yield msg;\n   201\t          }\n   202\t        },\n   203\t      },\n   204\t      // Browser-facing metric-history stream — yields the parent's current\n   205\t      // ring on subscribe (the full history, so a reload/tab-switch replays\n   206\t      // it), then forwards each per-tick delta the sampler publishes.\n   207\t      metricHistory: {\n   208\t        source: async function* (_input, signal) {\n   209\t          yield {\n   210\t            kind: \"snapshot\",\n   211\t            samples: [...historyRing],\n   212\t          } satisfies MetricHistoryMsg;\n   213\t          for await (const msg of historyBus.subscribe(signal)) {\n   214\t            yield msg;\n   215\t          }\n   216\t        },\n   217\t      },\n   218\t    },\n   219\t    // The browser-facing `kill` is a pure FORWARD: the parent owns no pids, so it\n   220\t    // relays to the agent through the live mirror's procedure stub (the R7 proof).\n   221\t    // No live link → an honest `{ ok: false }`, surfaced to the user; a stub call\n   222\t    // against a just-dropped link rejects and the rejection reaches the browser.\n   223\t    procedures: {\n   224\t      process: {\n   225\t        kill: async ({ input }) => {\n   226\t          const procs = liveProcedures.current;\n   227\t          if (!procs) {\n   228\t            return { ok: false, error: \"no live agent connection\" };\n   229\t          }\n   230\t          return procs.process.kill(input);\n   231\t        },\n   232\t      },\n   233\t    },\n   234\t  });\n   235\t\n   236\t  // Compile-time guard for the least-privilege narrowing: the real\n   237\t  // fragment must satisfy the pump sink's write-only view. Stated here (not\n   238\t  // only implied by the `makeSink` closure below) so a refactor of that sink\n   239\t  // can't quietly drop the check — a surface collection rename surfaces as\n   240\t  // an error on this line.\n   241\t  const _pumpCtx: FragmentCtx = fragment;\n   242\t  void _pumpCtx;\n   243\t\n   244\t  // Sample the metric ring once per agent system tick. Every series reads off\n   245\t  // the just-arrived `system` snapshot — CPU% is the agent-computed\n   246\t  // `system.cpuPct` (the single host-CPU mean), so the parent no longer\n   247\t  // re-averages `coreCache` (which is pumped on a separate leg and could lag\n   248\t  // the system tick by a frame). `pushSample` evicts points past the retention\n   249\t  // bound, and the delta goes to every live browser subscriber.\n   250\t  const recordSample = (system: SystemInfo): void => {\n   251\t    const sample = captureSample(Date.now(), system);\n   252\t    historyRing = pushSample(historyRing, sample, HISTORY_RETENTION_MS);\n   253\t    historyBus.publish({ kind: \"delta\", sample });\n   254\t  };\n   255\t\n   256\t  // ── Bridge remote agent surface → parent's local surface ──────────\n   257\t  // `pumpRemoteSurface` (R7 keystone) pins the session, then loops over\n   258\t  // each successive AgentClient the session produces — each time the agent\n   259\t  // process is respawned (after a transport drop), the pump fetches the new\n   260\t  // client and re-issues ONE `mirrorRemoteSurface` against the sink built\n   261\t  // below. The framework's `ClientRetryPlugin` is NOT load-bearing here:\n   262\t  // stdio links don't recover mid-stream (the underlying streams die with\n   263\t  // the process), so the only reliable recovery is to re-mirror on the\n   264\t  // *new* client. The pump's outer loop is what implements \"reconnect →\n   265\t  // state reconciles, no ghosts\"; drishti supplies only the per-spawn sink.\n   266\t  void pumpRemoteSurface({\n   267\t    source: surface,\n   268\t    session,\n   269\t    // Build the mirror sink for ONE freshly-spawned client. Called once per\n   270\t    // (re)spawn, so the per-client state below resets naturally each\n   271\t    // reconnect: the agent leads every (re)connect with a fresh `system`\n   272\t    // snapshot, so the first-frame handshake marker and the frame counter\n   273\t    // re-arm with the client. `seq` labels successive spawns (`#1`, `#2`, …)\n   274\t    // so the otherwise-identical per-reconnect log lines trace to a specific\n   275\t    // spawn — if the mirror against `#2` never yields a `system` frame while\n   276\t    // the agent logged `serving surface over stdio`, the handoff (not the\n   277\t    // remote) is where a stuck reconnect lives.\n   278\t    makeSink: ({ seq }) => {\n   279\t      let firstSystemFrame = true;\n   280\t      let frames = 0;\n   281\t      const issuedAt = Date.now();\n   282\t      return {\n   283\t        cells: {\n   284\t          // The agent's `system` cell → the parent's. The first yield is also\n   285\t          // the connection handshake: it flips the session to `connected`\n   286\t          // (idempotent thereafter). Every tick is the parent's authoritative\n   287\t          // metric-history sampling point (it sees every tick, browser or not).\n   288\t          system: (remoteSystem) => {\n   289\t            if (firstSystemFrame) {\n   290\t              firstSystemFrame = false;\n   291\t              log(\n   292\t                `system: first snapshot → marking connected (client #${seq}, ${Date.now() - issuedAt}ms to first RPC)`,\n   293\t              );\n   294\t            }\n   295\t            session.markConnected();\n   296\t            fragment.ctx.cells.system.set(remoteSystem);\n   297\t            recordSample(remoteSystem);\n   298\t          },\n   299\t          // The agent's `alerts` cell → the parent's. Wire-read-only downstream;\n   300\t          // the parent only ever mirrors the agent's derived value inward. The\n   301\t          // agent's own `equals` (`alertsEqual`) already gated the frame, so a\n   302\t          // frame arriving here is a genuine raise/clear worth re-publishing.\n   303\t          alerts: (remoteAlerts) => {\n   304\t            fragment.ctx.cells.alerts.set(remoteAlerts);\n   305\t          },\n   306\t        },\n   307\t        collections: {\n   308\t          // Small-N per-key collections — the path the private collection\n   309\t          // engine drives (keys stream + per-key value streams). `coreCache` /\n   310\t          // `netCache` outlive the per-spawn sink (they're minted once above),\n   311\t          // so a core/iface that vanished while the ssh link was down would\n   312\t          // survive as a ghost row across the reconnect. `initialKeys` hands the\n   313\t          // fresh mirror this spawn's carry-over keys; its first `keys` frame\n   314\t          // prunes any the snapshot omits — no stale row, no empty flash\n   315\t          // (kolu #1661; mirrors surface-remote's reServeSurface).\n   316\t          cpuCores: {\n   317\t            upsert: (key, value) =>\n   318\t              fragment.ctx.collections.cpuCores.upsert(key, value),\n   319\t            remove: (key) => fragment.ctx.collections.cpuCores.remove(key),\n   320\t            initialKeys: () => new Set(coreCache.keys()),\n","exit_code":0,"status":"completed"}}
{"type":"item.started","item":{"id":"item_5","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba packages/app/src/server/router.ts | sed -n '280,520p'; nl -ba packages/app/src/client/wire.ts | sed -n '1,260p'; git diff --no-ext-diff --unified=30 18fce74e184e5d0bde723c24ef435783f363d527 -- packages/app/src/client/App.tsx\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
{"type":"item.completed","item":{"id":"item_5","type":"command_execution","command":"/run/current-system/sw/bin/bash -lc \"nl -ba packages/app/src/server/router.ts | sed -n '280,520p'; nl -ba packages/app/src/client/wire.ts | sed -n '1,260p'; git diff --no-ext-diff --unified=30 18fce74e184e5d0bde723c24ef435783f363d527 -- packages/app/src/client/App.tsx\"","aggregated_output":"   280\t      let frames = 0;\n   281\t      const issuedAt = Date.now();\n   282\t      return {\n   283\t        cells: {\n   284\t          // The agent's `system` cell → the parent's. The first yield is also\n   285\t          // the connection handshake: it flips the session to `connected`\n   286\t          // (idempotent thereafter). Every tick is the parent's authoritative\n   287\t          // metric-history sampling point (it sees every tick, browser or not).\n   288\t          system: (remoteSystem) => {\n   289\t            if (firstSystemFrame) {\n   290\t              firstSystemFrame = false;\n   291\t              log(\n   292\t                `system: first snapshot → marking connected (client #${seq}, ${Date.now() - issuedAt}ms to first RPC)`,\n   293\t              );\n   294\t            }\n   295\t            session.markConnected();\n   296\t            fragment.ctx.cells.system.set(remoteSystem);\n   297\t            recordSample(remoteSystem);\n   298\t          },\n   299\t          // The agent's `alerts` cell → the parent's. Wire-read-only downstream;\n   300\t          // the parent only ever mirrors the agent's derived value inward. The\n   301\t          // agent's own `equals` (`alertsEqual`) already gated the frame, so a\n   302\t          // frame arriving here is a genuine raise/clear worth re-publishing.\n   303\t          alerts: (remoteAlerts) => {\n   304\t            fragment.ctx.cells.alerts.set(remoteAlerts);\n   305\t          },\n   306\t        },\n   307\t        collections: {\n   308\t          // Small-N per-key collections — the path the private collection\n   309\t          // engine drives (keys stream + per-key value streams). `coreCache` /\n   310\t          // `netCache` outlive the per-spawn sink (they're minted once above),\n   311\t          // so a core/iface that vanished while the ssh link was down would\n   312\t          // survive as a ghost row across the reconnect. `initialKeys` hands the\n   313\t          // fresh mirror this spawn's carry-over keys; its first `keys` frame\n   314\t          // prunes any the snapshot omits — no stale row, no empty flash\n   315\t          // (kolu #1661; mirrors surface-remote's reServeSurface).\n   316\t          cpuCores: {\n   317\t            upsert: (key, value) =>\n   318\t              fragment.ctx.collections.cpuCores.upsert(key, value),\n   319\t            remove: (key) => fragment.ctx.collections.cpuCores.remove(key),\n   320\t            initialKeys: () => new Set(coreCache.keys()),\n   321\t          },\n   322\t          networkInterfaces: {\n   323\t            upsert: (key, value) =>\n   324\t              fragment.ctx.collections.networkInterfaces.upsert(key, value),\n   325\t            remove: (key) =>\n   326\t              fragment.ctx.collections.networkInterfaces.remove(key),\n   327\t            initialKeys: () => new Set(netCache.keys()),\n   328\t          },\n   329\t        },\n   330\t        streams: {\n   331\t          // Bulk discriminated-union stream — ONE long-lived stream regardless\n   332\t          // of process count (vs. keys-stream + N per-key subscribes, a drip\n   333\t          // over a high-latency ssh link). Each frame is a full keyed-snapshot\n   334\t          // (first, or on reconnect) or a per-tick delta; `applySnapshotMessage`\n   335\t          // applies both, and the parent re-publishes the frame verbatim to its\n   336\t          // browser bus.\n   337\t          processesSnapshot: {\n   338\t            input: {},\n   339\t            onFrame: (msg) => {\n   340\t              frames += 1;\n   341\t              applySnapshotMessage(log, msg, processCache, fragment, frames);\n   342\t              browserSnapshotBus.publish(msg);\n   343\t            },\n   344\t          },\n   345\t        },\n   346\t      };\n   347\t    },\n   348\t    // Publish each spawn's forwarding stubs for the parent's `kill` handler;\n   349\t    // the pump clears them the instant the link dies, so a kill in the gap\n   350\t    // fails honestly rather than calling into a dead client.\n   351\t    liveProcedures,\n   352\t    // The session's link health (copying / connecting / failed) onto the\n   353\t    // browser-facing `connection` cell — the pump OWNS this subscription for the\n   354\t    // session's lifetime and tears it down on exit (kolu #1568), so it can't be\n   355\t    // forgotten or leak. The cell tracks the SESSION's state, never a mirror frame.\n   356\t    connection: { set: (info) => fragment.ctx.cells.connection.set(info) },\n   357\t    log,\n   358\t  });\n   359\t\n   360\t  // `implementSurface` returns a router *fragment* — `{ surface: ... }`\n   361\t  // wrapping the per-key namespaces. Passing it directly to RPCHandler\n   362\t  // produces a `surface/surface/...` double-prefix in the matcher tree\n   363\t  // (no procedure matches what the client sends). Wrap once via\n   364\t  // `implement(contract).router({...fragment})` to flatten the prefix.\n   365\t  const router = implement(browserSurface.contract).router({\n   366\t    ...fragment.router,\n   367\t  });\n   368\t  return { router, session };\n   369\t}\n   370\t\n   371\t/** The write-side methods the pump sink is allowed to touch — a\n   372\t *  deliberate least-privilege narrowing of `implementSurface(...).ctx`,\n   373\t *  not the full ctx. The sink only ever mirrors remote data inward, so it\n   374\t *  gets `set` / `upsert` / `remove`; `readAll` and the underlying stores\n   375\t *  stay out of reach. This is a boundary, not a maintenance chore: the\n   376\t *  `_pumpCtx` guard above assigns the real fragment to this type, so a\n   377\t *  collection renamed or retyped on the surface becomes a compile error\n   378\t *  here rather than silent drift. */\n   379\ttype FragmentCtx = {\n   380\t  ctx: {\n   381\t    cells: {\n   382\t      system: { set: (v: SystemInfo) => void };\n   383\t      alerts: { set: (v: Alerts) => void };\n   384\t      connection: { set: (v: ConnectionInfo) => void };\n   385\t    };\n   386\t    collections: {\n   387\t      processes: {\n   388\t        upsert: (k: Pid, v: Process) => void;\n   389\t        remove: (k: Pid) => void;\n   390\t      };\n   391\t      cpuCores: {\n   392\t        upsert: (k: CoreId, v: CpuCore) => void;\n   393\t        remove: (k: CoreId) => void;\n   394\t      };\n   395\t      networkInterfaces: {\n   396\t        upsert: (k: IfaceName, v: NetInterface) => void;\n   397\t        remove: (k: IfaceName) => void;\n   398\t      };\n   399\t    };\n   400\t  };\n   401\t};\n   402\t\n   403\t/** Apply one `processesSnapshot` frame to the parent's local\n   404\t *  collection — full reset on `snapshot`, incremental delta on\n   405\t *  `delta`. Reads `processCache` directly for the live-PID set; the\n   406\t *  framework's `upsert`/`remove` keep the cache and the per-key\n   407\t *  channels in lockstep, so there's no separate shadow set to\n   408\t *  maintain here. */\n   409\tfunction applySnapshotMessage(\n   410\t  log: Logger,\n   411\t  msg: ProcessesSnapshotMsg,\n   412\t  processCache: Map<Pid, Process>,\n   413\t  fragment: FragmentCtx,\n   414\t  frameNumber: number,\n   415\t): void {\n   416\t  if (msg.kind === \"snapshot\") {\n   417\t    const next = new Set(msg.entries.map(([pid]) => pid));\n   418\t    for (const pid of [...processCache.keys()]) {\n   419\t      if (!next.has(pid)) fragment.ctx.collections.processes.remove(pid);\n   420\t    }\n   421\t    for (const [pid, value] of msg.entries) {\n   422\t      fragment.ctx.collections.processes.upsert(pid, value);\n   423\t    }\n   424\t    log(\n   425\t      `processes: snapshot frame #${frameNumber} — ${msg.entries.length} PIDs (cold-start or reconnect)`,\n   426\t    );\n   427\t    return;\n   428\t  }\n   429\t  for (const [pid, value] of msg.upserts) {\n   430\t    fragment.ctx.collections.processes.upsert(pid, value);\n   431\t  }\n   432\t  for (const pid of msg.removes) {\n   433\t    fragment.ctx.collections.processes.remove(pid);\n   434\t  }\n   435\t  // Per-tick delta frames are intentionally NOT logged — the agent\n   436\t  // polls every 2s, so steady-state deltas would dominate stderr. The\n   437\t  // snapshot frame above and the stream-close/error logs in\n   438\t  // pumpProcessesSnapshot are the load-bearing signals; if you need\n   439\t  // per-tick visibility, attach a debugger or temporarily re-enable\n   440\t  // the line below.\n   441\t  // log(`processes: delta frame #${frameNumber} — upsert=… remove=… total=…`);\n   442\t}\n     1\t/**\n     2\t * Client-side surface bundle — ONE WebSocket for the whole app.\n     3\t *\n     4\t * Every configured host used to get its own `PartySocket` via\n     5\t * `connectSurface`; that's DELETED (`@kolu/surface-map` adoption). Now the\n     6\t * admin socket — drishti's control plane (host set + the surface-app\n     7\t * sibling) — is the ONLY connection. Every host's own data (`system` /\n     8\t * `cpuCores` / `processesSnapshot` / `connection` / …) rides the SAME\n     9\t * transport, key-folded through the `hosts` host MAP\n    10\t * (`../common/hostMap.ts`): `connectSurfaceMap(hostSurfaceMap,\n    11\t * conn.transport, \"hosts\")` slices the map's link off the admin socket's\n    12\t * BRANDED handle, so every host chip's dot floors on the SAME real\n    13\t * transport liveness the control plane already watches — there is no\n    14\t * second socket, no second half-open watchdog, and no per-host\n    15\t * `disposeHostSurface` left to call on removal (a departed host's live\n    16\t * subs end typed, over this one socket, the instant the server's `entries`\n    17\t * drops the key).\n    18\t *\n    19\t * `connectSurfaces` wires the half-open liveness heartbeat — probing the\n    20\t * framework-reserved `system.live` round-trip — BY CONSTRUCTION, and its\n    21\t * BRANDED transport handle is what `connectSurfaceMap` requires (never a\n    22\t * raw link), so a silently half-open connection can no longer paint a\n    23\t * green host-map dot either.\n    24\t */\n    25\t\n    26\timport type { ContractRouterClient } from \"@orpc/contract\";\n    27\timport { createProcessIdEcho } from \"@kolu/surface-app/connect\";\n    28\timport { createNotify } from \"@kolu/surface-app/notify\";\n    29\timport { connectSurfaces } from \"@kolu/surface-app/solid\";\n    30\timport { connectSurfaceMap } from \"@kolu/surface-map/client\";\n    31\timport { adminContract, adminSurfaces } from \"../common/admin-surface\";\n    32\timport { ADMIN_HOST_SENTINEL } from \"../common/host\";\n    33\timport { hostSurfaceMap } from \"../common/hostMap\";\n    34\timport type { browserSurface } from \"drishti-common/browser\";\n    35\t\n    36\t// ONE `pid` echo for the ONE socket. The parent mints a fresh `processId`\n    37\t// per boot; the echo threads the last-known one back as the `pid` query\n    38\t// param on every (re)connect so the parent recognizes a stale tab after a\n    39\t// restart and rejects it at the handshake. `App.tsx` feeds this via the\n    40\t// provider's `onProcessId` callback (the turnkey `{ ws, probe }` source\n    41\t// publishes each observed id); it's null until the first probe, so the\n    42\t// first connect omits the param.\n    43\tconst echo = createProcessIdEcho();\n    44\texport const rememberServerProcessId = echo.remember;\n    45\t\n    46\t// The ONE WS URL — WITHOUT the `pid` (the echo appends it). `host=` is kept\n    47\t// as the routing sentinel `main.ts`'s upgrade handler still checks, though\n    48\t// there is now exactly one thing it can route to.\n    49\tfunction wsBase(): string {\n    50\t  const proto = location.protocol === \"https:\" ? \"wss:\" : \"ws:\";\n    51\t  return `${proto}//${location.host}/rpc/ws?host=${encodeURIComponent(ADMIN_HOST_SENTINEL)}`;\n    52\t}\n    53\t\n    54\t// Cold start can take 30+ seconds while the parent provisions the FIRST\n    55\t// host's agent via `nix copy`, so the connect deadline is bumped well past\n    56\t// partysocket's 4s default — without this, the socket flaps repeatedly\n    57\t// during the first connect.\n    58\tconst BASE_SOCKET_OPTIONS = {\n    59\t  connectionTimeout: 60_000,\n    60\t  minReconnectionDelay: 2_000,\n    61\t  maxReconnectionDelay: 15_000,\n    62\t} as const;\n    63\t\n    64\t// The admin transport multiplexes TWO sibling surfaces (kolu#1197/#1201):\n    65\t// drishti's own `admin` surface (host-lifecycle procedures) and\n    66\t// surface-app's complete surface (`buildInfo` + the `identity.info` probe).\n    67\t// `connectSurfaces` splits the one link into a per-key client bundle and\n    68\t// folds them into ONE `health()` fact (`live` AND-reduced across siblings\n    69\t// off the one socket). It ALWAYS wires the half-open watchdog (it mints the\n    70\t// watchdog-backed `LiveSignal` every client — and now the host map too —\n    71\t// requires). The `<SurfaceAppProvider>` lifecycle over the SAME socket\n    72\t// (`App.tsx`) opts ITS own watchdog out (`heartbeat={false}`) so the socket\n    73\t// isn't double-watched; the lifecycle still retires the socket on a\n    74\t// stale-restart, so this opts out of self-retire (`retireOnStaleClose:\n    75\t// false`).\n    76\tconst conn = connectSurfaces({\n    77\t  surfaces: adminSurfaces,\n    78\t  url: wsBase,\n    79\t  echo,\n    80\t  socketOptions: BASE_SOCKET_OPTIONS,\n    81\t  retireOnStaleClose: false,\n    82\t});\n    83\t\n    84\texport const ws = conn.ws;\n    85\t\n    86\t// ── The host MAP — a keyed map of remote surfaces: ONE entry surface\n    87\t//    (`browserSurface`) served N times, keyed by host. `host` is no longer a\n    88\t//    dedicated socket — every host's `system`/`cpuCores`/`processesSnapshot`/\n    89\t//    `connection` rides `hostMap.entry(host)` (a pure point lens) or\n    90\t//    `hostMap.useEntry(activeHost)` (a reactive lens that re-keys on\n    91\t//    switch). The map is dialled over the `hosts` SIBLING of `conn`'s\n    92\t//    BRANDED transport handle: `connectSurfaceMap` slices `hosts` from it\n    93\t//    and recovers the parent `connectSurfaces` watchdog `live` by\n    94\t//    construction (the handle is unforgeable), so every chip floors on the\n    95\t//    real socket — there is no raw `{ live }` seam to pass a\n    96\t//    green-over-dead accessor through.\n    97\texport const hostMap = connectSurfaceMap(hostSurfaceMap, conn.transport, \"hosts\");\n    98\t\n    99\t// The origin's ONE notification seam (kolu W5, `@kolu/surface-app/notify`) —\n   100\t// the last hop of cross-host attention. App-scoped alongside the host map it\n   101\t// draws from: `App.tsx`'s `watchByEntry` over `hostMap` fires `notify.show`\n   102\t// per newly-raised alert, and `notify.onClick` routes a click's `{ host, id }`\n   103\t// back to drill into that host. The payload shape `D` is drishti's own routing\n   104\t// key — the framework carries it opaquely and hands it back verbatim.\n   105\texport const notify = createNotify<{ host: string; id: string }>((data) => {\n   106\t  // Validate the click envelope the framework relays (a live postMessage or a\n   107\t  // cold-start URL param) before routing — a stale/pre-upgrade notification, or a\n   108\t  // `{}` a degraded worker substitutes, is dropped rather than routed to\n   109\t  // `expandHost(undefined)`. Both fields are plain strings here (a host key and a\n   110\t  // metric-series id), so a shape check is the whole validation.\n   111\t  if (typeof data !== \"object\" || data === null) return undefined;\n   112\t  const d = data as Record<string, unknown>;\n   113\t  if (typeof d.host !== \"string\" || typeof d.id !== \"string\") return undefined;\n   114\t  return { host: d.host, id: d.id };\n   115\t});\n   116\t\n   117\t/** The ONE membership-error handler for `hostMap.entries` — shared by every\n   118\t *  whole-collection consumer (`App.tsx`'s reconcile effect, `TabStrip`'s\n   119\t *  strip) so a membership-stream failure toasts once, not per-consumer. */\n   120\texport const onHostMembershipError = (err: Error): void => {\n   121\t  console.error(\"host membership subscription failed\", err);\n   122\t};\n   123\t\n   124\t// `connectSurfaceMap` types `entry(key).rpc` as `unknown` at the generic map\n   125\t// boundary (it sidesteps a TS2590 \"union too complex\" expansion under a\n   126\t// generic `ES`) — recover the CONCRETE contract here, the framework's\n   127\t// blessed \"cast `.rpc` to your concrete contract once at the wire boundary\".\n   128\texport type HostRpc = ContractRouterClient<typeof browserSurface.contract>;\n   129\t\n   130\t/** The per-host PROCEDURE client — `hostRpc(host).surface.process.kill(...)`\n   131\t *  resolves at the map's key-folded wire path. Replaces the old\n   132\t *  `surfaceForHost(host).rpc`. */\n   133\texport function hostRpc(host: string): HostRpc {\n   134\t  return hostMap.entry(host).rpc as HostRpc;\n   135\t}\n   136\t\n   137\t// The admin scoped client's `.rpc` is the slice `{ surface: link.surface.admin }`,\n   138\t// typed `any` by `connectSurfaces`; recover the admin router type so the\n   139\t// imperative host-lifecycle procedures stay typed.\n   140\ttype AdminScopedRpc = {\n   141\t  surface: ContractRouterClient<typeof adminContract>[\"surface\"][\"admin\"];\n   142\t};\n   143\t\n   144\t/** Get the admin surface client — drishti's OWN `admin` surface, used for\n   145\t *  its host-lifecycle procedures. */\n   146\texport function adminClient() {\n   147\t  return conn.clients.admin;\n   148\t}\n   149\t\n   150\t/** The admin surface's PROCEDURE namespace. `adminRpc().hosts.add(...)` /\n   151\t *  `.remove(...)` / `.reconnect(...)` / `.recheck(...)` resolve at\n   152\t *  `/surface/admin/hosts/<verb>`. */\n   153\texport function adminRpc() {\n   154\t  return (conn.clients.admin.rpc as AdminScopedRpc).surface;\n   155\t}\n   156\t\n   157\t/** The surface-app client over the admin transport — the global\n   158\t *  build-identity `buildInfo` cell + the `identity.info` restart probe.\n   159\t *  Handed to `<SurfaceAppProvider controlPlane=...>` and\n   160\t *  `surfaceAppProbe(...)`. The `surfaceApp` key is consumed by the scope,\n   161\t *  so the probe's wire path is `/surface/surfaceApp/identity/info` (the key\n   162\t *  does NOT reappear). */\n   163\texport function surfaceAppClient() {\n   164\t  return conn.clients.surfaceApp;\n   165\t}\n   166\t\n   167\t/** The ONE transport. drishti's control plane — surface-app's\n   168\t *  `<SurfaceAppProvider>` observes ITS open/close to derive the connection\n   169\t *  lifecycle (paired with the `surfaceApp.info` probe to tell a transient\n   170\t *  drop from a parent restart). Every host chip's dot ultimately floors on\n   171\t *  this same socket via `hostMap`'s branded transport slice. */\n   172\texport function adminSocket() {\n   173\t  return conn.ws;\n   174\t}\ndiff --git a/packages/app/src/client/App.tsx b/packages/app/src/client/App.tsx\nindex 3f5786d..931c596 100644\n--- a/packages/app/src/client/App.tsx\n+++ b/packages/app/src/client/App.tsx\n@@ -10,61 +10,66 @@\n  * `connection` cell subscriptions stay live and the dot colors keep\n  * updating.\n  *\n  * `<HostView>` is the prior single-host body, now parametric on `host`.\n  * The per-host data shape (cells/collections/streams) is unchanged.\n  */\n \n import type { EntryState } from \"@kolu/surface-map\";\n import { unenrolledStreamCall } from \"@kolu/surface/client\";\n import { createSubscription, surfaceClientsHealth } from \"@kolu/surface/solid\";\n import { STALE_PROCESS_CLOSE_CODE } from \"@kolu/surface-app\";\n import { shellCommit } from \"@kolu/surface-app/lifecycle\";\n import { SurfaceAppProvider, surfaceAppProbe } from \"@kolu/surface-app/solid\";\n import { Meta, Title } from \"@solidjs/meta\";\n import {\n   type Accessor,\n   createContext,\n   createEffect,\n   createMemo,\n   createResource,\n   createSignal,\n   For,\n   type JSX,\n   on,\n   onCleanup,\n   type Setter,\n   Show,\n   type Signal,\n   useContext,\n } from \"solid-js\";\n-import { scopedByEntry, type ScopedByEntry } from \"@kolu/surface-map/client\";\n+import {\n+  scopedByEntry,\n+  type ScopedByEntry,\n+  watchByEntry,\n+} from \"@kolu/surface-map/client\";\n+import type { AlertId } from \"drishti-common/alerts\";\n import {\n   type CoreId,\n   type CpuCore,\n   DEFAULT_SYSTEM,\n   type IfaceName,\n   type MetricHistoryMsg,\n   type MetricSample,\n   type NetInterface,\n   type Pid,\n   type Process,\n   type ProcessesSnapshotMsg,\n   type SystemInfo,\n } from \"drishti-common\";\n import {\n   type ConnectionInfo,\n   type ConnectionState,\n   DEFAULT_CONNECTION,\n } from \"drishti-common/browser\";\n import { disconnectedMessage, STATE, withElapsed } from \"./connectionColors\";\n import { HostDot } from \"./HostDot\";\n import type { View } from \"./view\";\n import { searchForView, viewFromSearch } from \"./urlState\";\n import {\n   diskGb,\n   diskPct,\n   formatBytes,\n   formatThroughput,\n   formatUptime,\n   memGb,\n   memPct,\n@@ -83,68 +88,86 @@ import {\n   isHistoryWindowKey,\n   type MetricKey,\n   polylinePoints,\n   pushSample,\n   SPARKLINE_MAX_POINTS,\n   WIDEST_HISTORY_WINDOW,\n   windowMsFor,\n   windowSlice,\n } from \"../common/history\";\n import { StatusFooter } from \"./StatusFooter\";\n import { TabStrip } from \"./TabStrip\";\n import { TransportOverlay } from \"./TransportOverlay\";\n import { prefKey, readPref, writePref } from \"./localStorageState\";\n import { brandColorForTheme } from \"./brand\";\n import { APP_TITLE } from \"./title\";\n import { createPageVisibility } from \"@solid-primitives/page-visibility\";\n import { createVisibilityGate } from \"./visibility\";\n import {\n   applyTheme,\n   initialTheme,\n   otherTheme,\n   THEME_KEY,\n   type Theme,\n } from \"./theme\";\n import {\n   adminClient,\n   adminRpc,\n   adminSocket,\n   hostMap,\n   hostRpc,\n+  notify,\n   onHostMembershipError,\n   rememberServerProcessId,\n   surfaceAppClient,\n } from \"./wire\";\n \n const SORT_KEYS = [\"cpu\", \"mem\", \"pid\", \"user\"] as const;\n type SortKey = (typeof SORT_KEYS)[number];\n \n+// The human word for a raised alert id — a CLIENT-owned presentation lookup\n+// (rename/localize here, no agent or wire change). Exhaustive over `AlertId`,\n+// so `LABELS[id]` always resolves; the word never rides the wire.\n+const LABELS: Record<AlertId, string> = {\n+  cpu: \"CPU\",\n+  mem: \"Memory\",\n+  disk: \"Disk\",\n+};\n+\n+// The Badging API isn't in the DOM lib types; narrow `navigator` to the two\n+// methods drishti calls (both optional — absent on browsers without the API,\n+// where the alert count simply isn't badged). Feature-detected at the call site.\n+type BadgingNavigator = Navigator & {\n+  setAppBadge?: (count?: number) => Promise<void>;\n+  clearAppBadge?: () => Promise<void>;\n+};\n+\n // Human labels for the kernel single-char process state codes (linux\n // `/proc/<pid>/stat` field 3; the leading char of darwin `ps -o state=`).\n // Codes outside this map (rare/transitional) render verbatim.\n const PROCESS_STATE_LABELS: Record<string, string> = {\n   R: \"running\",\n   S: \"sleeping\",\n   D: \"uninterruptible\",\n   Z: \"zombie\",\n   T: \"stopped\",\n   t: \"tracing stop\",\n   I: \"idle\",\n   X: \"dead\",\n   W: \"paging\",\n };\n \n // Which process row (if any) is expanded into the detail panel. Selection is\n // a navigation concern owned by `HostView`, the same tier that owns the\n // `processes` store and the filter/sort prefs — so `ProcessTable` stays a\n // pure renderer (it never learns about selection) and `ProcessRow` reaches\n // the signal through context for its click + highlight, mirroring how the\n // app-level `view` signal threads down without widening every component's\n // props. `toggle` re-selecting the open pid closes the panel.\n type ProcessSelection = {\n   selectedPid: Accessor<Pid | null>;\n   toggle: (pid: Pid) => void;\n };\n const SelectionContext = createContext<ProcessSelection>();\n \n // One host's per-host VIEW state, owned by the host map's `scopedByEntry` scope\n // (padi W7): the expanded PID lives in the host's OWN reactive scope, retained\n@@ -495,60 +518,103 @@ function MultiHostApp() {\n   // Resolve intent against the live host set: a host view whose host has\n   // been removed falls back to the fleet overview rather than a blank\n   // pane, and the fleet view always resolves to itself.\n   const resolvedView = createMemo<View>(() => {\n     const v = view();\n     if (v.kind === \"host\" && hostList().includes(v.host)) return v;\n     return { kind: \"fleet\" };\n   });\n   const selectedHost = createMemo<string | null>(() => {\n     const v = resolvedView();\n     return v.kind === \"host\" ? v.host : null;\n   });\n \n   // Per-host view state owned BY the host map (padi W7's `scopedByEntry`). Each\n   // host's expanded PID is born in its own reactive scope, RETAINED across a tab\n   // switch (restored verbatim on switch-back), and disposed when the host leaves\n   // the fleet. This replaces the per-`HostView` `createSignal` that reset to\n   // `null` on every keyed remount: \"expanded pid lost on tab switch\" dissolves\n   // into the scope's retention. `selectedHost` (nullable — the fleet view selects\n   // no host) stays the app-policy \"which host is shown\"; the framework owns the\n   // per-host lifetime.\n   const hostScopes: ScopedByEntry<string, HostScope> = scopedByEntry(\n     hostMap,\n     selectedHost,\n     () => {\n       const [selectedPid, setSelectedPid] = createSignal<Pid | null>(null);\n       return { selectedPid, setSelectedPid };\n     },\n   );\n \n+  // ── Cross-host attention (kolu W5: watchByEntry + notify) ──────────────\n+  // The FRAMEWORK-GATE consumer of the new `alerts` cell: watch EVERY host's\n+  // alerts EAGERLY (a background host in trouble is exactly the one you need to\n+  // hear from) and fire an OS notification per newly-raised metric. Raise\n+  // detection is the framework's pure set-diff over the stable alert ids; this\n+  // runs under `MultiHostApp`'s reactive owner (watchByEntry throws otherwise)\n+  // and every per-host subscription tears down when the host leaves the fleet.\n+  // Permission is requested once (idempotent); delivery is a silent no-op until\n+  // granted, so an un-permissioned browser costs nothing.\n+  void notify.requestPermission();\n+  const alertsWatch = watchByEntry(\n+    hostMap,\n+    (e) => e.cells.alerts,\n+    (v) => v.items,\n+    (host, raised) =>\n+      raised.forEach((id) =>\n+        void notify.show({\n+          tag: `${host}/${id}`,\n+          title: `${host}: ${LABELS[id]} alert`,\n+          data: { host, id },\n+        }),\n+      ),\n+  );\n+  // A notification click drills into the host it fired for — drishti's\n+  // host-select is just setting the `view` intent. Torn down with the app.\n+  onCleanup(notify.onClick(({ host }) => setView({ kind: \"host\", host })));\n+\n+  // App badge = the COUNT OF HOSTS with any LIVE alert (drishti's own fold — a\n+  // host in trouble is one unit of attention, NOT the sum of its raised\n+  // metrics). A stale host (its link down) keeps its last value marked stale\n+  // and is deliberately NOT counted — a badge should reflect what's live. Guard\n+  // the Badging API (absent on some browsers) at the call site.\n+  createEffect(() => {\n+    const count = hostList().reduce((n, host) => {\n+      const w = alertsWatch.get(host);\n+      return n + (w?.kind === \"live\" && w.value.items.length > 0 ? 1 : 0);\n+    }, 0);\n+    if (typeof navigator === \"undefined\") return;\n+    const nav = navigator as BadgingNavigator;\n+    if (count > 0) void nav.setAppBadge?.(count);\n+    else void nav.clearAppBadge?.();\n+  });\n+\n   // Theme is global app chrome (like `view`), so it lives here, not per\n   // host. The signal seeds from the attribute the pre-paint bootstrap in\n   // index.html already applied; toggling flips the attribute and persists\n   // the choice. `applyTheme` is the single writer of both DOM and storage.\n   const [theme, setTheme] = createSignal<Theme>(initialTheme());\n   // The signal is the source of truth; this effect projects it to the DOM\n   // (via theme.ts, which owns the attribute/element detail) and persists\n   // the choice — the same signal-is-truth / store-is-projection shape as\n   // the per-host pref effects below. `defer` skips the redundant first\n   // write: the pre-paint bootstrap in index.html already applied the\n   // initial theme and storage already holds it.\n   createEffect(\n     on(\n       theme,\n       (t) => {\n         applyTheme(t);\n         writePref(THEME_KEY, t);\n       },\n       { defer: true },\n     ),\n   );\n   const toggleTheme = () => setTheme(otherTheme(theme()));\n \n   const onAdd = async (host: string): Promise<string | null> => {\n     try {\n       const res = await adminRpc().hosts.add({ host });\n       if (!res.ok) return res.error ?? \"add failed\";\n       setView({ kind: \"host\", host });\n       return null;\n     } catch (err) {\n@@ -661,103 +727,116 @@ function MultiHostApp() {\n     </div>\n   );\n }\n \n // ── Fleet overview: every host as a live summary card ──────────────────\n \n // The aggregate \"pane of glass\". Each card subscribes to its host's\n // `system` / `connection` cells and `cpuCores` collection — the same\n // per-host sockets the tab chips already keep warm — so opening the\n // overview costs subscriptions, not new connections. Clicking a card\n // drills into that host's full htop body.\n function FleetView(props: {\n   hosts: readonly string[];\n   onSelect: (host: string) => void;\n }) {\n   return (\n     <div class=\"grid min-h-0 flex-1 grid-cols-1 gap-3 overflow-y-auto p-4 sm:grid-cols-2 lg:grid-cols-3\">\n       <For each={props.hosts}>\n         {(host) => (\n           <HostCard host={host} onSelect={() => props.onSelect(host)} />\n         )}\n       </For>\n     </div>\n   );\n }\n \n function HostCard(props: { host: string; onSelect: () => void }) {\n   const entry = hostMap.entry(props.host);\n   const system = entry.cells.system.use({});\n   const connection = entry.cells.connection.use({});\n+  // The host's raised-alert set (kolu W5 `alerts` cell). A minimal pip on the\n+  // card surfaces \"this host is in trouble\" at a glance, alongside the OS\n+  // notification the app-scope `watchByEntry` fires — same source of truth.\n+  const alerts = entry.cells.alerts.use({});\n+  const alertCount = createMemo(() => alerts.value()?.items.length ?? 0);\n \n   const sys = createMemo<SystemInfo>(() => system.value() ?? DEFAULT_SYSTEM);\n   const state = createMemo<ConnectionState>(\n     () => (connection.value() ?? DEFAULT_CONNECTION).phase,\n   );\n   // The dot + readiness gate read the host MAP's `EntryStatus` fact\n   // (floored on real transport liveness by `connectSurfaceMap`) — the\n   // per-host `SurfaceHealth`/`app.health()` this used to gate on no longer\n   // exists now that every host rides the ONE admin transport. The status\n   // WORD stays driven by the richer `ConnectionState` cell (copying vs\n   // connecting vs the failure detail) — see `HostDot.tsx`'s docstring for\n   // why the dot and the word now read two different facts.\n   const entryState = createMemo<EntryState>(() => entry.state());\n   // CPU% and the core count are read straight off the `system` cell — the agent\n   // folds them in (`system.cpuPct` / `system.coreCount`). The card used to open\n   // the per-key `cpuCores` collection (one value stream PER core PER host) just\n   // to average it for one number; reading the aggregate cell drops the fleet's\n   // entire O(hosts×cores) subscription fan-out. The per-core collection stays\n   // for the host drill-in (CpuStrip), which actually renders a bar per core.\n   const cpuPct = createMemo(() => sys().cpuPct);\n   const coreCount = createMemo(() => sys().coreCount);\n   const mem = createMemo(() => memPct(sys()));\n   const memText = createMemo(() => {\n     const gb = memGb(sys());\n     return `${gb.used}/${gb.total} GB · ${mem().toFixed(0)}%`;\n   });\n   const disk = createMemo(() => diskPct(sys()));\n   const diskText = createMemo(() => {\n     const gb = diskGb(sys());\n     return `/ · ${gb.used}/${gb.total} GB · ${disk().toFixed(0)}%`;\n   });\n \n   return (\n     <button\n       type=\"button\"\n       onClick={props.onSelect}\n       class=\"flex flex-col gap-2 rounded border border-gray-200 bg-gray-50 p-3 text-left transition-colors hover:border-indigo-400 hover:bg-white dark:border-gray-800 dark:bg-gray-900/40 dark:hover:border-indigo-500 dark:hover:bg-gray-900\"\n     >\n       <div class=\"flex items-center gap-2\">\n         <HostDot state={entryState} class=\"shrink-0\" />\n         <span class=\"truncate font-semibold\" title={props.host}>\n           {props.host}\n         </span>\n+        <Show when={alertCount() > 0}>\n+          <span\n+            class=\"shrink-0 rounded-full bg-red-500/15 px-1.5 text-xs font-semibold text-red-600 dark:text-red-400\"\n+            title={`${alertCount()} alert${alertCount() === 1 ? \"\" : \"s\"}`}\n+          >\n+            {alertCount()}\n+          </span>\n+        </Show>\n         <span class={`ml-auto shrink-0 text-xs ${STATE[state()].text}`}>\n           {state()}\n         </span>\n       </div>\n \n       <Show\n         when={entryState().kind === \"connected\"}\n         fallback={\n           <div class=\"py-3 text-center text-xs text-gray-400 dark:text-gray-500\">\n             {STATE[state()].label}\n           </div>\n         }\n       >\n         <CardMetric\n           label=\"cpu\"\n           pct={cpuPct()}\n           detail={`${cpuPct().toFixed(0)}% · ${coreCount()} cores`}\n         />\n         <CardMetric label=\"mem\" pct={mem()} detail={memText()} />\n         <CardMetric label=\"disk\" pct={disk()} detail={diskText()} />\n         <div class=\"flex justify-between text-xs text-gray-500 dark:text-gray-400\">\n           <span>\n             load{\" \"}\n             <span class=\"font-semibold text-gray-700 dark:text-gray-300\">\n               {sys().loadAvg[0].toFixed(2)}\n             </span>{\" \"}\n             {sys().loadAvg[1].toFixed(2)} {sys().loadAvg[2].toFixed(2)}\n           </span>\n           <span>\n             up {formatUptime(sys().uptime)} · {sys().os}\n","exit_code":0,"status":"completed"}}
